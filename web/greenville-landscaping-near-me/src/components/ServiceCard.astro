---
interface Props {
  id: string;
  title: string;
  desc: string;
  icon: string;
}

const { id, title, desc, icon } = Astro.props;
---

<div class="card-service" id={id}>
  <div class="card-icon" style="width:56px;height:56px;margin-bottom:var(--space-3);">
    <Fragment set:html={icon} />
  </div>
  <h3 style="font-size:var(--text-h3);margin-bottom:var(--space-1);">{title}</h3>
  <p style="color:var(--color-text-muted);font-size:var(--text-small);line-height:var(--leading-body);">
    {desc}
  </p>
</div>
