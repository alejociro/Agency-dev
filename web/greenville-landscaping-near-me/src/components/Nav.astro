---
interface Props {
  currentPage?: string;
}
const { currentPage = '' } = Astro.props;
---

<nav class="nav nav-enter" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Greenville Landscaping — Home">
      <svg width="32" height="32" viewBox="0 0 32 32" aria-hidden="true" style="display:inline-block;vertical-align:middle;margin-right:0.5rem;">
        <circle cx="16" cy="16" r="14" fill="var(--color-primary)"/>
        <path d="M10 22c2-6 4-12 8-14 1 4-1 10-4 14h-4z" fill="var(--color-accent)"/>
        <path d="M14 22c3-5 6-10 9-11 0 4-2 9-5 11h-4z" fill="var(--color-secondary)" opacity="0.7"/>
      </svg>
      <span>Greenville<br/><strong style="color:var(--color-primary)">Landscaping</strong></span>
    </a>

    <div class="nav-links">
      <a href="/" class={`nav-link ${currentPage === 'home' ? 'active' : ''}`}>Home</a>
      <a href="/services" class={`nav-link ${currentPage === 'services' ? 'active' : ''}`}>Services</a>
      <a href="/about" class={`nav-link ${currentPage === 'about' ? 'active' : ''}`}>About</a>
      <a href="/contact" class={`nav-link ${currentPage === 'contact' ? 'active' : ''}`}>Contact</a>
      <a href="/contact" class="btn btn-primary" style="padding:0.625rem 1.5rem;font-size:var(--text-small);">Get Free Estimate</a>
    </div>

    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<!-- Mobile menu -->
<div class="nav-mobile" id="mobile-menu" role="dialog" aria-label="Mobile navigation">
  <a href="/" class={currentPage === 'home' ? 'active' : ''}>Home</a>
  <a href="/services" class={currentPage === 'services' ? 'active' : ''}>Services</a>
  <a href="/about" class={currentPage === 'about' ? 'active' : ''}>About</a>
  <a href="/contact" class={currentPage === 'contact' ? 'active' : ''}>Contact</a>
  <a href="/contact" class="btn btn-primary btn-lg" style="margin-top:var(--space-4);">Get Free Estimate</a>
  <div style="margin-top:var(--space-4);display:flex;align-items:center;gap:var(--space-2);color:var(--color-text-muted);font-size:var(--text-small);">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    <a href="tel:+18649001234" style="color:var(--color-primary);font-weight:600;">(864) 900-1234</a>
  </div>
</div>

<style>
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1.15;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }
  .nav-logo strong {
    font-weight: 700;
  }
</style>
