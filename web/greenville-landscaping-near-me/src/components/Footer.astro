---
const year = new Date().getFullYear();
const communities = [
  'Anderson', 'Easly', 'Fountain Inn', 'Greenville',
  'Greer', 'Duncan', 'Mauldin', 'Piedmont',
  'Powdersville', 'Simpsonville', 'Spartanburg', 'Taylors',
  'Travelers Rest', 'Marietta', 'Pickens'
];
---

<footer class="footer">
  <!-- Wave divider top -->
  <div class="divider-wave-inv" style="background:var(--color-text);margin-top:-1px;"></div>

  <div class="container" style="padding-top:var(--space-8);">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Greenville Landscaping — Home">
          <svg width="36" height="36" viewBox="0 0 32 32" aria-hidden="true">
            <circle cx="16" cy="16" r="14" fill="var(--color-primary)"/>
            <path d="M10 22c2-6 4-12 8-14 1 4-1 10-4 14h-4z" fill="var(--color-accent)"/>
            <path d="M14 22c3-5 6-10 9-11 0 4-2 9-5 11h-4z" fill="var(--color-secondary-light)" opacity="0.7"/>
          </svg>
          <span>Greenville Landscaping</span>
        </a>
        <p class="footer-muted" style="margin-top:var(--space-2);max-width:30ch;">
          Year-round lawn care trusted by 695+ homeowners across the Upstate.
        </p>
        <div class="footer-social" style="margin-top:var(--space-3);">
          <a href="https://www.google.com/search?q=Greenville+Landscaping+Near+Me,+LLC+Reviews" aria-label="Google Reviews" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="footer-heading">Quick Links</h4>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="footer-heading">Services</h4>
        <ul class="footer-links">
          <li><a href="/services#mowing">Lawn Mowing</a></li>
          <li><a href="/services#edging">Edging & Blowing</a></li>
          <li><a href="/services#hedges">Hedge Trimming</a></li>
          <li><a href="/services#debris">Debris Removal</a></li>
          <li><a href="/services#weed">Weed Treatment</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="footer-heading">Contact</h4>
        <ul class="footer-links footer-contact">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:+18647941315">(864) 794-1315</a>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Greenville, SC &amp; the Upstate
          </li>
        </ul>
      </div>
    </div>

    <!-- Service area -->
    <div class="footer-areas" data-animate="fade-up">
      <h4 class="footer-heading" style="margin-bottom:var(--space-2);">Service Area</h4>
      <p class="footer-muted" style="font-size:var(--text-small);">
        {communities.join(' · ')}
      </p>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-muted" style="font-size:var(--text-xs);">
        &copy; {year} Greenville Landscaping Near Me. All rights reserved.
      </p>
      <div class="footer-legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);

    @media (min-width: 640px) {
      grid-template-columns: repeat(2, 1fr);
    }
    @media (min-width: 1024px) {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
    }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-text-light);
    text-decoration: none;
  }

  .footer-heading {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-block-end: var(--space-3);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);

    & a {
      color: var(--color-text-light-muted);
      font-size: var(--text-small);
      transition: color var(--duration-fast) ease;

      &:hover { color: var(--color-primary); }
    }
  }

  .footer-contact li {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-text-light-muted);
    font-size: var(--text-small);

    & svg { flex-shrink: 0; color: var(--color-primary); }
  }

  .footer-social {
    display: flex;
    gap: var(--space-3);

    & a {
      color: var(--color-text-light-muted);
      transition: color var(--duration-fast) ease, transform var(--duration-fast) var(--ease-spring);

      &:hover {
        color: var(--color-primary);
        transform: translateY(-2px);
      }
    }
  }

  .footer-areas {
    margin-block-start: var(--space-8);
    padding-block-start: var(--space-6);
    border-block-start: 1px solid oklch(100% 0 0 / 0.08);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
    margin-block-start: var(--space-6);
    padding-block-start: var(--space-4);
    border-block-start: 1px solid oklch(100% 0 0 / 0.08);
  }

  .footer-legal {
    display: flex;
    gap: var(--space-4);

    & a {
      color: var(--color-text-light-muted);
      font-size: var(--text-xs);
      transition: color var(--duration-fast) ease;

      &:hover { color: var(--color-primary); }
    }
  }
</style>
