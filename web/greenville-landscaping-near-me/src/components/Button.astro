---
interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'ghost';
  size?: 'default' | 'lg';
  href?: string;
  type?: 'button' | 'submit';
  fullWidth?: boolean;
  [key: string]: any;
}

const {
  variant = 'primary',
  size = 'default',
  href,
  type = 'button',
  fullWidth = false,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
const classes = [
  'btn',
  `btn-${variant}`,
  size === 'lg' && 'btn-lg',
  fullWidth && 'btn-full'
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}

<style>
  .btn-full {
    width: 100%;
  }
</style>
