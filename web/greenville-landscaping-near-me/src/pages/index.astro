---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: 'mowing',
    title: 'Lawn Mowing',
    desc: 'Precision mowing at the right height for your grass type, leaving clean lines and a healthy, even cut every visit.',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="20" width="24" height="14" rx="3"/><circle cx="12" cy="38" r="4"/><circle cx="28" cy="38" r="4"/><path d="M32 28h6l4 6v4h-6"/><line x1="20" y1="12" x2="20" y2="20"/><path d="M14 14h12" stroke-dasharray="3 2"/></svg>`
  },
  {
    id: 'edging',
    title: 'Edging & Blowing',
    desc: 'Crisp edges along driveways, sidewalks and flower beds — finished with a clean blow-off that leaves zero clippings behind.',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M24 6v30"/><path d="M18 36h12"/><circle cx="24" cy="40" r="4"/><path d="M20 10l8 4M20 18l8 4"/><path d="M10 42c4-2 6-4 6-8M38 42c-4-2-6-4-6-8"/></svg>`
  },
  {
    id: 'hedges',
    title: 'Hedge Trimming',
    desc: 'Expert shaping and trimming that keeps hedges dense, healthy and looking sharp through every season.',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 30c0-10 8-20 16-20s16 10 16 20"/><line x1="24" y1="30" x2="24" y2="44"/><path d="M18 30v-6M30 30v-6"/><path d="M12 30h24" stroke="var(--color-accent)"/></svg>`
  },
  {
    id: 'debris',
    title: 'Debris Removal',
    desc: 'Leaves, branches and storm debris cleared fast — your property stays clean and hazard-free year-round.',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 8c-2 6 0 12 4 16l-6 14h24l-6-14c4-4 6-10 4-16"/><path d="M20 24h8" stroke="var(--color-accent)"/><circle cx="24" cy="16" r="2" fill="var(--color-primary)"/></svg>`
  },
  {
    id: 'weed',
    title: 'Weed Treatment',
    desc: 'Targeted weed control that protects your lawn without harming the grass — keeping your yard lush and weed-free.',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M24 44V24"/><path d="M24 24c-8-2-12-10-10-18 6 2 12 8 10 18z" fill="var(--color-primary)" opacity="0.12"/><path d="M24 24c-8-2-12-10-10-18 6 2 12 8 10 18z"/><path d="M24 30c6-1 10-7 9-14-5 1-10 6-9 14z" fill="var(--color-accent)" opacity="0.12"/><path d="M24 30c6-1 10-7 9-14-5 1-10 6-9 14z" stroke="var(--color-accent)"/></svg>`
  },
  {
    id: 'seasonal',
    title: 'Seasonal Packages',
    desc: 'Year-round care plans tailored to your property — from spring cleanup to fall leaf removal, we handle every season.',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="16"/><path d="M24 8v4M24 36v4M8 24h4M36 24h4"/><circle cx="24" cy="24" r="6" fill="var(--color-primary)" opacity="0.12"/><path d="M18 18l2 2M28 28l2 2M28 18l-2 2M18 28l-2 2" stroke="var(--color-accent)"/></svg>`
  }
];

const testimonials = [
  { name: 'Robert C.', text: 'Used this company to have compost and mulch laid around my home. Paige maintained great communication on the project and Jackie and the Landscaping crew did an excellent job. Would highly recommend this company!', rating: 5 },
  { name: 'Hunter G.', text: 'They have always gone above and beyond to get something done right when needed. Would highly recommend working with them.', rating: 5 },
  { name: 'Tara D.', text: 'Professional and reliable. Maintained our property efficiently and we never had any trouble with scheduling. Highly recommend.', rating: 5 },
  { name: 'Terry D.', text: 'We were so happy with the work that Greenville Landscaping Near Me did a few weeks ago, we asked them back to complete a tough leaf removal in our back yard.', rating: 5 }
];

const steps = [
  { num: '01', title: 'Schedule a Visit', desc: 'Book a free property visit online or by phone. We assess your yard and listen to what you want.' },
  { num: '02', title: 'Get Your Plan', desc: 'Receive a personalized care plan with clear pricing — no hidden fees, no surprises.' },
  { num: '03', title: 'We Get to Work', desc: 'Our crew arrives on schedule with professional equipment. You relax while we handle everything.' },
  { num: '04', title: 'Enjoy Your Yard', desc: 'Come home to a pristine lawn, every time. We follow up to make sure you\'re 100% satisfied.' }
];
---

<BaseLayout
  title="Greenville Landscaping Near Me | Expert Lawn Care in Greenville SC"
  description="Professional lawn mowing, hedge trimming & year-round yard care for 695+ homeowners in Greenville, SC. Schedule your free property visit today."
>
  <Nav currentPage="home" />

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero" id="hero">
    <!-- Decorative blobs -->
    <div class="blob blob-1" style="top:10%;right:5%;" aria-hidden="true"></div>
    <div class="blob blob-2" style="bottom:20%;left:8%;" aria-hidden="true"></div>

    <div class="container hero-content">
      <span class="badge hero-badge">Trusted by 695+ Homeowners</span>

      <h1 class="hero-title" style="font-size:var(--text-hero);max-width:14ch;">
        Your Yard,<br/>
        <span class="text-gradient">Perfected.</span>
      </h1>

      <p class="hero-sub" style="font-size:clamp(1.1rem,1.5vw,1.3rem);color:var(--color-text-muted);max-width:48ch;">
        Year-round professional lawn care for homeowners across Greenville, SC and the Upstate.
        From mowing to seasonal cleanups — we handle it all.
      </p>

      <div class="hero-ctas" style="display:flex;flex-wrap:wrap;gap:var(--space-2);margin-top:var(--space-4);">
        <a href="/contact" class="btn btn-primary btn-lg">
          Schedule a Free Visit
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="#services" class="btn btn-ghost" style="font-size:var(--text-body);">
          View Services →
        </a>
      </div>

      <div class="hero-proof" style="display:flex;flex-wrap:wrap;gap:var(--space-6);margin-top:var(--space-8);padding-top:var(--space-4);border-top:1px solid var(--color-divider);">
        <div style="display:flex;align-items:center;gap:var(--space-1);">
          <div style="display:flex;">
            {[1,2,3,4,5].map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <span style="font-size:var(--text-small);color:var(--color-text-muted);font-weight:500;">5.0 on Google</span>
        </div>
        <div style="font-size:var(--text-small);color:var(--color-text-muted);">
          <strong style="color:var(--color-text);">55+</strong> active contracts this year
        </div>
        <div style="font-size:var(--text-small);color:var(--color-text-muted);">
          <strong style="color:var(--color-text);">15</strong> communities served
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero-scroll scroll-indicator" style="position:absolute;bottom:var(--space-6);left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
      <span style="font-size:var(--text-xs);color:var(--color-text-muted);letter-spacing:0.1em;text-transform:uppercase;">Scroll</span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
    </div>
  </section>

  <!-- ═══════════════ STATS BAR ═══════════════ -->
  <section class="stats-bar bg-dark" style="position:relative;z-index:2;">
    <div class="divider-wave" style="background:var(--color-secondary);position:absolute;top:-1px;left:0;right:0;"></div>
    <div class="container" style="padding-block:var(--space-12);">
      <div class="stats-grid" data-animate="stagger">
        <div class="stat-item" style="text-align:center;">
          <span class="stat-number" data-counter data-target="695" style="color:var(--color-primary);">0</span>
          <span class="stat-suffix" style="font-family:var(--font-display);font-size:var(--text-h2);font-weight:700;color:var(--color-primary);">+</span>
          <p class="stat-label" style="color:var(--color-text-light-muted);">Happy Homeowners</p>
        </div>
        <div class="stat-item" style="text-align:center;">
          <span class="stat-number" data-counter data-target="55" style="color:var(--color-primary);">0</span>
          <span class="stat-suffix" style="font-family:var(--font-display);font-size:var(--text-h2);font-weight:700;color:var(--color-primary);">+</span>
          <p class="stat-label" style="color:var(--color-text-light-muted);">Annual Contracts</p>
        </div>
        <div class="stat-item" style="text-align:center;">
          <span class="stat-number" data-counter data-target="40" style="color:var(--color-primary);">0</span>
          <span class="stat-suffix" style="font-family:var(--font-display);font-size:var(--text-h2);font-weight:700;color:var(--color-primary);">+</span>
          <p class="stat-label" style="color:var(--color-text-light-muted);">Repeat Projects</p>
        </div>
        <div class="stat-item" style="text-align:center;">
          <span class="stat-number" data-counter data-target="15" style="color:var(--color-primary);">0</span>
          <p class="stat-label" style="color:var(--color-text-light-muted);">Communities Served</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ SERVICES ═══════════════ -->
  <section class="section" id="services">
    <div class="container">
      <div style="text-align:center;max-width:600px;margin-inline:auto;margin-bottom:var(--space-8);">
        <span class="section-tag" data-animate="fade-up">What We Do</span>
        <h2 data-animate="fade-up" data-delay="100" style="margin-bottom:var(--space-3);">
          Everything Your Lawn Needs,<br/><span class="text-gradient">Nothing It Doesn't</span>
        </h2>
        <p data-animate="fade-up" data-delay="200" style="color:var(--color-text-muted);margin-inline:auto;">
          From weekly mowing to seasonal deep care — our services cover every inch of your property, every month of the year.
        </p>
      </div>

      <div class="grid-services" data-animate="stagger">
        {services.map((s) => (
          <div class="card-service" id={s.id}>
            <div class="card-icon" style="width:56px;height:56px;margin-bottom:var(--space-3);" set:html={s.icon} />
            <h3 style="font-size:var(--text-h3);margin-bottom:var(--space-1);">{s.title}</h3>
            <p style="color:var(--color-text-muted);font-size:var(--text-small);line-height:var(--leading-body);">{s.desc}</p>
          </div>
        ))}
      </div>

      <div style="text-align:center;margin-top:var(--space-8);" data-animate="fade-up">
        <a href="/services" class="btn btn-secondary">See All Service Details →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ WHY US ═══════════════ -->
  <section class="section" style="background:var(--color-surface);position:relative;overflow:hidden;">
    <div class="leaf-deco" style="top:15%;left:5%;width:30px;height:30px;animation-delay:-2s;" aria-hidden="true"></div>
    <div class="leaf-deco" style="bottom:20%;right:8%;width:24px;height:24px;animation-delay:-5s;" aria-hidden="true"></div>

    <div class="container">
      <div class="grid-asymmetric" style="align-items:center;">
        <div>
          <span class="section-tag" data-animate="fade-right">Why Homeowners Choose Us</span>
          <h2 data-animate="fade-right" data-delay="100" style="margin-bottom:var(--space-6);">
            Not Just Another<br/>Lawn Service
          </h2>

          <div class="why-list" style="display:flex;flex-direction:column;gap:var(--space-4);">
            <div class="why-item" data-animate="fade-right" data-delay="200" style="display:flex;gap:var(--space-3);align-items:flex-start;">
              <div style="flex-shrink:0;width:48px;height:48px;border-radius:var(--radius-lg);background:var(--color-primary-glow);display:flex;align-items:center;justify-content:center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <div>
                <h3 style="font-size:var(--text-body);font-weight:700;margin-bottom:0.25rem;">695+ Homeowners Can't Be Wrong</h3>
                <p style="font-size:var(--text-small);color:var(--color-text-muted);">Real track record, real results. Our client base speaks louder than any ad — and 40+ projects come back to us every year.</p>
              </div>
            </div>

            <div class="why-item" data-animate="fade-right" data-delay="300" style="display:flex;gap:var(--space-3);align-items:flex-start;">
              <div style="flex-shrink:0;width:48px;height:48px;border-radius:var(--radius-lg);background:var(--color-accent-glow);display:flex;align-items:center;justify-content:center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></svg>
              </div>
              <div>
                <h3 style="font-size:var(--text-body);font-weight:700;margin-bottom:0.25rem;">Consistent, Year-Round Schedules</h3>
                <p style="font-size:var(--text-small);color:var(--color-text-muted);">Weekly, bi-weekly or seasonal — you choose the frequency. We show up on time, every time, rain plan included.</p>
              </div>
            </div>

            <div class="why-item" data-animate="fade-right" data-delay="400" style="display:flex;gap:var(--space-3);align-items:flex-start;">
              <div style="flex-shrink:0;width:48px;height:48px;border-radius:var(--radius-lg);background:var(--color-secondary-glow);display:flex;align-items:center;justify-content:center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary-light)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <h3 style="font-size:var(--text-body);font-weight:700;margin-bottom:0.25rem;">15 Communities, One Standard</h3>
                <p style="font-size:var(--text-small);color:var(--color-text-muted);">From Simpsonville to Travelers Rest, Taylors to Five Forks — same quality, same attention to detail, wherever you are in the Upstate.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Visual — imagen real de landscaping -->
        <div data-animate="fade-left" style="position:relative;">
          <div class="why-image-wrapper img-hover">
            <img
              src="https://images.unsplash.com/photo-1592417817098-8fd3d9eb14a5?auto=format&fit=crop&w=800&q=80"
              alt="Freshly mowed lawn with crisp edging lines along a residential walkway in Greenville, SC"
              width="800"
              height="1000"
              loading="lazy"
              decoding="async"
              style="width:100%;height:100%;object-fit:cover;"
            />
            <div style="position:absolute;bottom:0;left:0;right:0;padding:var(--space-6);background:linear-gradient(transparent, oklch(0 0 0 / 0.55));">
              <p style="font-family:var(--font-display);font-size:var(--text-h3);color:var(--color-text-light);font-weight:600;">
                "Your yard is our reputation."
              </p>
            </div>
          </div>
          <!-- Offset badge -->
          <div style="position:absolute;bottom:-1.5rem;left:-1rem;background:var(--color-accent);color:var(--color-text-light);border-radius:var(--radius-xl);padding:var(--space-2) var(--space-3);font-weight:700;font-size:var(--text-small);box-shadow:var(--shadow-lg);z-index:2;">
            ★ 5.0 Google Rating
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ PROCESS ═══════════════ -->
  <section class="section" id="process">
    <div class="container">
      <div style="text-align:center;max-width:550px;margin-inline:auto;margin-bottom:var(--space-8);">
        <span class="section-tag" data-animate="fade-up">How It Works</span>
        <h2 data-animate="fade-up" data-delay="100">
          From Call to <span class="text-gradient">Curb Appeal</span><br/>in 4 Steps
        </h2>
      </div>

      <div class="process-grid">
        {steps.map((step, i) => (
          <div class="process-step" data-animate="fade-up" data-delay={String((i + 1) * 100)}>
            <div class="process-num">{step.num}</div>
            <div class="process-line" aria-hidden="true"></div>
            <h3 style="font-size:var(--text-h3);margin-bottom:var(--space-1);">{step.title}</h3>
            <p style="font-size:var(--text-small);color:var(--color-text-muted);">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA INTERMEDIO ═══════════════ -->
  <section style="background:linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-secondary) 100%);padding-block:var(--space-12);position:relative;overflow:hidden;">
    <div class="blob blob-2" style="top:-30%;right:-10%;opacity:0.1;width:400px;height:400px;" aria-hidden="true"></div>
    <div class="container" style="text-align:center;position:relative;z-index:2;">
      <h2 data-animate="fade-up" style="color:var(--color-text-light);font-size:var(--text-h1);margin-bottom:var(--space-3);max-width:18ch;margin-inline:auto;">
        Your Neighbors Already Called Us
      </h2>
      <p data-animate="fade-up" data-delay="100" style="color:var(--color-text-light-muted);max-width:50ch;margin-inline:auto;margin-bottom:var(--space-6);">
        Spring is here and spots are filling fast. Get your free property assessment before our schedule locks for the season.
      </p>
      <div data-animate="fade-up" data-delay="200">
        <a href="/contact" class="btn btn-accent btn-lg">
          Get Your Free Spring Estimate
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ TESTIMONIALS ═══════════════ -->
  <section class="section" id="testimonials">
    <div class="container">
      <div style="text-align:center;max-width:550px;margin-inline:auto;margin-bottom:var(--space-8);">
        <span class="section-tag" data-animate="fade-up">What Clients Say</span>
        <h2 data-animate="fade-up" data-delay="100">
          Real Results,<br/><span class="text-gradient">Real Homeowners</span>
        </h2>
      </div>

      <div class="testimonials-autoscroll" data-animate="fade-up" data-delay="200">
        <div class="testimonials-track-auto">
          {/* Original cards */}
          {testimonials.map((t) => (
            <div class="card-testimonial">
              <div style="display:flex;gap:0.25rem;margin-bottom:var(--space-2);">
                {[1,2,3,4,5].map(() => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ))}
              </div>
              <p style="font-size:var(--text-body);line-height:var(--leading-body);color:var(--color-text);margin-bottom:var(--space-3);font-style:italic;">
                &ldquo;{t.text}&rdquo;
              </p>
              <div style="display:flex;align-items:center;gap:var(--space-2);">
                <div style="width:40px;height:40px;border-radius:var(--radius-full);background:var(--color-primary);display:flex;align-items:center;justify-content:center;color:var(--color-text-light);font-family:var(--font-display);font-weight:700;font-size:var(--text-small);">
                  {t.name.charAt(0)}
                </div>
                <div>
                  <p style="font-weight:600;font-size:var(--text-small);">{t.name}</p>
                  <p style="font-size:var(--text-xs);color:var(--color-text-muted);">Greenville, SC Homeowner</p>
                </div>
              </div>
            </div>
          ))}
          {/* Duplicated cards for seamless infinite loop */}
          {testimonials.map((t) => (
            <div class="card-testimonial" aria-hidden="true">
              <div style="display:flex;gap:0.25rem;margin-bottom:var(--space-2);">
                {[1,2,3,4,5].map(() => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ))}
              </div>
              <p style="font-size:var(--text-body);line-height:var(--leading-body);color:var(--color-text);margin-bottom:var(--space-3);font-style:italic;">
                &ldquo;{t.text}&rdquo;
              </p>
              <div style="display:flex;align-items:center;gap:var(--space-2);">
                <div style="width:40px;height:40px;border-radius:var(--radius-full);background:var(--color-primary);display:flex;align-items:center;justify-content:center;color:var(--color-text-light);font-family:var(--font-display);font-weight:700;font-size:var(--text-small);">
                  {t.name.charAt(0)}
                </div>
                <div>
                  <p style="font-weight:600;font-size:var(--text-small);">{t.name}</p>
                  <p style="font-size:var(--text-xs);color:var(--color-text-muted);">Greenville, SC Homeowner</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

