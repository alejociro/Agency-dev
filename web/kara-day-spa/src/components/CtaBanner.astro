---
---

<section class="cta-banner full-bleed">
  <div class="cta-inner" data-animate="scale-in">
    <div class="container cta-content">
      <span class="cta-label">Limited Availability</span>
      <h2>Your Escape Is<br />One Call Away</h2>
      <p>
        Appointments fill quickly — especially for our signature massage
        and facial packages. Don't wait to feel your best.
      </p>
      <div class="cta-actions">
        <a href="https://www.secure-booker.com/karaspa/MakeAppointment/Search.aspx" target="_blank" rel="noopener noreferrer" class="btn-primary btn-cta">
          Book Online Now
        </a>
        <a href="tel:+18642335352" class="btn-cta-ghost">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M6.6 8.4c.9 1.8 2.4 3.3 4.2 4.2l1.4-1.4c.2-.2.5-.2.7-.1 1 .3 2 .5 3.1.5.3 0 .5.2.5.5v3c0 .3-.2.5-.5.5C7.2 15.6 1 9.4 1 2.5c0-.3.2-.5.5-.5h3c.3 0 .5.2.5.5 0 1.1.2 2.1.5 3.1.1.2 0 .5-.1.7L4 8.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Or call (864) 233-5352
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    position: relative;
  }

  .cta-inner {
    background: linear-gradient(
      135deg,
      var(--color-primary-dark) 0%,
      var(--color-primary) 60%,
      oklch(50% 0.09 195) 100%
    );
    padding-block: var(--space-12);
    position: relative;
    overflow: hidden;

    &::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size: 256px;
      opacity: 0.06;
      pointer-events: none;
    }

    &::after {
      content: '';
      position: absolute;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: oklch(68% 0.1 70 / 0.08);
      top: -200px;
      right: -100px;
      filter: blur(80px);
      pointer-events: none;
    }
  }

  .cta-content {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .cta-label {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-accent-light);
  }

  .cta-content h2 {
    color: var(--color-bg);
    font-size: var(--text-h1);
    text-align: center;
  }

  .cta-content p {
    color: oklch(88% 0.01 60);
    text-align: center;
    max-width: 50ch;
    margin-inline: auto;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-block-start: var(--space-3);
  }

  .btn-cta {
    padding: 1rem 2.5rem;
    font-size: var(--text-body);
  }

  .btn-cta-ghost {
    color: oklch(90% 0.01 60);
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    transition: color var(--duration-fast) var(--ease-out);

    &:hover {
      color: var(--color-accent-light);
    }
  }
</style>
