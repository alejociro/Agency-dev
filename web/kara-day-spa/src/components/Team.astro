---
import SectionHeader from './ui/SectionHeader.astro';

const team = [
  {
    name: 'Alicia Moreau',
    role: 'Co-Founder',
    initials: 'AM',
    description: 'Co-founded Kara Spa Group in 2005 alongside her daughter Korri. Alicia brings decades of dedication to creating a welcoming, world-class spa experience in downtown Greenville.',
    color: 'var(--color-primary)',
  },
  {
    name: 'Korri Moreau Henson',
    role: 'Co-Founder',
    initials: 'KH',
    description: 'Mother-daughter team with Alicia since 2005. Korri helps lead the vision for Kara Spa, ensuring every guest experiences affordable luxury in a beautiful, tranquil environment.',
    color: 'var(--color-accent)',
  },
  {
    name: 'Tara Hazouri',
    role: 'Chiropractor & Massage Therapist',
    initials: 'TH',
    description: 'Practicing since 2001, Tara graduated from Sherman College of Chiropractic in Spartanburg, SC. She combines chiropractic care with massage for a holistic approach to body wellness.',
    color: 'var(--color-secondary)',
  },
  {
    name: 'Meredith Buras',
    role: 'Massage Therapist',
    initials: 'MB',
    description: 'With a background from UNC-Wilmington and training at The Ballantyne Spa in Charlotte, Meredith specializes in deep tissue, aromatherapy, prenatal, and reflexology massage.',
    color: 'var(--color-primary-light)',
  },
];
---

<section class="section-alt" id="team">
  <div class="container">
    <SectionHeader
      tag="Our Team"
      title="In Expert <em>Hands</em>"
      subtitle="Founded in 2005 by the mother-daughter team of Alicia and Korri, our licensed professionals bring over 40 years of combined experience to every treatment."
      align="center"
    />

    <div class="team-grid" data-animate="stagger">
      {team.map((member) => (
        <article class="team-card">
          <div class="team-avatar" style={`--avatar-color: ${member.color}`}>
            <span>{member.initials}</span>
          </div>
          <h3>{member.name}</h3>
          <span class="team-role">{member.role}</span>
          <p>{member.description}</p>
        </article>
      ))}
    </div>

    <div class="team-badge" data-animate="fade-up" data-delay="300">
      <div class="badge-item">
        <span class="badge-number" data-counter="20" data-suffix="+">20+</span>
        <span class="badge-label">Years in Greenville</span>
      </div>
      <div class="badge-divider" aria-hidden="true"></div>
      <div class="badge-item">
        <span class="badge-number" data-counter="40" data-suffix="+">40+</span>
        <span class="badge-label">Years Combined Experience</span>
      </div>
      <div class="badge-divider" aria-hidden="true"></div>
      <div class="badge-item">
        <span class="badge-number">Family</span>
        <span class="badge-label">Owned & Operated</span>
      </div>
    </div>
  </div>
</section>

<style>
  .team-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .team-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .team-avatar {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-blob);
    background-color: var(--avatar-color, var(--color-primary));
    display: flex;
    align-items: center;
    justify-content: center;
    margin-block-end: var(--space-1);
    transition: border-radius var(--duration-slow) var(--ease-out);

    & span {
      font-family: var(--font-display);
      font-size: var(--text-h2);
      font-weight: 500;
      color: var(--color-bg);
    }
  }

  .team-card:hover .team-avatar {
    border-radius: 70% 30% 30% 70% / 70% 70% 30% 30%;
  }

  .team-card h3 {
    font-size: var(--text-h4);
  }

  .team-role {
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .team-card p {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    max-width: 30ch;
    text-align: center;
  }

  /* Trust badges */
  .team-badge {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-6);
    margin-block-start: var(--space-10);
    padding: var(--space-6);
    background-color: var(--color-surface);
    border-radius: var(--radius-xl);
  }

  .badge-item {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .badge-number {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    color: var(--color-primary-dark);
    font-variant-numeric: tabular-nums;
  }

  .badge-label {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
  }

  .badge-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
    display: none;
  }

  @media (min-width: 640px) {
    .badge-divider {
      display: block;
    }
  }
</style>
