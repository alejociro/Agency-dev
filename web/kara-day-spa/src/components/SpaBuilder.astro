---

<section class="section" id="spa-builder">
  <div class="container">
    <div class="section-header section-header--center" data-animate="fade-up">
      <span class="label" style="justify-content: center;">Build Your Spa Day</span>
      <h2>Design Your <em>Escape</em></h2>
      <p>Browse our services by category and build your perfect spa day. Select treatments to see your total.</p>
    </div>

    <div class="builder-wrap" data-animate="fade-up" data-delay="200">
      <!-- Category tabs -->
      <div class="builder-tabs" role="tablist" aria-label="Service categories">
        {categories.map((cat, i) => (
          <button
            role="tab"
            class:list={['builder-tab', { active: i === 0 }]}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${cat.id}`}
            data-tab={cat.id}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <div class="builder-body">
        <!-- Service panels -->
        <div class="builder-panels">
          {categories.map((cat, i) => (
            <div
              role="tabpanel"
              id={`panel-${cat.id}`}
              class:list={['builder-panel', { active: i === 0 }]}
              data-panel={cat.id}
            >
              {cat.services.map((svc) => (
                <label class="builder-service">
                  <input type="checkbox" name="service" value={svc.name} data-price={svc.price} />
                  <span class="builder-check" aria-hidden="true">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                      <path d="M2 6.5l2.5 2.5 5.5-5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span class="builder-name">{svc.name}</span>
                  <span class="builder-price">${svc.price}</span>
                </label>
              ))}
            </div>
          ))}
        </div>

        <!-- Running total sidebar -->
        <aside class="builder-summary">
          <h4>Your Spa Day</h4>
          <div class="builder-selected" id="builder-selected">
            <p class="builder-empty">Select services to build your perfect day.</p>
          </div>
          <hr class="menu-divider" />
          <div class="builder-total-row">
            <span>Estimated Total</span>
            <span class="builder-total" id="builder-total">$0</span>
          </div>
          <a href="https://www.secure-booker.com/karaspa/MakeAppointment/Search.aspx" target="_blank" rel="noopener noreferrer" class="btn-primary builder-book">
            Book Selected Services
          </a>
          <p class="builder-note">Prices are estimates. Final pricing confirmed at booking.</p>
        </aside>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  'use strict';

  // Tab switching
  const tabs = document.querySelectorAll('.builder-tab');
  const panels = document.querySelectorAll('.builder-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach((t) => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach((p) => p.classList.remove('active'));
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const panel = document.getElementById('panel-' + target);
      if (panel) panel.classList.add('active');
    });
  });

  // Service selection & total
  const checkboxes = document.querySelectorAll('.builder-service input[type="checkbox"]');
  const selectedEl = document.getElementById('builder-selected');
  const totalEl = document.getElementById('builder-total');

  function updateSummary() {
    const checked = Array.from(checkboxes).filter((cb) => cb.checked);
    let total = 0;
    let html = '';

    if (checked.length === 0) {
      html = '<p class="builder-empty">Select services to build your perfect day.</p>';
    } else {
      checked.forEach((cb) => {
        const price = parseInt(cb.dataset.price, 10);
        total += price;
        html += '<div class="builder-line"><span>' + cb.value + '</span><span>$' + price + '</span></div>';
      });
    }

    if (selectedEl) selectedEl.innerHTML = html;
    if (totalEl) totalEl.textContent = '$' + total;
  }

  checkboxes.forEach((cb) => {
    cb.addEventListener('change', updateSummary);
  });
})();
</script>

<style>
  .builder-wrap {
    background-color: var(--color-surface);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border-subtle);
  }

  /* Tabs */
  .builder-tabs {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg-alt);
  }

  .builder-tabs::-webkit-scrollbar { display: none; }

  .builder-tab {
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    background: none;
    border: none;
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    position: relative;
    transition: color var(--duration-fast) var(--ease-out);
    white-space: nowrap;

    &::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: var(--space-4);
      right: var(--space-4);
      height: 2px;
      background-color: var(--color-accent);
      transform: scaleX(0);
      transition: transform var(--duration-normal) var(--ease-out);
    }

    &:hover { color: var(--color-primary); }

    &.active {
      color: var(--color-primary-dark);

      &::after { transform: scaleX(1); }
    }
  }

  /* Body */
  .builder-body {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 360px;
  }

  @media (min-width: 768px) {
    .builder-body {
      grid-template-columns: 1fr 300px;
    }
  }

  /* Panels */
  .builder-panels {
    padding: var(--space-4);
  }

  .builder-panel {
    display: none;
    flex-direction: column;
    gap: 2px;

    &.active { display: flex; }
  }

  .builder-service {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out);

    &:hover { background-color: var(--color-bg); }
  }

  .builder-service input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .builder-check {
    width: 22px;
    height: 22px;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all var(--duration-fast) var(--ease-out);
    color: transparent;
  }

  .builder-service input:checked ~ .builder-check {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-bg);
  }

  .builder-service input:focus-visible ~ .builder-check {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .builder-name {
    flex: 1;
    font-size: var(--text-small);
    color: var(--color-text);
  }

  .builder-price {
    font-family: var(--font-display);
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-accent-dark);
    flex-shrink: 0;
  }

  /* Summary sidebar */
  .builder-summary {
    padding: var(--space-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  @media (min-width: 768px) {
    .builder-summary {
      border-top: none;
      border-left: 1px solid var(--color-border);
      background-color: var(--color-bg);
    }
  }

  .builder-summary h4 {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .builder-selected {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-height: 80px;
  }

  .builder-empty {
    font-size: var(--text-small);
    color: var(--color-text-light);
    font-style: italic;
    max-width: none;
  }

  :global(.builder-line) {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    font-size: var(--text-small);
    color: var(--color-text);
    padding-block: 2px;
  }

  :global(.builder-line span:last-child) {
    font-weight: 500;
    color: var(--color-accent-dark);
    flex-shrink: 0;
  }

  .menu-divider {
    height: 1px;
    background: var(--color-border);
    border: none;
  }

  .builder-total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .builder-total-row > span:first-child {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .builder-total {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    color: var(--color-primary-dark);
  }

  .builder-book {
    width: 100%;
    text-align: center;
  }

  .builder-note {
    font-size: var(--text-label);
    color: var(--color-text-light);
    text-align: center;
    max-width: none;
  }
</style>
