---
interface Props {
  tag?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  animate?: string;
}

const { tag, title, subtitle, align = 'left', animate = 'fade-up' } = Astro.props;
const isCenter = align === 'center';
---

<div
  class:list={['section-header', { 'section-header--center': isCenter }]}
  data-animate={animate}
>
  {tag && <span class="label" style={isCenter ? 'justify-content: center;' : ''}>{tag}</span>}
  <h2 set:html={title} />
  {subtitle && <p set:html={subtitle} />}
</div>

<style>
  .section-header--center {
    text-align: center;
    margin-inline: auto;

    & p {
      margin-inline: auto;
    }
  }

  h2 :global(em) {
    color: var(--color-accent);
    font-style: italic;
  }
</style>
