---
import '../styles/design-system.css';
import '../styles/animations.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical = 'https://karaspa.com/' } = Astro.props;
const ogImage = `${canonical}og-image.jpg`;
const siteName = 'Kara Day Spa';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="day spa greenville sc, massage greenville, facials greenville, body wraps, pedicure, chiropractic, nail care, spa packages, downtown greenville spa, wellness spa" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Geo -->
    <meta name="geo.region" content="US-SC" />
    <meta name="geo.placename" content="Greenville" />

    <!-- Fonts — preconnect + swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Jost:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#226D7A" />

    <!-- Schema.org JSON-LD: HealthAndBeautyBusiness + DaySpa -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["HealthAndBeautyBusiness", "DaySpa"],
      "name": "Kara Day Spa",
      "description": "Full-service day spa offering massage, facials, body wraps, nail care, pedicures and on-site chiropractic services in downtown Greenville, SC.",
      "url": "https://karaspa.com/",
      "telephone": "+1-864-233-5352",
      "email": "relax@karaspa.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "105 Lavinia Ave",
        "addressLocality": "Greenville",
        "addressRegion": "SC",
        "postalCode": "29601",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 34.8526,
        "longitude": -82.4012
      },
      "priceRange": "$$",
      "image": ogImage,
      "sameAs": [
        "https://www.facebook.com/kara.spa/",
        "https://www.instagram.com/karaspaandboutique/"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Spa Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Signature Integrative Massage",
              "description": "90-minute deep-tissue and neuro-muscular massage therapy",
              "offers": { "@type": "Offer", "price": "150.00", "priceCurrency": "USD" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Kara Ultimate Facial",
              "description": "90-minute luxurious facial with microderm exfoliation, light therapy and high-frequency treatments",
              "offers": { "@type": "Offer", "price": "180.00", "priceCurrency": "USD" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Kara Ultimate Pedicure",
              "description": "Hot stone pedicure with soothing foot soak, warm stone massage, exfoliation and nail care",
              "offers": { "@type": "Offer", "price": "90.00", "priceCurrency": "USD" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Kara Wellness Package",
              "description": "60-minute wellness facial and 60-minute integrative massage with skin care samples",
              "offers": { "@type": "Offer", "price": "184.50", "priceCurrency": "USD" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Kara Ultimate Package",
              "description": "6 hours of comprehensive spa treatments — the full sanctuary experience",
              "offers": { "@type": "Offer", "price": "443.00", "priceCurrency": "USD" }
            }
          }
        ]
      }
    })} />

    <!-- Performance: content-visibility for below-the-fold sections -->
    <style is:inline>
      section:not(#hero) {
        content-visibility: auto;
        contain-intrinsic-size: auto 600px;
      }
    </style>
  </head>
  <body class="grain">
    <!-- Reading progress bar -->
    <div class="reading-progress" aria-hidden="true"></div>

    <slot />

    <!-- Animations JS -->
    <script src="../scripts/animations.js"></script>
  </body>
</html>
