---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Specials from '../components/Specials.astro';
import SpaBuilder from '../components/SpaBuilder.astro';
import Packages from '../components/Packages.astro';
import LunchMenu from '../components/LunchMenu.astro';
import HowToSpa from '../components/HowToSpa.astro';
import Testimonials from '../components/Testimonials.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Team from '../components/Team.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Kara Day Spa — Day Spa & Massage in Downtown Greenville, SC"
  description="Kara Day Spa offers massage, facials, body wraps, nail care, pedicures and on-site chiropractic in downtown Greenville, SC. Book your escape — by appointment only."
>
  <Nav />
  <main>
    <Hero />
    <Services />
    <Specials />
    <SpaBuilder />
    <Packages />
    <LunchMenu />
    <HowToSpa />
    <Testimonials />
    <CtaBanner />
    <Team />
    <FAQ />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
