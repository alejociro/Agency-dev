---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/design-system.css';
import '../styles/animations.css';
---
<BaseLayout
  title="The WRKT Greenville | Reformer Pilates Studio on E North St"
  description="Join The WRKT Greenville for unlimited Reformer Pilates classes. Flexible memberships from $150/mo. Located at 1631 E North St, Greenville, SC 29607."
  canonical="https://the-wrkt-greenville.vercel.app"
>

<!-- ===== NAVBAR ===== -->
<header class="navbar nav-enter" role="banner">
  <div class="navbar-inner container">
    <a href="/" class="site-logo" aria-label="The WRKT Home">
      <span class="logo-text">the<strong>wrkt</strong></span>
    </a>

    <nav class="nav-menu" role="navigation" aria-label="Main navigation">
      <a href="#about" class="nav-link">The Training</a>
      <a href="#memberships" class="nav-link">Memberships</a>
      <a href="#studio" class="nav-link">Our Studio</a>
      <a href="#faq" class="nav-link">FAQ</a>
      <a href="#contact" class="nav-link">Contact</a>
      <a href="#memberships" class="btn btn-primary btn-nav" data-magnetic>Book Now</a>
    </nav>

    <button class="nav-toggle" aria-expanded="false" aria-label="Toggle navigation">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </div>
</header>

<!-- ===== HERO ===== -->
<section id="hero" class="hero" data-label="Home">
  <div class="hero-bg-wrap">
    <img
      src="https://images.unsplash.com/photo-1518611012118-696072aa579a?w=1920&q=80&auto=format&fit=crop"
      alt="Reformer Pilates studio with natural light and equipment"
      class="hero-bg-img"
      width="1920"
      height="1080"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero-overlay"></div>
    <!-- Breathing pulse rings — Pilates breathing rhythm -->
    <div class="hero-breath" aria-hidden="true">
      <div class="breath-ring breath-ring-core"></div>
      <div class="breath-ring"></div>
      <div class="breath-ring breath-ring-outer"></div>
    </div>
  </div>

  <div class="container hero-content hero-content--dark">
    <span class="hero-tag text-label">Reformer Pilates Studio — Greenville, SC</span>
    <h1 class="hero-title text-hero" data-split>The wrkt you've been waiting for.</h1>
    <p class="hero-sub">Unlimited Reformer Pilates classes with flexible memberships.<br>Sculpt, strengthen, and move with precision.</p>
    <div class="hero-cta">
      <a href="#memberships" class="btn btn-primary btn-lg" data-magnetic>Book Your First Class</a>
      <a href="#about" class="btn btn-outline-light">Explore The Training <span aria-hidden="true">&darr;</span></a>
    </div>
    <div class="hero-proof">
      <div class="proof-item">
        <span class="proof-number" data-counter data-target="185" data-prefix="$">$0</span>
        <span class="proof-label">Unlimited / Month</span>
      </div>
      <div class="proof-divider" aria-hidden="true"></div>
      <div class="proof-item">
        <span class="proof-number" data-counter data-target="35" data-prefix="$">$0</span>
        <span class="proof-label">Drop-In Class</span>
      </div>
      <div class="proof-divider" aria-hidden="true"></div>
      <div class="proof-item">
        <span class="proof-number">E North St</span>
        <span class="proof-label">Greenville, SC</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>
</section>

<!-- ===== ABOUT / WHAT IS REFORMER PILATES ===== -->
<section id="about" class="section" data-label="About">
  <div class="container">
    <div class="about-grid">
      <div class="about-content" data-animate="fade-up">
        <span class="section-tag">The Training</span>
        <h2>What is Reformer Pilates?</h2>
        <p>Reformer Pilates is a full-body workout performed on a specialized sliding carriage with adjustable resistance springs. Unlike mat Pilates, the Reformer provides constant tension throughout every movement, building long, lean muscle while improving flexibility, posture, and core strength.</p>
        <p>At The WRKT, every class is led by certified instructors who guide you through 50 minutes of controlled, precise movement. Whether you are a total beginner or a seasoned athlete, the Reformer adapts to your level.</p>
        <div class="about-stats" data-animate="stagger">
          <div class="stat-card">
            <span class="stat-number counter" data-counter data-target="6" data-suffix="+">0</span>
            <span class="stat-unit">&nbsp;</span>
            <span class="stat-label">Membership Options</span>
          </div>
          <div class="stat-card">
            <span class="stat-number counter" data-counter data-target="35" data-prefix="$">$0</span>
            <span class="stat-unit">&nbsp;</span>
            <span class="stat-label">Drop-In Class</span>
          </div>
          <div class="stat-card">
            <span class="stat-number" style="font-size: var(--text-h3);">All Levels</span>
            <span class="stat-unit">&nbsp;</span>
            <span class="stat-label">Welcome</span>
          </div>
        </div>
      </div>
      <div class="about-visual" data-animate="fade-left">
        <div class="about-image-block">
          <img
            src="https://images.squarespace-cdn.com/content/v1/67ee985553c8e90522ea9bc8/72a2409e-2c38-42ed-ba2c-1c73b747562e/TheWrkt_62.jpg?format=1500w"
            alt="Reformer Pilates class in session at The WRKT Greenville"
            width="400"
            height="500"
            loading="lazy"
            style="width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-lg);"
          />
          <div class="float-dot" style="top: 10%; right: -8px;" aria-hidden="true"></div>
          <div class="float-dot" style="bottom: 20%; left: -12px; animation-delay: 2s;" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== BENEFITS / WHY THE WRKT ===== -->
<section id="benefits" class="section section-dark" data-label="Benefits">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-tag">Why The WRKT</span>
      <h2>More than a workout.<br>A practice.</h2>
    </div>

    <div class="benefits-grid" data-animate="stagger">
      <div class="benefit-card">
        <div class="benefit-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="16" r="8" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 44c0-8.837 7.163-16 16-16s16 7.163 16 16" stroke="currentColor" stroke-width="1.5" fill="none"/>
            <line x1="24" y1="28" x2="24" y2="36" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3>Certified Instructors</h3>
        <p>Every class is led by trained, certified Pilates professionals who know the Reformer inside and out.</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <rect x="8" y="12" width="32" height="4" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="16" cy="24" r="6" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="32" cy="24" r="6" stroke="currentColor" stroke-width="1.5"/>
            <line x1="12" y1="36" x2="36" y2="36" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3>Premium Reformers</h3>
        <p>State-of-the-art equipment maintained to perfection. Feel the difference in every spring and strap.</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <path d="M24 8v32M16 16l8-8 8 8M16 32l8 8 8-8" stroke="currentColor" stroke-width="1.5" fill="none"/>
            <circle cx="24" cy="24" r="4" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3>Flexible Memberships</h3>
        <p>No contracts. Month-to-month commitment. Student, teacher, and professional discounts available.</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <rect x="10" y="8" width="28" height="32" rx="4" stroke="currentColor" stroke-width="1.5" fill="none"/>
            <line x1="16" y1="16" x2="32" y2="16" stroke="currentColor" stroke-width="1.5"/>
            <line x1="16" y1="22" x2="28" y2="22" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
            <line x1="16" y1="28" x2="32" y2="28" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="34" cy="34" r="8" fill="#c4956a" opacity="0.3"/>
            <path d="M30 34l3 3 5-6" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3>Easy Booking</h3>
        <p>Download TheWrktMethod app and book your favorite class times. Classes posted weekly with waitlist support.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== MEMBERSHIPS ===== -->
<section id="memberships" class="section" data-label="Memberships">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-tag">Memberships</span>
      <h2>Find your plan.</h2>
      <p class="section-description">Unlimited Reformer Pilates. No contracts. Cancel anytime with 3 business days notice.</p>
    </div>

    <div class="pricing-grid" data-animate="stagger">
      <!-- Featured: The Membership -->
      <div class="pricing-card featured">
        <div class="pricing-badge">Most Popular</div>
        <h3 class="pricing-name">The Membership</h3>
        <div class="pricing-price">
          <span class="pricing-currency">$</span>
          <span class="pricing-amount">185</span>
          <span class="pricing-period">/mo</span>
        </div>
        <p class="pricing-description">Unlimited Reformer Pilates classes, auto-renewing monthly.</p>
        <ul class="pricing-features">
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l4 4 6-8" stroke="currentColor" stroke-width="1.5"/></svg>
            Unlimited classes
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l4 4 6-8" stroke="currentColor" stroke-width="1.5"/></svg>
            All class times
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l4 4 6-8" stroke="currentColor" stroke-width="1.5"/></svg>
            Month-to-month
          </li>
        </ul>
        <a href="https://www.thewrkt.co/greenville" class="btn btn-primary btn-block" data-magnetic target="_blank" rel="noopener">Get Started</a>
      </div>

      <!-- Student/Teacher/SmallBiz -->
      <div class="pricing-card">
        <h3 class="pricing-name">Special Memberships</h3>
        <div class="pricing-price">
          <span class="pricing-currency">$</span>
          <span class="pricing-amount">150</span>
          <span class="pricing-period">/mo</span>
        </div>
        <p class="pricing-description">Discounted unlimited access for qualifying members.</p>
        <ul class="pricing-features">
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l4 4 6-8" stroke="currentColor" stroke-width="1.5"/></svg>
            Small Business owners
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l4 4 6-8" stroke="currentColor" stroke-width="1.5"/></svg>
            Students
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l4 4 6-8" stroke="currentColor" stroke-width="1.5"/></svg>
            Teachers
          </li>
        </ul>
        <a href="https://www.thewrkt.co/greenville" class="btn btn-outline btn-block" target="_blank" rel="noopener">Learn More</a>
      </div>

      <!-- Health/Young Professional -->
      <div class="pricing-card">
        <h3 class="pricing-name">Professional</h3>
        <div class="pricing-price">
          <span class="pricing-currency">$</span>
          <span class="pricing-amount">170</span>
          <span class="pricing-period">/mo</span>
        </div>
        <p class="pricing-description">For health professionals and young professionals.</p>
        <ul class="pricing-features">
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l4 4 6-8" stroke="currentColor" stroke-width="1.5"/></svg>
            Health Professionals
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l4 4 6-8" stroke="currentColor" stroke-width="1.5"/></svg>
            Young Professionals
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l4 4 6-8" stroke="currentColor" stroke-width="1.5"/></svg>
            Unlimited classes
          </li>
        </ul>
        <a href="https://www.thewrkt.co/greenville" class="btn btn-outline btn-block" target="_blank" rel="noopener">Learn More</a>
      </div>
    </div>

    <!-- Packages -->
    <div class="packages-section" data-animate="fade-up">
      <h3 class="packages-title">Or try a class pack</h3>
      <div class="packages-grid">
        <div class="package-card">
          <span class="package-name">Drop In</span>
          <span class="package-price">$35</span>
          <span class="package-detail">1 class credit</span>
        </div>
        <div class="package-card">
          <span class="package-name">5-Pack</span>
          <span class="package-price">$135</span>
          <span class="package-detail">$27/class &middot; never expires</span>
        </div>
        <div class="package-card">
          <span class="package-name">10-Pack</span>
          <span class="package-price">$275</span>
          <span class="package-detail">$27.50/class &middot; never expires</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== CTA BANNER ===== -->
<section id="cta" class="cta-banner section-dark" data-label="Book">
  <div class="cta-banner-inner" data-animate="fade-up">
    <h2>Your first class is waiting.</h2>
    <p>Download TheWrktMethod app, pick your time, and show up ready to move.</p>
    <a href="https://www.thewrkt.co/greenville" class="btn btn-primary btn-lg" data-magnetic target="_blank" rel="noopener">Book Your First Class</a>
  </div>
</section>

<!-- ===== STUDIO TOUR ===== -->
<section id="studio" class="section section-sand" data-label="Studio">
  <div class="container">
    <div class="studio-grid">
      <div class="studio-info" data-animate="fade-up">
        <span class="section-tag">Our Studio</span>
        <h2>The WRKT Greenville</h2>
        <p class="studio-address">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M10 2C6.686 2 4 4.686 4 8c0 4.5 6 10 6 10s6-5.5 6-10c0-3.314-2.686-6-6-6z" stroke="currentColor" stroke-width="1.5" fill="none"/>
            <circle cx="10" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          1631 E North St, Greenville, SC 29607
        </p>
        <p class="studio-email">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
            <path d="M2 6l8 5 8-5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <a href="mailto:greenville@thewrkt.com">greenville@thewrkt.com</a>
        </p>
        <div class="studio-features">
          <div class="studio-feature">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span>Premium Reformer equipment</span>
          </div>
          <div class="studio-feature">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span>Grippy socks available in studio</span>
          </div>
          <div class="studio-feature">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span>Water for purchase</span>
          </div>
          <div class="studio-feature">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span>Arrive 10-15 min early for first class</span>
          </div>
        </div>
      </div>

      <div class="studio-visual" data-animate="curtain-up">
        <!-- Studio tour gallery -->
        <div class="studio-tour" aria-label="Studio tour gallery">
          <div class="tour-slide is-active" aria-hidden="false">
            <img
              src="https://images.squarespace-cdn.com/content/v1/67ee985553c8e90522ea9bc8/72a2409e-2c38-42ed-ba2c-1c73b747562e/TheWrkt_62.jpg?format=1500w"
              alt="The WRKT Greenville studio interior"
              width="800"
              height="500"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="tour-slide" aria-hidden="true">
            <img
              src="https://images.squarespace-cdn.com/content/v1/67ee985553c8e90522ea9bc8/1bb04f92-910a-478d-8ded-b6fb50c3ecf2/2.png?format=1500w"
              alt="Reformer Pilates equipment at The WRKT"
              width="800"
              height="500"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="tour-slide" aria-hidden="true">
            <img
              src="https://images.unsplash.com/photo-1574680096145-d05b474e2155?w=1200&q=80&auto=format&fit=crop"
              alt="Reformer Pilates class in progress with instructor"
              width="800"
              height="500"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="tour-controls">
            <button class="tour-prev" aria-label="Previous slide">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
            <div class="tour-dots">
              <button class="tour-dot active" aria-label="Slide 1" aria-current="true"></button>
              <button class="tour-dot" aria-label="Slide 2" aria-current="false"></button>
              <button class="tour-dot" aria-label="Slide 3" aria-current="false"></button>
            </div>
            <button class="tour-next" aria-label="Next slide">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M8 4l6 6-6 6" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Google Maps embed -->
    <div class="map-wrap" data-animate="fade-up">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3279.8!2d-82.37!3d34.86!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s1631+E+North+St%2C+Greenville%2C+SC+29607!5e0!3m2!1sen!2sus!4v1"
        width="100%"
        height="300"
        style="border:0; border-radius: var(--radius-lg);"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="The WRKT Greenville location on Google Maps"
      ></iframe>
    </div>
  </div>
</section>

<!-- ===== COMMUNITY ===== -->
<section id="community" class="section section-compact" data-label="Community">
  <div class="container">
    <div class="community-section" data-animate="fade-up">
      <span class="section-tag">Our Community</span>
      <h2>Join a growing community of movers.</h2>
      <p class="community-description">From first-timers to seasoned athletes, our members come for the workout and stay for the community. Flexible memberships starting at $150/mo with student, teacher, and professional discounts.</p>
      <div class="community-highlights" data-animate="stagger">
        <div class="community-card">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="6" stroke="var(--color-accent)" stroke-width="1.5"/>
            <circle cx="26" cy="14" r="6" stroke="var(--color-accent)" stroke-width="1.5"/>
            <path d="M4 34c0-6 5-10 10-10h12c5 0 10 4 10 10" stroke="var(--color-accent)" stroke-width="1.5" fill="none"/>
          </svg>
          <h3>All Levels Welcome</h3>
          <p>Whether it is your very first class or your hundredth, our instructors meet you where you are.</p>
        </div>
        <div class="community-card">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <rect x="6" y="6" width="28" height="28" rx="6" stroke="var(--color-accent)" stroke-width="1.5" fill="none"/>
            <path d="M14 20l4 4 8-10" stroke="var(--color-accent)" stroke-width="2"/>
          </svg>
          <h3>No Contracts</h3>
          <p>Month-to-month memberships. Cancel anytime with 3 business days notice by email.</p>
        </div>
        <div class="community-card">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <path d="M20 6l4 8h8l-6 5 2 8-8-5-8 5 2-8-6-5h8z" stroke="var(--color-accent)" stroke-width="1.5" fill="none"/>
          </svg>
          <h3>Multiple Locations</h3>
          <p>The WRKT is growing. Join our Greenville studio and be part of something bigger.</p>
        </div>
      </div>
      <div class="community-image" data-animate="curtain-up">
        <img
          src="https://images.unsplash.com/photo-1599058917765-a780eda07a3e?w=1200&q=80&auto=format&fit=crop"
          alt="Group of people enjoying a Reformer Pilates session together"
          width="1200"
          height="500"
          loading="lazy"
          decoding="async"
          class="community-img"
        />
      </div>
      <div class="community-cta">
        <a href="#memberships" class="btn btn-primary btn-lg" data-magnetic>Become a Member</a>
      </div>
    </div>
  </div>
</section>

<!-- ===== FAQ ===== -->
<section id="faq" class="section section-dark" data-label="FAQ">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-tag">Frequently Asked</span>
