---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---
<div class="faq-item">
  <button class="faq-trigger" aria-expanded="false">
    <span>{question}</span>
    <span class="faq-icon" aria-hidden="true">+</span>
  </button>
  <div class="faq-content" role="region">
    <div class="faq-content-inner" set:html={answer} />
  </div>
</div>
