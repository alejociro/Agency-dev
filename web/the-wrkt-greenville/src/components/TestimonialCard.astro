---
interface Props {
  text: string;
  name: string;
  role: string;
  initials: string;
  rating?: number;
}

const { text, name, role, initials, rating = 5 } = Astro.props;
---
<div class="testimonial-card">
  <div class="testimonial-stars" aria-label={`${rating} out of 5 stars`}>
    {Array.from({ length: rating }).map(() => (
      <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--color-accent)" aria-hidden="true">
        <path d="M8 1l2.2 4.6 5 .7-3.6 3.5.9 5L8 12.4 3.5 15l.9-5L.8 6.3l5-.7z"/>
      </svg>
    ))}
  </div>
  <blockquote class="testimonial-text">{text}</blockquote>
  <div class="testimonial-author">
    <div class="author-avatar" aria-hidden="true">{initials}</div>
    <div class="author-info">
      <span class="author-name">{name}</span>
      <span class="author-role">{role}</span>
    </div>
  </div>
</div>
