---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Classes & Pricing | Studio 17 - Classical Pilates Greenville, SC"
  description="Group reformer, mat, and private Pilates classes in Greenville, SC. View our class schedule, pricing, and new client packages at Studio 17."
  activePage="classes"
>
  <main>
    <!-- ======== PAGE HERO ======== -->
    <section class="page-hero">
      <div class="container">
        <span class="hero-tag section-tag">Studio 17</span>
        <h1 class="hero-title" style="font-size: var(--text-h1);">Classes &amp; Pricing</h1>
        <p class="hero-sub" style="font-size: var(--text-body); max-width: 55ch; color: var(--color-text-muted); margin-top: var(--space-3);">
          All sessions are 50 minutes unless otherwise noted. Find the class that matches your experience level and goals.
        </p>
      </div>
    </section>

    <!-- ======== CLASS FINDER QUIZ ======== -->
    <section class="section" id="quiz" style="background-color: var(--color-surface);">
      <div class="container" style="max-width: 700px;">
        <div style="text-align: center; margin-bottom: var(--space-6);" data-animate="fade-up">
          <span class="section-tag" style="justify-content: center;">Not Sure Where to Start?</span>
          <h2 style="margin-top: var(--space-2);">Find Your Ideal Class</h2>
        </div>

        <div class="class-quiz" data-animate="fade-up">
          <div class="quiz-progress">
            <div class="quiz-progress-bar"></div>
          </div>

          <!-- Step 1: Experience -->
          <div class="quiz-step active" data-question="experience">
            <h3>What is your Pilates experience?</h3>
            <p>Select the option that best describes you.</p>
            <div class="quiz-options">
              <div class="quiz-option" data-value="none">
                <div class="quiz-option-title">Brand New</div>
                <div class="quiz-option-desc">Never done Pilates before</div>
              </div>
              <div class="quiz-option" data-value="beginner">
                <div class="quiz-option-title">Beginner</div>
                <div class="quiz-option-desc">Some experience, learning the basics</div>
              </div>
              <div class="quiz-option" data-value="intermediate">
                <div class="quiz-option-title">Intermediate</div>
                <div class="quiz-option-desc">Regular practice, comfortable with exercises</div>
              </div>
              <div class="quiz-option" data-value="advanced">
                <div class="quiz-option-title">Advanced</div>
                <div class="quiz-option-desc">Committed practitioner, ready for challenge</div>
              </div>
            </div>
          </div>

          <!-- Step 2: Goal -->
          <div class="quiz-step" data-question="goal">
            <h3>What is your primary goal?</h3>
            <p>Choose what matters most to you right now.</p>
            <div class="quiz-options">
              <div class="quiz-option" data-value="general">
                <div class="quiz-option-title">Overall Wellness</div>
                <div class="quiz-option-desc">Improve posture, flexibility, and balance</div>
              </div>
              <div class="quiz-option" data-value="strength">
                <div class="quiz-option-title">Build Strength</div>
                <div class="quiz-option-desc">Focus on controlled power and core stability</div>
              </div>
              <div class="quiz-option" data-value="recovery">
                <div class="quiz-option-title">Recovery</div>
                <div class="quiz-option-desc">Returning from injury or extended break</div>
              </div>
              <div class="quiz-option" data-value="equipment">
                <div class="quiz-option-title">Equipment Work</div>
                <div class="quiz-option-desc">Train on Reformer, Cadillac, and apparatus</div>
              </div>
            </div>
          </div>

          <!-- Step 3: Pace -->
          <div class="quiz-step" data-question="pace">
            <h3>What pace do you prefer?</h3>
            <p>How would you like your sessions to feel?</p>
            <div class="quiz-options">
              <div class="quiz-option" data-value="steady">
                <div class="quiz-option-title">Steady &amp; Mindful</div>
                <div class="quiz-option-desc">Focused on precision and breath</div>
              </div>
              <div class="quiz-option" data-value="lively">
                <div class="quiz-option-title">Lively &amp; Flowing</div>
                <div class="quiz-option-desc">Moving with energy and rhythm</div>
              </div>
            </div>
          </div>

          <!-- Quiz Result -->
          <div class="quiz-result">
            <div class="quiz-recommendation" data-class="getting-started">
              <span class="section-tag" style="justify-content: center; margin-bottom: var(--space-3); display: inline-flex;">Your Recommendation</span>
              <h3>Getting Started Package</h3>
              <p style="margin: var(--space-3) auto; max-width: 45ch;">Perfect for you. Three private sessions to build your foundation with personalized one-on-one instruction. $200 for new students.</p>
              <a href="/contact" class="btn btn-primary" data-magnetic>Book Getting Started</a>
            </div>
            <div class="quiz-recommendation" data-class="mat-beginner">
              <span class="section-tag" style="justify-content: center; margin-bottom: var(--space-3); display: inline-flex;">Your Recommendation</span>
              <h3>Mat Class &mdash; Beginner</h3>
              <p style="margin: var(--space-3) auto; max-width: 45ch;">Great match for your level. Build strength and confidence with the traditional mat order in a supportive setting.</p>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874853" target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-magnetic>Sign Up for Mat Beginner</a>
            </div>
            <div class="quiz-recommendation" data-class="mat-advanced">
              <span class="section-tag" style="justify-content: center; margin-bottom: var(--space-3); display: inline-flex;">Your Recommendation</span>
              <h3>Mat Class &mdash; Advanced</h3>
              <p style="margin: var(--space-3) auto; max-width: 45ch;">You are ready for the challenge. Follow the Advanced Mat order at a lively, steady pace with experienced practitioners.</p>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874889" target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-magnetic>Sign Up for Mat Advanced</a>
            </div>
            <div class="quiz-recommendation" data-class="group-reformer">
              <span class="section-tag" style="justify-content: center; margin-bottom: var(--space-3); display: inline-flex;">Your Recommendation</span>
              <h3>Group Reformer</h3>
              <p style="margin: var(--space-3) auto; max-width: 45ch;">Perfect for your goals. Precision, control, and flow on the Reformer in a group setting with the Classical system.</p>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874319" target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-magnetic>Sign Up for Reformer</a>
            </div>
            <div class="quiz-recommendation" data-class="old-school">
              <span class="section-tag" style="justify-content: center; margin-bottom: var(--space-3); display: inline-flex;">Your Recommendation</span>
              <h3>Old School Workout</h3>
              <p style="margin: var(--space-3) auto; max-width: 45ch;">Independent practice on equipment you have been trained on, with observation and personalized cues from BeLinda.</p>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874945" target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-magnetic>Sign Up for Old School</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== ALL CLASSES ======== -->
    <section class="section" id="all-classes">
      <div class="container">
        <div style="text-align: center; margin-bottom: var(--space-8);" data-animate="fade-up">
          <span class="section-tag" style="justify-content: center;">Group Classes</span>
          <h2 style="margin-top: var(--space-2);">All Class Options</h2>
        </div>

        <div class="all-classes-grid" data-animate="stagger">
          <!-- Group Reformer -->
          <div class="class-card">
            <div class="class-card-header">
              <span class="class-card-badge">Group</span>
              <h3>Group Reformer Class</h3>
            </div>
            <p>This class is designed for students familiar with the Classical Pilates Reformer order. The class moves at a steady pace, emphasizing precision, control, and flow within the traditional Classical system.</p>
            <div class="class-card-footer">
              <span class="class-card-duration">50 min</span>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874319" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="padding: 0.6rem 1.2rem; font-size: var(--text-xs);">Sign Up</a>
            </div>
          </div>

          <!-- Mat Beginner -->
          <div class="class-card">
            <div class="class-card-header">
              <span class="class-card-badge" style="background-color: var(--color-accent-glow); color: var(--color-accent-dark);">Beginner</span>
              <h3>Mat Class Beginner</h3>
            </div>
            <p>This class follows the traditional mat order, focusing on precision, flow, and full-body engagement. Students build strength and confidence in a supportive setting. Ideal for beginners, those returning after injury, or anyone resuming their practice after an extended break.</p>
            <div class="class-card-footer">
              <span class="class-card-duration">50 min</span>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874853" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="padding: 0.6rem 1.2rem; font-size: var(--text-xs);">Sign Up</a>
            </div>
          </div>

          <!-- Mat Advanced -->
          <div class="class-card">
            <div class="class-card-header">
              <span class="class-card-badge" style="background-color: rgba(212,184,150,0.25); color: var(--color-secondary-dark);">Advanced</span>
              <h3>Mat Class Advanced</h3>
            </div>
            <p>Similar to the Beginner Mat class, this class is intended for students with prior experience who are committed to their practice. This class follows the Advanced Mat order and moves at a lively, steady pace.</p>
            <div class="class-card-footer">
              <span class="class-card-duration">50 min</span>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874889" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="padding: 0.6rem 1.2rem; font-size: var(--text-xs);">Sign Up</a>
            </div>
          </div>

          <!-- Old School -->
          <div class="class-card">
            <div class="class-card-header">
              <span class="class-card-badge" style="background-color: var(--color-primary-glow); color: var(--color-primary-dark);">All Levels</span>
              <h3>Old School Workout</h3>
            </div>
            <p>Old School Workout is a group class taught in the Classical Pilates tradition. Students of all levels practice independently on the equipment they have been trained on, while the instructor provides observation, personalized cues, corrections, and alignment assistance as needed.</p>
            <div class="class-card-footer">
              <span class="class-card-duration">50 min</span>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874945" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="padding: 0.6rem 1.2rem; font-size: var(--text-xs);">Sign Up</a>
            </div>
          </div>

          <!-- Personal Practice -->
          <div class="class-card">
            <div class="class-card-header">
              <span class="class-card-badge" style="background-color: var(--color-surface-alt); color: var(--color-text-muted);">Independent</span>
              <h3>Personal Practice</h3>
            </div>
            <p>Offered while BeLinda is teaching a Private Session. This is an independent, unassisted practice where students have full access to all equipment they have been trained on. Teaching aids are provided to support safe and effective practice.</p>
            <div class="class-card-footer">
              <span class="class-card-duration">50 min</span>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88875012" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="padding: 0.6rem 1.2rem; font-size: var(--text-xs);">Sign Up</a>
            </div>
          </div>
        </div>

        <div style="text-align: center; margin-top: var(--space-6);" data-animate="fade-up">
          <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952" target="_blank" rel="noopener noreferrer" class="btn btn-secondary" data-magnetic>Full Class Schedule</a>
        </div>
      </div>
    </section>

    <!-- ======== PRIVATE LESSONS ======== -->
    <section class="section" id="private" style="background-color: var(--color-bg-warm);">
      <div class="container">
        <div class="grid-asymmetric" style="align-items: center;">
          <div data-animate="fade-right">
            <span class="section-tag" style="margin-bottom: var(--space-3); display: inline-flex;">One-on-One</span>
            <h2>Private Lessons</h2>
            <p style="margin-top: var(--space-3); margin-bottom: var(--space-6);">
              Get personalized instruction tailored to your specific goals and needs. Contact us to schedule. Packages also available.
            </p>
            <div class="pricing-grid">
              <div class="pricing-item">
                <span class="pricing-label">Single Session</span>
                <span class="pricing-price">$85</span>
              </div>
              <div class="pricing-item">
                <span class="pricing-label">30 Minute Session</span>
                <span class="pricing-price">$45</span>
              </div>
              <div class="pricing-item">
                <span class="pricing-label">Duo (2 people)</span>
                <span class="pricing-price">$100</span>
              </div>
              <div class="pricing-item">
                <span class="pricing-label">Trio (3 people)</span>
                <span class="pricing-price">$135</span>
              </div>
            </div>
            <a href="/contact" class="btn btn-primary" data-magnetic style="margin-top: var(--space-4);">Schedule a Private</a>
          </div>
          <div data-animate="fade-left" data-delay="200">
            <div class="card-accent" style="padding: var(--space-6); border-radius: var(--radius-xl); text-align: center;">
              <span style="font-size: var(--text-xs); letter-spacing: var(--tracking-widest); text-transform: uppercase; color: rgba(255,255,255,0.7);">New Students</span>
              <h3 style="color: var(--color-surface); margin-top: var(--space-2); margin-bottom: var(--space-3);">Getting Started Package</h3>
              <p style="font-family: var(--font-display); font-size: var(--text-h1); color: var(--color-surface); margin-bottom: var(--space-2);">$200</p>
              <p style="color: rgba(255,255,255,0.85); font-size: var(--text-small); margin-bottom: var(--space-4); max-width: 30ch; margin-inline: auto;">
                Three private sessions designed to establish proper form and technique.
              </p>
              <a href="/contact" class="btn" style="background: var(--color-surface); color: var(--color-primary-dark);">Get Started</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== WHAT TO BRING ======== -->
    <section class="section" id="prepare">
      <div class="container" style="max-width: 800px;">
        <div style="text-align: center; margin-bottom: var(--space-6);" data-animate="fade-up">
          <span class="section-tag" style="justify-content: center;">Prepare</span>
          <h2 style="margin-top: var(--space-2);">What to Bring to Class</h2>
        </div>
        <div class="prepare-grid" data-animate="stagger">
          <div class="prepare-item">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <p>No street shoes in the studio &mdash; practice barefoot or in grip socks</p>
          </div>
          <div class="prepare-item">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
            <p>Avoid clothing with zippers &mdash; they can damage equipment</p>
          </div>
          <div class="prepare-item">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <p>Grip socks or toe socks recommended for traction</p>
          </div>
          <div class="prepare-item">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 6v6l4 2"/></svg>
            <p>Long hair must be tied up and secured</p>
          </div>
        </div>
        <p style="text-align: center; margin-top: var(--space-4); color: var(--color-text-muted); font-size: var(--text-small);" data-animate="fade-up">
          We provide all equipment. Just bring yourself and wear comfortable, fitted clothing.
        </p>
      </div>
    </section>

    <!-- ======== FAQ ======== -->
    <section class="section" id="faq" style="background-color: var(--color-surface);">
      <div class="container" style="max-width: 800px;">
        <div style="text-align: center; margin-bottom: var(--space-6);" data-animate="fade-up">
          <span class="section-tag" style="justify-content: center;">FAQ</span>
          <h2 style="margin-top: var(--space-2);">Frequently Asked Questions</h2>
        </div>

        <div class="faq-list" data-animate="stagger">
          <details class="faq-item">
            <summary>
              <span>Is Pilates right for me?</span>
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="faq-content">
              <p>Absolutely. Classical Pilates is for every body, regardless of age, fitness level, or physical condition. BeLinda adapts exercises to meet your individual needs, and the Getting Started package ensures you build a safe foundation before joining group classes.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>
              <span>What if I have injuries or limitations?</span>
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="faq-content">
              <p>Your safety is the top priority at Studio 17. During your initial consultation, share any injuries, conditions, or concerns. BeLinda will modify exercises and choose appropriate apparatus to support your recovery and practice safely.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>
              <span>How often should I practice?</span>
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="faq-content">
              <p>Joseph Pilates recommended practicing 3 times per week for best results. However, even once a week can bring noticeable improvements in posture, flexibility, and strength. Consistency is key &mdash; find a rhythm that works for your lifestyle.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>
              <span>What is the difference between Classical and contemporary Pilates?</span>
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="faq-content">
              <p>Classical Pilates follows the original order and exercises as designed by Joseph Pilates. It uses specific Contrology apparatus and emphasizes a systematic progression. Contemporary Pilates often modifies or adds exercises outside the original system. At Studio 17, we honor the Classical method while meeting your individual needs.</p>
            </div>
          </details>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Page hero */
  .page-hero {
    padding-block-start: calc(var(--space-16) + var(--space-8));
    padding-block-end: var(--space-8);
  }

  /* Class cards */
  .all-classes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);

    @media (min-width: 640px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media (min-width: 1024px) {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .class-card {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    transition: all var(--duration-normal) var(--ease-out);

    &:hover {
      box-shadow: var(--shadow-hover);
      transform: translateY(-4px);
    }

    & p {
      font-size: var(--text-small);
      color: var(--color-text-muted);
      margin-top: var(--space-2);
      flex-grow: 1;
    }
  }

  .class-card-header {
    & h3 {
      margin-top: var(--space-2);
      font-size: var(--text-h3);
    }
  }

  .class-card-badge {
    display: inline-block;
    padding: 0.2rem 0.8rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
    background-color: var(--color-primary-glow);
    color: var(--color-primary-dark);
  }

  .class-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .class-card-duration {
    font-size: var(--text-xs);
    color: var(--color-text-light);
  }

  /* Pricing */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  .pricing-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3);
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .pricing-label {
    font-size: var(--text-small);
    color: var(--color-text-muted);
  }

  .pricing-price {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--color-text);
  }

  /* Prepare grid */
  .prepare-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);

    @media (min-width: 640px) {
      grid-template-columns: 1fr 1fr;
    }
  }

  .prepare-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-3);

    & svg {
      flex-shrink: 0;
      margin-top: 2px;
    }

    & p {
      font-size: var(--text-small);
      color: var(--color-text-muted);
    }
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--duration-fast) var(--ease-out);

    &[open] {
      border-color: var(--color-primary);
    }

    & summary {
      cursor: pointer;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: var(--space-3) var(--space-4);
      font-family: var(--font-body);
      font-weight: 500;
      font-size: var(--text-body);
      min-height: 44px;

      &::marker { display: none; }
      &::-webkit-details-marker { display: none; }
    }

    & .faq-icon {
      transition: transform var(--duration-fast) var(--ease-out);
      flex-shrink: 0;
    }

    &[open] .faq-icon {
      transform: rotate(180deg);
    }
  }

  .faq-content {
    padding: 0 var(--space-4) var(--space-4);
