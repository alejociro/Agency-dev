---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About BeLinda Bellows | Studio 17 - Classical Pilates Greenville"
  description="Meet BeLinda Bellows, certified Classical Pilates instructor with 17+ years of experience. Discover her training philosophy and certifications at Studio 17 Greenville."
  activePage="about"
>
  <main>
    <!-- ======== PAGE HERO ======== -->
    <section class="page-hero">
      <div class="container">
        <span class="hero-tag section-tag">Our Story</span>
        <h1 class="hero-title" style="font-size: var(--text-h1);">About Studio 17</h1>
      </div>
    </section>

    <!-- ======== MEET BELINDA ======== -->
    <section class="section" id="belinda">
      <div class="container">
        <div class="grid-asymmetric-reverse" style="align-items: start; gap: var(--space-8);">
          <div data-animate="fade-right">
            <div class="img-hover-zoom" style="position: relative;">
              <img
                src="https://images.squarespace-cdn.com/content/v1/68e1557acc9b4e509628a381/a3ba8022-0d23-4214-ae20-fa350c5ee1e4/DSC04106-A.jpg"
                alt="BeLinda Bellows - Owner and certified Classical Pilates instructor at Studio 17 Greenville, SC"
                width="600"
                height="750"
                loading="eager"
                decoding="async"
                style="border-radius: var(--radius-lg); aspect-ratio: 4/5; object-fit: cover;"
              />
              <div class="breathing-circle" style="bottom: -30px; left: -30px; width: 100px; height: 100px;"></div>
            </div>
          </div>
          <div data-animate="fade-left" data-delay="200">
            <span class="section-tag" style="margin-bottom: var(--space-3); display: inline-flex;">Your Instructor</span>
            <h2>BeLinda Bellows</h2>
            <p style="font-family: var(--font-display); font-style: italic; font-size: var(--text-h3); color: var(--color-primary-dark); margin: var(--space-4) 0; line-height: var(--leading-snug);">
              &ldquo;At Studio 17, my goal is to create a space where Classical Pilates is designed around you.&rdquo;
            </p>
            <p style="margin-bottom: var(--space-3);">
              BeLinda began her Pilates practice in 2007 with a mat class and developed a sustained commitment to Classical Pilates methodology. Her teaching approach honors Joseph Pilates' original work while meeting individual client needs.
            </p>
            <p style="margin-bottom: var(--space-3);">
              BeLinda describes herself as a &ldquo;forever Pilates student,&rdquo; emphasizing that continuous education preserves Classical method integrity and supports comprehensive teaching of strength, mobility, balance, and confidence development.
            </p>
            <p style="color: var(--color-text-muted); font-size: var(--text-small);">
              Bachelor of Science in Interior Design &bull; University of Utah &bull; Raised in Wyoming &bull; Married with two adult daughters, two sons-in-law, and two grandsons
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== CERTIFICATIONS TIMELINE ======== -->
    <section class="section" id="certifications" style="background-color: var(--color-surface);">
      <div class="container" style="max-width: 800px;">
        <div style="text-align: center; margin-bottom: var(--space-8);" data-animate="fade-up">
          <span class="section-tag" style="justify-content: center;">Credentials</span>
          <h2 style="margin-top: var(--space-2);">Certifications &amp; Training</h2>
          <p style="margin-top: var(--space-3); color: var(--color-text-muted); margin-inline: auto;">
            A commitment to continuous education ensures the highest quality of Classical instruction.
          </p>
        </div>

        <div class="timeline" data-animate="stagger">
          <div class="timeline-item">
            <div class="timeline-year">2022 &ndash; Present</div>
            <div class="timeline-content">
              <h3>Karen Frischmann Classical Pilates</h3>
              <p>Mastery Series &mdash; ongoing advanced study in the authentic Classical method</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2022</div>
            <div class="timeline-content">
              <h3>Classical Pilates Progression</h3>
              <p>Karen Frischmann &mdash; deepening understanding of the Classical order and its systematic approach</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2017</div>
            <div class="timeline-content">
              <h3>Peak Pilates Comprehensive Certification</h3>
              <p>Full comprehensive certification covering all apparatus and methods</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2017</div>
            <div class="timeline-content">
              <h3>NETA Certification</h3>
              <p>National Exercise Trainers Association professional certification</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2015</div>
            <div class="timeline-content">
              <h3>Balanced Body Reformer Level 1</h3>
              <p>Specialized training in Reformer instruction and technique</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2014</div>
            <div class="timeline-content">
              <h3>Balanced Body Mat Pilates Certification</h3>
              <p>Foundation certification in mat-based Pilates instruction</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2013</div>
            <div class="timeline-content">
              <h3>Balanced Body Intro to Anatomy</h3>
              <p>Foundational anatomy studies for movement professionals</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2007</div>
            <div class="timeline-content">
              <h3>Pilates Journey Begins</h3>
              <p>First mat class sparks a lifelong dedication to the Classical method</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== STUDIO VALUES ======== -->
    <section class="section" id="values">
      <div class="container">
        <div style="text-align: center; margin-bottom: var(--space-8);" data-animate="fade-up">
          <span class="section-tag" style="justify-content: center;">Philosophy</span>
          <h2 style="margin-top: var(--space-2);">What We Believe</h2>
        </div>

        <div class="values-grid" data-animate="stagger">
          <div class="value-card">
            <div class="value-number">01</div>
            <h3>Classical Integrity</h3>
            <p>We honor Joseph Pilates' original work. The Classical system is a complete, proven method &mdash; not a collection of random exercises.</p>
          </div>
          <div class="value-card">
            <div class="value-number">02</div>
            <h3>Personal Approach</h3>
            <p>Every body is different. We design your practice around your unique needs, goals, and physical considerations.</p>
          </div>
          <div class="value-card">
            <div class="value-number">03</div>
            <h3>Safe Foundation</h3>
            <p>Proper form and technique come first. Our Getting Started package ensures every student builds a solid, safe foundation before advancing.</p>
          </div>
          <div class="value-card">
            <div class="value-number">04</div>
            <h3>Lifelong Practice</h3>
            <p>Pilates is not a trend &mdash; it is a practice for life. We aim to make Studio 17 a place where your practice can grow for years to come.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== STUDIO NUMBERS ======== -->
    <section class="full-bleed" style="background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%); padding-block: var(--space-8);">
      <div class="container">
        <div class="stats-grid" data-animate="fade-up">
          <div class="stat-item">
            <span class="counter" data-counter data-target="17" data-suffix="+">0</span>
            <span class="stat-label">Years of Practice</span>
          </div>
          <div class="stat-item">
            <span class="counter" data-counter data-target="7">0</span>
            <span class="stat-label">Certifications</span>
          </div>
          <div class="stat-item">
            <span class="counter" data-counter data-target="5">0</span>
            <span class="stat-label">Class Types</span>
          </div>
          <div class="stat-item">
            <span class="counter" data-counter data-target="6">0</span>
            <span class="stat-label">Days Per Week</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== CTA ======== -->
    <section class="section" style="text-align: center;">
      <div class="container" data-animate="fade-up">
        <h2 style="margin-bottom: var(--space-3);">Ready to Begin?</h2>
        <p style="margin-inline: auto; color: var(--color-text-muted); margin-bottom: var(--space-6);">
          Schedule a consultation and let us create the perfect Pilates practice for you.
        </p>
        <a href="/contact" class="btn btn-primary" data-magnetic>Schedule Your Consultation</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .page-hero {
    padding-block-start: calc(var(--space-16) + var(--space-8));
    padding-block-end: var(--space-8);
  }

  /* Timeline */
  .timeline {
    position: relative;
    padding-inline-start: var(--space-6);

    &::before {
      content: '';
      position: absolute;
      inset-inline-start: 0;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(180deg, var(--color-primary), var(--color-secondary), var(--color-border));
    }
  }

  .timeline-item {
    position: relative;
    padding-block-end: var(--space-6);

    &::before {
      content: '';
      position: absolute;
      inset-inline-start: calc(-1 * var(--space-6) - 1px);
      top: 6px;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--color-primary);
      border: 2px solid var(--color-surface);
    }

    &:last-child {
      padding-block-end: 0;
    }
  }

  .timeline-year {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-block-end: var(--space-1);
  }

  .timeline-content {
    & h3 {
      font-size: var(--text-h3);
      margin-block-end: var(--space-1);
    }

    & p {
      font-size: var(--text-small);
      color: var(--color-text-muted);
    }
  }

  /* Values */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);

    @media (min-width: 640px) {
      grid-template-columns: 1fr 1fr;
    }
  }

  .value-card {
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--duration-normal) var(--ease-out);

    &:hover {
      border-color: var(--color-primary);
      box-shadow: var(--shadow-card);
    }
  }

  .value-number {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--color-primary-light);
    opacity: 0.4;
    line-height: 1;
    margin-block-end: var(--space-2);
  }

  .value-card h3 {
    margin-block-end: var(--space-2);
  }

  .value-card p {
    font-size: var(--text-small);
    color: var(--color-text-muted);
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    text-align: center;

    @media (min-width: 640px) {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat-item .counter {
    font-size: var(--text-h1);
    color: var(--color-surface);
    font-weight: 400;
  }

  .stat-label {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.7);
  }
</style>
