---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Studio 17 | Classical Pilates in Greenville, SC" activePage="home">
  <main>
    <!-- ======== HERO ======== -->
    <section class="hero" id="hero">
      <div class="hero-bg hero-bg-parallax">
        <img
          src="https://images.squarespace-cdn.com/content/v1/68e1557acc9b4e509628a381/d5a0260a-7c5a-476e-86e3-bc431d761b3b/BLB-1002495.jpeg"
          alt="Classical Pilates session at Studio 17 in Greenville, SC - Reformer equipment and focused practice"
          width="1920"
          height="1080"
          loading="eager"
          decoding="async"
          class="hero-image"
        />
        <div class="hero-overlay"></div>
      </div>
      <div class="container hero-content">
        <span class="hero-tag section-tag">Classical Pilates in Greenville, SC</span>
        <h1 class="hero-title text-display" data-split>A System That Lengthens, Strengthens, and Balances</h1>
        <p class="hero-sub">Discover how Classical Pilates can transform your posture, relieve pain, and build strength you can feel &mdash; in a studio designed around you.</p>
        <div class="hero-cta" style="display: flex; gap: var(--space-3); flex-wrap: wrap; align-items: center;">
          <a href="/contact" class="btn btn-primary" data-magnetic>Start Your Journey</a>
          <a href="/classes" class="btn btn-ghost link-arrow">Explore Classes <span class="arrow">&rarr;</span></a>
        </div>
        <div class="hero-scroll-hint" aria-hidden="true">
          <svg width="24" height="36" viewBox="0 0 24 36" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="1" y="1" width="22" height="34" rx="11" />
            <circle cx="12" cy="10" r="2" fill="currentColor" class="scroll-dot" />
          </svg>
        </div>
      </div>
    </section>

    <!-- Wave divider -->
    <svg class="section-divider" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
      <path class="divider-path wave-path" d="M0,60 C360,120 1080,0 1440,60 L1440,120 L0,120 Z" fill="var(--color-bg)"/>
    </svg>

    <!-- ======== WHAT IS CLASSICAL PILATES ======== -->
    <section class="section" id="about-pilates" style="background-color: var(--color-surface);">
      <div class="container">
        <div class="grid-asymmetric" style="align-items: center;">
          <div data-animate="fade-right">
            <span class="section-tag" style="margin-bottom: var(--space-3); display: inline-flex;">The Method</span>
            <h2>What is Classical Pilates</h2>
            <p style="margin-top: var(--space-3); margin-bottom: var(--space-4);">
              Classical Pilates is a system developed by Joseph Pilates. It focuses on precise, controlled movements, breath, and a strong mind-body connection. It can improve posture, balance and flexibility.
            </p>
            <p style="margin-bottom: var(--space-4);">
              Studio 17 is a fully equipped Classical Studio &mdash; all of the equipment used at Studio 17 is Contrology, by Balanced Body including the Cadillac, Reformer, Barrels, Chairs, and supporting small apparatus, designed to help the body become stronger on the Mat.
            </p>
            <a href="/classes" class="btn btn-secondary link-arrow">Explore Classes <span class="arrow">&rarr;</span></a>
          </div>
          <div data-animate="fade-left" data-delay="200">
            <div class="img-hover-zoom" style="position: relative;">
              <img
                src="https://images.squarespace-cdn.com/content/v1/68e1557acc9b4e509628a381/19ed5838-cadd-4b3c-803c-ef6e2f5acb77/Image+2-7-26+at+12.52%E2%80%AFPM.png"
                alt="Classical Pilates equipment at Studio 17 - Reformer, Cadillac, and Barrels by Balanced Body"
                width="600"
                height="500"
                loading="lazy"
                decoding="async"
                style="border-radius: var(--radius-lg); aspect-ratio: 6/5; object-fit: cover;"
              />
              <!-- Decorative breathing circle -->
              <div class="breathing-circle" style="top: -40px; right: -40px; width: 120px; height: 120px;"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== MEET BELINDA ======== -->
    <section class="section section-tilted" id="instructor">
      <div class="container">
        <div class="grid-asymmetric-reverse" style="align-items: center;">
          <div data-animate="fade-right">
            <div class="img-hover-zoom">
              <img
                src="https://images.squarespace-cdn.com/content/v1/68e1557acc9b4e509628a381/a3ba8022-0d23-4214-ae20-fa350c5ee1e4/DSC04106-A.jpg"
                alt="BeLinda Bellows - Owner and certified Classical Pilates instructor at Studio 17 Greenville"
                width="500"
                height="600"
                loading="lazy"
                decoding="async"
                style="border-radius: var(--radius-lg); aspect-ratio: 5/6; object-fit: cover;"
              />
            </div>
          </div>
          <div data-animate="fade-left" data-delay="200">
            <span class="section-tag" style="margin-bottom: var(--space-3); display: inline-flex;">Your Instructor</span>
            <h2>Welcome to Studio 17</h2>
            <blockquote style="font-family: var(--font-display); font-style: italic; font-size: var(--text-h3); color: var(--color-primary-dark); margin: var(--space-4) 0; padding-left: var(--space-3); border-left: 2px solid var(--color-secondary);">
              &ldquo;I love Pilates, it has truly changed my body. My hope is that it becomes your lifelong practice.&rdquo;
            </blockquote>
            <p style="margin-bottom: var(--space-3);">
              I want everyone who walks through the doors of Studio 17 to feel welcome, supported, and at home in their bodies.
            </p>
            <p style="margin-bottom: var(--space-4); color: var(--color-text-muted); font-size: var(--text-small);">
              BeLinda Bellows &mdash; Practicing since 2007 &bull; Karen Frischmann Classical Pilates Mastery Series &bull; Peak Pilates Comprehensive Certification
            </p>
            <a href="/about" class="btn btn-ghost link-arrow">About BeLinda <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== FEATURED CLASSES ======== -->
    <section class="section" id="classes-preview" style="background-color: var(--color-bg-warm);">
      <div class="container">
        <div style="text-align: center; margin-bottom: var(--space-8);" data-animate="fade-up">
          <span class="section-tag" style="justify-content: center;">Our Classes</span>
          <h2 style="margin-top: var(--space-2);">Find Your Practice</h2>
          <p style="margin-top: var(--space-3); margin-inline: auto; color: var(--color-text-muted);">
            All sessions are 50 minutes. From beginner mat work to advanced reformer, there is a class for every body.
          </p>
        </div>

        <div class="classes-grid" data-animate="stagger">
          <!-- Group Reformer -->
          <div class="card">
            <div class="card-content" style="padding: var(--space-4);">
              <div style="display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-3);">
                <div style="width: 48px; height: 48px; border-radius: var(--radius-md); background: var(--color-primary-glow); display: grid; place-items: center;">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-dark)" stroke-width="1.5"><rect x="2" y="8" width="20" height="4" rx="1"/><line x1="6" y1="12" x2="6" y2="20"/><line x1="18" y1="12" x2="18" y2="20"/><circle cx="12" cy="6" r="2"/></svg>
                </div>
                <span class="text-label">Group</span>
              </div>
              <h3>Group Reformer</h3>
              <p style="margin-top: var(--space-2); font-size: var(--text-small); color: var(--color-text-muted);">
                Designed for students familiar with the Classical Pilates Reformer order. Emphasizing precision, control, and flow.
              </p>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874319" target="_blank" rel="noopener noreferrer" class="btn btn-ghost link-arrow" style="margin-top: var(--space-3);">Sign Up <span class="arrow">&rarr;</span></a>
            </div>
          </div>

          <!-- Mat Beginner -->
          <div class="card">
            <div class="card-content" style="padding: var(--space-4);">
              <div style="display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-3);">
                <div style="width: 48px; height: 48px; border-radius: var(--radius-md); background: var(--color-accent-glow); display: grid; place-items: center;">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-dark)" stroke-width="1.5"><rect x="2" y="14" width="20" height="3" rx="1.5"/><path d="M7 14c0-3 2-7 5-7s5 4 5 7"/></svg>
                </div>
                <span class="text-label">Beginner</span>
              </div>
              <h3>Mat Class</h3>
              <p style="margin-top: var(--space-2); font-size: var(--text-small); color: var(--color-text-muted);">
                Follows the traditional mat order, focusing on precision, flow, and full-body engagement. Ideal for beginners.
              </p>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874853" target="_blank" rel="noopener noreferrer" class="btn btn-ghost link-arrow" style="margin-top: var(--space-3);">Sign Up <span class="arrow">&rarr;</span></a>
            </div>
          </div>

          <!-- Old School -->
          <div class="card">
            <div class="card-content" style="padding: var(--space-4);">
              <div style="display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-3);">
                <div style="width: 48px; height: 48px; border-radius: var(--radius-md); background: rgba(212, 184, 150, 0.25); display: grid; place-items: center;">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary-dark)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
                </div>
                <span class="text-label">All Levels</span>
              </div>
              <h3>Old School Workout</h3>
              <p style="margin-top: var(--space-2); font-size: var(--text-small); color: var(--color-text-muted);">
                Students of all levels practice independently on equipment while the instructor provides personalized guidance.
              </p>
              <a href="https://app.acuityscheduling.com/schedule.php?owner=38253952&appointmentType=88874945" target="_blank" rel="noopener noreferrer" class="btn btn-ghost link-arrow" style="margin-top: var(--space-3);">Sign Up <span class="arrow">&rarr;</span></a>
            </div>
          </div>
        </div>

        <div style="text-align: center; margin-top: var(--space-6);" data-animate="fade-up">
          <a href="/classes" class="btn btn-secondary" data-magnetic>View All Classes &amp; Pricing</a>
        </div>
      </div>
    </section>

    <!-- ======== CTA — GETTING STARTED ======== -->
    <section class="full-bleed" style="background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 50%, var(--color-primary-light) 100%); padding-block: var(--space-12); position: relative; overflow: hidden;">
      <div class="breathing-circle" style="top: -60px; left: -60px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(255,255,255,0.08), transparent);"></div>
      <div class="container" style="position: relative; text-align: center; color: var(--color-surface);">
        <div data-animate="fade-up">
          <span style="font-size: var(--text-xs); letter-spacing: var(--tracking-widest); text-transform: uppercase; color: rgba(255,255,255,0.7);">New to Studio 17?</span>
          <h2 style="color: var(--color-surface); margin-top: var(--space-2); margin-bottom: var(--space-3);">Start With Our Getting Started Package</h2>
          <p style="max-width: 55ch; margin-inline: auto; color: rgba(255,255,255,0.85); margin-bottom: var(--space-2);">
            Three private sessions designed to establish proper form and technique. This foundation ensures your safety and sets you up for success in all future classes.
          </p>
          <p style="font-family: var(--font-display); font-size: var(--text-h2); color: var(--color-surface); margin-bottom: var(--space-4);">$200</p>
          <a href="/contact" class="btn" data-magnetic style="background-color: var(--color-surface); color: var(--color-primary-dark); font-weight: 500;">Book Your First Session</a>
        </div>
      </div>
    </section>

    <!-- ======== WHY STUDIO 17 ======== -->
    <section class="section" id="why-us">
      <div class="container">
        <div style="text-align: center; margin-bottom: var(--space-8);" data-animate="fade-up">
          <span class="section-tag" style="justify-content: center;">Why Studio 17</span>
          <h2 style="margin-top: var(--space-2);">What Sets Us Apart</h2>
        </div>

        <div class="differentiators-grid" data-animate="stagger">
          <div class="differentiator-item">
            <div class="differentiator-number">01</div>
            <h3>Fully Equipped Classical Studio</h3>
            <p>Complete Contrology equipment by Balanced Body &mdash; Cadillac, Reformer, Barrels, Chairs, and supporting small apparatus. Everything you need under one roof.</p>
          </div>
          <div class="differentiator-item">
            <div class="differentiator-number">02</div>
            <h3>Certified Classical Method</h3>
            <p>BeLinda trained under Karen Frischmann with ongoing Mastery Series since 2022. Authentic Classical Pilates preserving Joseph Pilates' original work.</p>
          </div>
          <div class="differentiator-item">
            <div class="differentiator-number">03</div>
            <h3>Personalized Attention</h3>
            <p>Every new student starts with private sessions to build a safe foundation. Small classes ensure individual corrections and alignment guidance throughout your practice.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Wave divider -->
    <svg class="section-divider" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
      <path class="divider-path wave-path" d="M0,40 C360,100 1080,10 1440,60 L1440,120 L0,120 Z" fill="var(--color-surface)"/>
    </svg>

    <!-- ======== HOW IT WORKS ======== -->
    <section class="section" id="process" style="background-color: var(--color-surface);">
      <div class="container">
        <div style="text-align: center; margin-bottom: var(--space-8);" data-animate="fade-up">
          <span class="section-tag" style="justify-content: center;">Your Journey</span>
          <h2 style="margin-top: var(--space-2);">How to Get Started</h2>
        </div>

        <div class="process-steps" data-animate="stagger">
          <div class="process-step">
            <div class="process-step-number">1</div>
            <div class="process-step-line"></div>
            <h3>Schedule a Consultation</h3>
            <p>Contact us to discuss your goals, needs, and any physical considerations. We create the best approach for your unique practice.</p>
          </div>
          <div class="process-step">
            <div class="process-step-number">2</div>
            <div class="process-step-line"></div>
            <h3>Getting Started Package</h3>
            <p>Three private sessions to establish proper form and technique. Build your foundation with personalized one-on-one instruction.</p>
          </div>
          <div class="process-step">
            <div class="process-step-number">3</div>
            <div class="process-step-line"></div>
            <h3>Join Group Classes</h3>
            <p>Once your foundation is set, choose from Reformer, Mat, Old School, or Personal Practice sessions that fit your schedule.</p>
          </div>
          <div class="process-step">
            <div class="process-step-number">4</div>
            <h3>Transform Your Body</h3>
            <p>With consistent practice, experience improved posture, flexibility, balance, and a stronger mind-body connection.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== TESTIMONIALS ======== -->
    <section class="section" id="testimonials">
      <div class="container">
        <div style="text-align: center; margin-bottom: var(--space-8);" data-animate="fade-up">
          <span class="section-tag" style="justify-content: center;">Testimonials</span>
          <h2 style="margin-top: var(--space-2);">What Our Clients Say</h2>
        </div>

        <div class="testimonials-track" data-animate="fade-up">
          <div class="testimonial-card">
            <div class="testimonial-stars" aria-label="5 out of 5 stars">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="testimonial-text">&ldquo;BeLinda truly cares about each student. After my Getting Started sessions, I felt confident moving into group classes. My posture has improved dramatically after just three months.&rdquo;</p>
            <div class="testimonial-author">
              <div class="testimonial-avatar" style="background-color: var(--color-primary-light);">SM</div>
              <div>
                <strong>Sarah M.</strong>
                <span>Reformer Student</span>
              </div>
            </div>
          </div>

          <div class="testimonial-card">
            <div class="testimonial-stars" aria-label="5 out of 5 stars">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="testimonial-text">&ldquo;I was intimidated by Pilates at first, but the welcoming environment at Studio 17 made all the difference. The Classical method is challenging but BeLinda meets you exactly where you are.&rdquo;</p>
            <div class="testimonial-author">
              <div class="testimonial-avatar" style="background-color: var(--color-accent);">JK</div>
              <div>
                <strong>Jennifer K.</strong>
                <span>Mat Class Student</span>
              </div>
            </div>
          </div>

          <div class="testimonial-card">
            <div class="testimonial-stars" aria-label="5 out of 5 stars">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="testimonial-text">&ldquo;As someone recovering from a back injury, I needed guided, careful exercise. BeLinda adapted every session to my needs. I am stronger now than before my injury.&rdquo;</p>
            <div class="testimonial-author">
              <div class="testimonial-avatar" style="background-color: var(--color-secondary);">DL</div>
              <div>
                <strong>David L.</strong>
                <span>Private Session Client</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== FINAL CTA ======== -->
    <section class="section" id="cta-final" style="text-align: center;">
      <div class="container" data-animate="fade-up">
        <h2 style="margin-bottom: var(--space-3);">Discover Your Practice</h2>
        <p style="margin-inline: auto; color: var(--color-text-muted); margin-bottom: var(--space-6);">
          Ready to start your Classical Pilates journey? Schedule a consultation so we can learn about your goals.
        </p>
        <div style="display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
          <a href="/contact" class="btn btn-primary" data-magnetic>Schedule Consultation</a>
          <a href="tel:8643260626" class="btn btn-secondary">Call (864) 326-0626</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;

    & img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(45, 45, 45, 0.3) 0%,
      rgba(45, 45, 45, 0.5) 50%,
      rgba(45, 45, 45, 0.7) 100%
    );
    /* Linen texture effect */
    background-image:
      linear-gradient(180deg, rgba(45, 45, 45, 0.3) 0%, rgba(45, 45, 45, 0.5) 50%, rgba(45, 45, 45, 0.7) 100%),
