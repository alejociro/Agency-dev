---
interface Props {
  text: string;
  name: string;
  role: string;
  initials: string;
  avatarColor?: string;
}

const { text, name, role, initials, avatarColor = 'var(--color-primary-light)' } = Astro.props;
---

<div class="testimonial-card">
  <div class="testimonial-stars" aria-label="5 out of 5 stars">
    {Array.from({ length: 5 }).map(() => (
      <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    ))}
  </div>
  <p class="testimonial-text">&ldquo;{text}&rdquo;</p>
  <div class="testimonial-author">
    <div class="testimonial-avatar" style={`background-color: ${avatarColor};`}>{initials}</div>
    <div>
      <strong>{name}</strong>
      <span>{role}</span>
    </div>
  </div>
</div>

<style>
  .testimonial-card {
    scroll-snap-align: start;
    flex: 0 0 clamp(280px, 80vw, 400px);
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .testimonial-stars {
    display: flex;
    gap: 2px;
  }

  .testimonial-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--color-text);
    flex-grow: 1;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: var(--space-2);

    & strong {
      display: block;
      font-family: var(--font-body);
      font-size: var(--text-small);
    }

    & span {
      font-size: var(--text-xs);
      color: var(--color-text-muted);
    }
  }

  .testimonial-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    color: white;
    font-size: var(--text-small);
    font-weight: 500;
    flex-shrink: 0;
  }
</style>
