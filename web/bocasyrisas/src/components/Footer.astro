---
const year = new Date().getFullYear();

const services = [
  { label: 'Diseño de Sonrisa', href: '#servicios' },
  { label: 'Ortodoncia', href: '#servicios' },
  { label: 'Implantes Dentales', href: '#servicios' },
  { label: 'Blanqueamiento', href: '#servicios' },
  { label: 'Endodoncia', href: '#servicios' },
  { label: 'Odontopediatría', href: '#servicios' },
];

const links = [
  { label: 'Inicio', href: '/' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Testimonios', href: '#testimonios' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <img
          src="/assets/images/logo-bocasyrisas.jpg"
          alt="Bocas y Risas"
          width="64"
          height="64"
          loading="lazy"
          decoding="async"
          style="border-radius: var(--radius-md);"
        />
        <p class="footer-tagline">Una sonrisa vale más que mil palabras.</p>
        <p class="footer-desc">
          27 años creando sonrisas en Medellín con tecnología de vanguardia y un equipo de especialistas comprometidos con tu bienestar.
        </p>
        <div class="footer-social">
          <a href="#" aria-label="Facebook" class="social-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" aria-label="Instagram" class="social-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4 class="footer-heading">Servicios</h4>
        <ul class="footer-list">
          {services.map(s => (
            <li><a href={s.href}>{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Links -->
      <div class="footer-col">
        <h4 class="footer-heading">Clínica</h4>
        <ul class="footer-list">
          {links.map(l => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4 class="footer-heading">Contacto</h4>
        <ul class="footer-list footer-contact">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Medellín, Antioquia
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (604) 444 5555
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            citas@bocasyrisas.com
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Lun - Vie: 8am - 6pm<br/>Sab: 8am - 1pm
          </li>
        </ul>
      </div>
    </div>

    <div class="divider" style="margin: 3rem 0 1.5rem;"></div>

    <div class="footer-bottom">
      <p>&copy; {year} Bocas & Risas Clínica Odontológica. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: var(--color-text-on-dark);
    padding: var(--space-12) 0 var(--space-4);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: var(--space-6);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-style: italic;
    color: var(--color-secondary-light);
    line-height: var(--leading-snug);
  }

  .footer-desc {
    font-size: var(--text-small);
    color: var(--color-text-on-dark-muted);
    max-width: 32ch;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-text-on-dark);
    transition: all 0.25s ease;
  }

  .social-icon:hover {
    background: var(--color-secondary);
    color: var(--color-primary-dark);
    transform: translateY(-2px);
  }

  .footer-heading {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary-light);
    margin-bottom: 1.25rem;
  }

  .footer-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .footer-list a {
    font-size: var(--text-small);
    color: var(--color-text-on-dark-muted);
    transition: color 0.2s ease;
  }

  .footer-list a:hover {
    color: var(--color-secondary-light);
  }

  .footer-contact li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: var(--text-small);
    color: var(--color-text-on-dark-muted);
  }

  .footer-contact svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-secondary);
  }

  .footer .divider {
    background: linear-gradient(90deg, transparent, rgba(78, 205, 196, 0.3), transparent);
  }

  .footer-bottom {
    text-align: center;
  }

  .footer-bottom p {
    font-size: var(--text-small);
    color: var(--color-text-on-dark-muted);
    max-width: none;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
