    background: linear-gradient(135deg, var(--color-secondary), var(--color-secondary-dark));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: clamp(1rem, 1.3vw, 1.2rem);
