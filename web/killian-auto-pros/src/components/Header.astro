---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const phone = '864-648-8408';
---

<header class="nav nav-enter" role="banner">
  <div class="nav__inner container">
    <!-- Logo -->
    <a href="/" class="nav__logo site-logo" aria-label="Killian Auto Pros - Home">
      <img
        src="https://killianautopros.com/wp-content/uploads/2023/02/killian-auto-pros-logo.png"
        alt="Killian Auto Pros logo"
        width="180"
        height="48"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="nav__desktop" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <!-- CTA + Phone -->
    <div class="nav__actions">
      <a href={`tel:${phone.replace(/-/g, '')}`} class="nav__phone" aria-label="Call us">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
        </svg>
        <span>{phone}</span>
      </a>
      <a href="/contact#appointment" class="btn btn--primary btn--sm" data-magnetic>
        Book Now
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button class="hamburger" data-menu-toggle aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" role="dialog" aria-label="Mobile navigation">
    <nav class="mobile-menu__nav">
      {navLinks.map((link) => (
        <a href={link.href} class="mobile-menu__link">{link.label}</a>
      ))}
      <a href={`tel:${phone.replace(/-/g, '')}`} class="mobile-menu__link mobile-menu__link--phone">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
        </svg>
        {phone}
      </a>
      <a href="/contact#appointment" class="btn btn--primary btn--lg mobile-menu__cta">Book Appointment</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: var(--z-nav);
    padding-block: var(--space-2);
    transition: background 300ms ease, padding 300ms ease;
  }

  .nav--scrolled {
    background: oklch(0.12 0.01 50 / 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding-block: 0.625rem;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .nav__logo img {
    height: 40px;
    width: auto;
  }

  .nav__desktop {
    display: none;
    align-items: center;
    gap: var(--space-4);

    @media (min-width: 1024px) {
      display: flex;
    }
  }

  .nav-link {
    font-family: var(--font-display), 'Bebas Neue', sans-serif;
    font-size: 1.05rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-inverse);
    position: relative;
  }

  .nav__actions {
    display: none;
    align-items: center;
    gap: var(--space-3);

    @media (min-width: 1024px) {
      display: flex;
    }
  }

  .nav__phone {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-text-inverse);
    font-size: var(--text-small);
    letter-spacing: var(--tracking-wide);
    transition: color var(--duration-fast) ease;

    &:hover {
      color: var(--color-primary);
    }
  }

  .btn--sm {
    padding: 0.625rem 1.5rem;
    font-size: 0.95rem;
  }

  .hamburger {
    display: flex;
    z-index: calc(var(--z-nav) + 2);

    @media (min-width: 1024px) {
      display: none;
    }
  }

  /* Mobile Menu */
  .mobile-menu {
    position: fixed;
    inset: 0;
    background: var(--color-secondary);
    z-index: calc(var(--z-nav) + 1);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;

    @media (min-width: 1024px) {
      display: none;
    }
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mobile-menu__link {
    font-family: var(--font-display), 'Bebas Neue', sans-serif;
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    text-transform: uppercase;
    color: var(--color-text-inverse);
    letter-spacing: var(--tracking-wide);
    transition: color var(--duration-fast) ease;

    &:hover {
      color: var(--color-primary);
    }
  }

  .mobile-menu__link--phone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 1.2rem;
    color: var(--color-metal);
  }

  .mobile-menu__cta {
    margin-block-start: var(--space-2);
  }
</style>
