---
const currentYear = new Date().getFullYear();
const phone = '864-648-8408';

const locations = [
  { name: 'Mauldin', address: '451 N Main St, Mauldin, SC 29662' },
  { name: 'Greenville', address: '3111 Augusta St, Greenville, SC 29605' },
  { name: 'Fountain Inn', address: '550 N Woods Dr, Fountain Inn, SC 29644' },
  { name: 'Spartanburg', address: '120B Southport Rd, Spartanburg, SC 29306' },
];

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'About Us', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const services = [
  'AC & Heat Repair',
  'Brake Repair',
  'Diagnostics',
  'Engines',
  'Jeep Specialists',
  'Oil Changes',
  'Steering & Suspension',
  'Tires & Alignments',
  'Transmissions',
];
---

<footer class="footer" role="contentinfo">
  <!-- Hazard stripe divider -->
  <div class="stripe-animated" aria-hidden="true"></div>

  <div class="footer__main metal-bg">
    <div class="container">
      <div class="footer__grid">
        <!-- Brand column -->
        <div class="footer__brand">
          <a href="/" class="footer__logo" aria-label="Killian Auto Pros">
            <img
              src="https://killianautopros.com/wp-content/uploads/2023/02/killian-auto-pros-logo.png"
              alt="Killian Auto Pros logo"
              width="200"
              height="52"
              loading="lazy"
              decoding="async"
            />
          </a>
          <p class="footer__tagline">Precision Workmanship. Timely Service.</p>
          <p class="footer__desc">
            Family-owned auto repair serving South Carolina with ASE-Certified technicians
            across 4 locations. Your car deserves the best.
          </p>
          <a href={`tel:${phone.replace(/-/g, '')}`} class="footer__phone-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
            {phone}
          </a>
        </div>

        <!-- Navigation -->
        <div class="footer__col">
          <h3 class="footer__heading">Navigate</h3>
          <nav aria-label="Footer navigation">
            <ul class="footer__list">
              {navLinks.map((link) => (
                <li><a href={link.href} class="footer__link">{link.label}</a></li>
              ))}
              <li><a href="/contact#appointment" class="footer__link">Book Appointment</a></li>
            </ul>
          </nav>
        </div>

        <!-- Services -->
        <div class="footer__col">
          <h3 class="footer__heading">Services</h3>
          <ul class="footer__list">
            {services.map((s) => (
              <li><a href="/services" class="footer__link">{s}</a></li>
            ))}
          </ul>
        </div>

        <!-- Locations -->
        <div class="footer__col">
          <h3 class="footer__heading">Locations</h3>
          <ul class="footer__locations">
            {locations.map((loc) => (
              <li class="footer__location">
                <strong>{loc.name}</strong>
                <span>{loc.address}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; {currentYear} Killian Auto Pros. All rights reserved.</p>
      <div class="footer__legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer__main {
    padding-block: var(--space-12) var(--space-8);
    color: var(--color-text-inverse);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);

    @media (min-width: 768px) {
      grid-template-columns: 2fr 1fr 1fr;
    }

    @media (min-width: 1024px) {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
    }
  }

  .footer__logo img {
    height: 44px;
    width: auto;
    margin-block-end: var(--space-2);
  }

  .footer__tagline {
    font-family: var(--font-display), 'Bebas Neue', sans-serif;
    font-size: var(--text-h3);
    text-transform: uppercase;
    color: var(--color-primary);
    letter-spacing: var(--tracking-wide);
    margin-block-end: var(--space-2);
  }

  .footer__desc {
    color: var(--color-metal);
    font-size: var(--text-small);
    line-height: var(--leading-body);
    margin-block-end: var(--space-3);
  }

  .footer__phone-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-inverse);
    font-family: var(--font-display), 'Bebas Neue', sans-serif;
    font-size: 1.3rem;
    letter-spacing: var(--tracking-wide);
    transition: color var(--duration-fast) ease;

    &:hover {
      color: var(--color-primary);
    }
  }

  .footer__heading {
    font-size: var(--text-h3);
    color: var(--color-text-inverse);
    margin-block-end: var(--space-3);
    padding-block-end: var(--space-1);
    border-block-end: 2px solid var(--color-primary);
    display: inline-block;
  }

  .footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__link {
    color: var(--color-metal);
    font-size: var(--text-small);
    transition: color var(--duration-fast) ease;

    &:hover {
      color: var(--color-text-inverse);
    }
  }

  .footer__locations {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__location {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;

    & strong {
      color: var(--color-text-inverse);
      font-family: var(--font-display), 'Bebas Neue', sans-serif;
      font-size: 1.05rem;
      text-transform: uppercase;
      letter-spacing: var(--tracking-wide);
    }

    & span {
      color: var(--color-metal);
      font-size: var(--text-small);
    }
  }

  .footer__bottom {
    background: oklch(0.08 0.01 50);
    padding-block: var(--space-2);
  }

  .footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-metal-dark);
    font-size: var(--text-small);
  }

  .footer__legal {
    display: flex;
    gap: var(--space-3);

    & a {
      color: var(--color-metal-dark);
      transition: color var(--duration-fast) ease;

      &:hover {
        color: var(--color-metal);
      }
    }
  }
</style>
