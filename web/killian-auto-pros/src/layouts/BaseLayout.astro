---
interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
  schema?: object;
}

const {
  title,
  description = "Family-owned auto repair with ASE-Certified technicians serving Mauldin, Greenville, Fountain Inn & Spartanburg, SC. Free loaner cars, rides to work, and 24/7 key dropbox.",
  canonicalURL,
  ogImage = "https://killianautopros.com/wp-content/uploads/2023/02/SLIDER3-01-01-scaled.jpg",
  schema
} = Astro.props;

const siteName = "Killian Auto Pros";
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const siteUrl = "https://killianautopros.com";

/* Default LocalBusiness schema if none provided */
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  "name": "Killian Auto Pros",
  "description": description,
  "url": siteUrl,
  "telephone": "864-648-8408",
  "image": ogImage,
  "priceRange": "$$",
  "logo": "https://killianautopros.com/wp-content/uploads/2023/02/killian-auto-pros-logo.png",
  "sameAs": [],
  "address": [
    {
      "@type": "PostalAddress",
      "streetAddress": "451 N Main St",
      "addressLocality": "Mauldin",
      "addressRegion": "SC",
      "postalCode": "29662",
      "addressCountry": "US"
    },
    {
      "@type": "PostalAddress",
      "streetAddress": "3111 Augusta St",
      "addressLocality": "Greenville",
      "addressRegion": "SC",
      "postalCode": "29605",
      "addressCountry": "US"
    },
    {
      "@type": "PostalAddress",
      "streetAddress": "550 N Woods Dr",
      "addressLocality": "Fountain Inn",
      "addressRegion": "SC",
      "postalCode": "29644",
      "addressCountry": "US"
    },
    {
      "@type": "PostalAddress",
      "streetAddress": "120B Southport Rd",
      "addressLocality": "Spartanburg",
      "addressRegion": "SC",
      "postalCode": "29306",
      "addressCountry": "US"
    }
  ],
  "areaServed": [
    { "@type": "City", "name": "Mauldin" },
    { "@type": "City", "name": "Greenville" },
    { "@type": "City", "name": "Fountain Inn" },
    { "@type": "City", "name": "Spartanburg" }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Auto Repair Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AC & Heat Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Brake Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Diagnostics" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Engine Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Oil Changes & Maintenance" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Steering & Suspension" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tires & Alignments" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Transmission Repair" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Jeep Specialists" } }
    ]
  }
};

import '../styles/design-system.css';
import '../styles/animations.css';

const schemaData = schema || defaultSchema;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO Primary -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="auto repair, mechanic, oil change, brakes, engine repair, transmission, tires, alignment, Mauldin SC, Greenville SC, Fountain Inn SC, Spartanburg SC, ASE certified, Killian Auto Pros" />
  {canonicalURL && <link rel="canonical" href={canonicalURL} />}
  <meta name="theme-color" content="#D90000" />
  <meta name="robots" content="index, follow" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="https://killianautopros.com/wp-content/uploads/2023/02/killian-auto-pros-favicon.png" />
  <link rel="apple-touch-icon" href="https://killianautopros.com/wp-content/uploads/2023/02/killian-auto-pros-favicon.png" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL || siteUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter/X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Preconnect to critical origins -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://maps.google.com" />

  <!-- Fonts (display=swap for performance) -->
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- Preload hero image -->
  <link rel="preload" href="https://killianautopros.com/wp-content/uploads/2023/02/SLIDER3-01-01-scaled.jpg" as="image" fetchpriority="high" />

  <!-- Design System + Animations (imported via Astro for Vite processing) -->

  <!-- Schema JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <!-- Speculation Rules (prefetch likely pages) -->
  <script type="speculationrules">
  {
    "prerender": [
      { "where": { "href_matches": "/services" } },
      { "where": { "href_matches": "/contact" } }
    ],
    "prefetch": [
      { "where": { "href_matches": "/about" } }
    ]
  }
  </script>

  <!-- Performance: content-visibility for below-fold sections -->
  <style>
    section:not(:first-of-type) {
      content-visibility: auto;
      contain-intrinsic-size: auto 600px;
    }
  </style>
</head>
<body class="grain">
  <!-- Skip to content (Accessibility) -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- Reading progress bar -->
  <div class="reading-progress" aria-hidden="true"></div>

  <main id="main-content">
    <slot />
  </main>

  <!-- Animation controller -->
  <script src="../scripts/animations.js"></script>
</body>
</html>
