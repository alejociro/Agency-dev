---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    num: '01',
    title: 'AC & Heat Repair',
    slug: 'ac-heat',
    category: 'climate',
    desc: 'Stay comfortable year-round with expert climate control service. We diagnose and repair AC compressors, condensers, evaporators, heater cores, and blower motors.',
    benefits: ['Full AC system diagnostics', 'Refrigerant recharge and leak detection', 'Heater core repair and replacement', 'Climate control electrical repair'],
    img: 'https://images.unsplash.com/photo-1580983218765-907b1e98d84a?w=800&h=500&fit=crop&q=75&auto=format',
  },
  {
    num: '02',
    title: 'Brake Repair',
    slug: 'brakes',
    category: 'safety',
    desc: 'Your brakes are your most important safety system. We inspect, repair, and replace every component to ensure confident, reliable stopping power.',
    benefits: ['Brake pad and rotor replacement', 'Caliper repair and rebuilding', 'Brake fluid flush and bleeding', 'ABS system diagnostics'],
    img: 'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&h=500&fit=crop&q=75&auto=format',
  },
  {
    num: '03',
    title: 'Diagnostics',
    slug: 'diagnostics',
    category: 'diagnostics',
    desc: 'Check engine light on? Strange noise? Our state-of-the-art diagnostic equipment pinpoints issues fast so we fix the problem right the first time.',
    benefits: ['Computer engine diagnostics', 'Electrical system testing', 'Check engine light diagnosis', 'Pre-purchase vehicle inspections'],
    img: 'https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=800&h=500&fit=crop&q=75&auto=format',
  },
  {
    num: '04',
    title: 'Engines',
    slug: 'engines',
    category: 'drivetrain',
    desc: 'From tune-ups to complete rebuilds, our ASE-Certified engine specialists keep your motor running at peak performance.',
    benefits: ['Engine rebuilds and replacements', 'Timing belt and chain service', 'Head gasket repair', 'Performance tuning and upgrades'],
    img: 'https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?w=800&h=500&fit=crop&q=75&auto=format',
  },
  {
    num: '05',
    title: 'Oil Changes & Maintenance',
    slug: 'oil-changes',
    category: 'maintenance',
    desc: 'Regular maintenance is the best way to avoid expensive repairs. Quick, thorough oil changes and scheduled maintenance to keep your vehicle reliable.',
    benefits: ['Conventional and synthetic oil changes', 'Multi-point vehicle inspections', 'Filter replacements (air, cabin, fuel)', 'Fluid top-offs and coolant flush'],
    img: 'https://images.unsplash.com/photo-1635784063388-1ff609e39537?w=800&h=500&fit=crop&q=75&auto=format',
  },
  {
    num: '06',
    title: 'Steering & Suspension',
    slug: 'steering',
    category: 'safety',
    desc: 'Ride smooth and handle with confidence. We repair and replace shocks, struts, tie rods, ball joints, and power steering components.',
    benefits: ['Shock and strut replacement', 'Power steering repair', 'Ball joint and tie rod service', 'Suspension lift and lowering kits'],
    img: 'https://images.unsplash.com/photo-1625047509248-ec889cbff17f?w=800&h=500&fit=crop&q=75&auto=format',
  },
  {
    num: '07',
    title: 'Tires & Alignments',
    slug: 'tires',
    category: 'maintenance',
    desc: 'Maximize tire life and fuel efficiency with expert tire service and precision computer alignments.',
    benefits: ['New tire sales and installation', 'Tire rotation and balancing', 'Precision 4-wheel alignment', 'Flat repair and TPMS service'],
    img: 'https://images.unsplash.com/photo-1578844251758-2f71da64c96f?w=800&h=500&fit=crop&q=75&auto=format',
  },
  {
    num: '08',
    title: 'Transmissions',
    slug: 'transmissions',
    category: 'drivetrain',
    desc: 'Manual or automatic, we handle it all. From fluid changes to complete rebuilds, we keep your drivetrain shifting smooth.',
    benefits: ['Transmission fluid service', 'Clutch repair and replacement', 'Transmission rebuild and replacement', 'Transfer case and differential service'],
    img: 'https://images.unsplash.com/photo-1530046339160-ce3e530c7d2f?w=800&h=500&fit=crop&q=75&auto=format',
  },
  {
    num: '09',
    title: 'Jeep Specialists',
    slug: 'jeep',
    category: 'specialty',
    desc: 'Dedicated Jeep service from our team of specialists. Whether you need trail-ready upgrades, lift kits, or routine maintenance, we know Jeeps inside and out.',
    benefits: ['Jeep-specific diagnostics and repair', 'Lift kit installation and suspension upgrades', 'Off-road preparation and trail maintenance', 'Wrangler, Cherokee, and Gladiator specialists'],
    img: 'https://images.unsplash.com/photo-1533473359331-0135ef1b58bf?w=800&h=500&fit=crop&q=75&auto=format',
  },
];

const faqs = [
  { q: 'How long does a typical repair take?', a: 'Most standard services like oil changes and brake jobs are completed same-day. Larger repairs like engine or transmission work typically take 2-5 business days. We always provide an estimated timeline before starting any work.' },
  { q: 'Do you offer warranties on repairs?', a: 'Yes. All parts and labor come with a warranty. Specific warranty terms vary by service type, and we will explain the coverage before any work begins.' },
  { q: 'Can I get a free estimate?', a: 'Absolutely. We provide free estimates for all services. For a second opinion on work quoted by another shop, just bring in the estimate and we will review it at no charge.' },
  { q: 'What makes Killian Auto Pros different?', a: 'We are family-owned with ASE-Certified technicians, and we offer amenities no other shop matches: free loaner cars, free rides to work, 24/7 key dropbox, free vehicle pickup and delivery, and always a free second opinion.' },
  { q: 'Do I need an appointment?', a: 'Appointments are recommended to ensure we can serve you promptly, but we do accept walk-ins based on availability. Book online or call us to secure your time slot.' },
  { q: 'Which location should I visit?', a: 'All four locations offer the same full range of services. Visit whichever is most convenient for you: Mauldin, Greenville, Fountain Inn, or Spartanburg.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<BaseLayout
  title="Auto Repair Services"
  description="Full-service auto repair: AC, brakes, diagnostics, engines, oil changes, steering, tires, and transmissions. ASE-Certified technicians at 4 SC locations."
  schema={faqSchema}
>
  <Header />

  <!-- ============================================
       HERO — Services
       ============================================ -->
  <section class="services-hero metal-bg">
    <div class="services-hero__overlay" aria-hidden="true"></div>
    <div class="container services-hero__content">
      <span class="hero-tag section-tag section-tag--light">9 Specialties · 4 Locations</span>
      <h1 class="hero-title" data-split>Expert Auto Repair For Every System</h1>
      <div class="hero-line red-line red-line--wide" aria-hidden="true"></div>
      <p class="hero-sub">
        From routine maintenance to complex engine and transmission rebuilds. Our ASE-Certified
        team handles everything under the hood.
      </p>
    </div>
  </section>

  <!-- ============================================
       SERVICE GRID
       ============================================ -->
  <section class="section-padding">
    <div class="container">
      <div class="services-grid" data-service-grid>
        {services.map((s) => (
          <article class="services-detail" id={s.slug} data-service-category={s.category}>
            <div class="services-detail__header">
              <span class="services-detail__num" aria-hidden="true">{s.num}</span>
              <h2 class="services-detail__title">{s.title}</h2>
              <div class="red-line" aria-hidden="true"></div>
            </div>
            <div class="services-detail__img-wrap">
              <img
                src={s.img}
                alt={`${s.title} service at Killian Auto Pros`}
                width="800"
                height="500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <p class="services-detail__desc">{s.desc}</p>
            <ul class="services-detail__benefits">
              {s.benefits.map((b) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {b}
                </li>
              ))}
            </ul>
            <a href="/contact#appointment" class="btn btn--primary">
              Book This Service <span class="arrow" aria-hidden="true">&rarr;</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       FAQ
       ============================================ -->
  <section class="section-padding metal-bg--light" id="faq">
    <div class="container">
      <div class="section-header" data-animate="fade-up">
        <span class="section-tag">FAQ</span>
        <h2>Common Questions</h2>
      </div>

      <div class="faq-list" data-animate="stagger">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-item__question">
              <span>{faq.q}</span>
              <svg class="faq-item__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </summary>
            <div class="faq-item__answer">
              <p>{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       CTA
       ============================================ -->
  <section class="cta-banner">
    <div class="container cta-banner__inner">
      <h2>Ready To Schedule Your Service?</h2>
      <p>Book online in 60 seconds or call us directly. Free estimates on every repair.</p>
      <a href="/contact#appointment" class="btn btn--outline-light btn--lg" data-magnetic>
        Book Appointment <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ---- Services Hero ---- */
  .services-hero {
    position: relative;
    padding-block: 10rem 5rem;
    overflow: hidden;
  }

  .services-hero__overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 60%, oklch(0.55 0.25 27 / 0.1) 0%, transparent 50%);
  }

  .services-hero__content {
    position: relative;
    z-index: 2;
  }

  .services-hero .hero-title {
    font-size: var(--text-h1);
    color: var(--color-text-inverse);
    max-width: 18ch;
    margin-block: var(--space-3) var(--space-2);
  }

  .services-hero .hero-sub {
    color: var(--color-metal);
    max-width: 50ch;
  }

  /* ---- Service Grid ---- */
  .services-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .services-detail {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    padding-block-end: var(--space-8);
    border-block-end: 1px solid var(--color-border);

    @media (min-width: 768px) {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4) var(--space-8);
    }
  }

  .services-detail__header {
    @media (min-width: 768px) {
      grid-column: 1 / -1;
    }
  }

  .services-detail__num {
    font-family: var(--font-display), 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.04em;
    opacity: 0.35;
  }

  .services-detail__title {
    font-size: var(--text-h2);
    margin-block: var(--space-1);
  }

  .services-detail__img-wrap {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border: 1px solid var(--color-border);

    @media (min-width: 768px) {
      grid-row: 2 / 5;
      grid-column: 2;
    }
  }

  .services-detail__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .services-detail:hover .services-detail__img-wrap img {
    transform: scale(1.04);
  }

  .services-detail__desc {
    color: var(--color-text-muted);
    line-height: var(--leading-body);
  }

  .services-detail__benefits {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    & li {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      font-size: var(--text-body);
    }
  }

  .services-detail .btn {
    align-self: start;
    margin-block-start: var(--space-1);

    @media (min-width: 768px) {
      grid-column: 1;
    }
  }

  /* ---- FAQ ---- */
  .faq-list {
    max-width: 800px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-block-end: 1px solid var(--color-border);
  }

  .faq-item summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
    padding-block: var(--space-3);
    font-family: var(--font-display), 'Bebas Neue', sans-serif;
    font-size: var(--text-h3);
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
    min-height: 44px;
  }

  .faq-item summary::marker {
    display: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item__icon {
    flex-shrink: 0;
    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-item[open] .faq-item__icon {
    transform: rotate(45deg);
  }

  .faq-item__answer {
    padding-block-end: var(--space-3);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    animation: faqSlideDown 0.3s ease both;
  }

  @keyframes faqSlideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ---- CTA Banner ---- */
  .cta-banner {
    background: var(--color-primary);
    padding-block: var(--space-12);
    text-align: center;
  }

  .cta-banner__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .cta-banner h2 {
    color: var(--color-text-inverse);
    font-size: var(--text-h1);
  }

  .cta-banner p {
    color: oklch(1 0 0 / 0.8);
    max-width: 45ch;
    text-align: center;
  }
</style>
