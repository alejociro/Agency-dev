---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { value: 4, suffix: '', label: 'SC Locations' },
  { value: 9, suffix: '', label: 'Service Specialties' },
  { value: 7, suffix: '+', label: 'Free Amenities' },
  { value: 24, suffix: '/7', label: 'Key Dropbox Access' },
];

const values = [
  {
    num: '01',
    title: 'Transparency',
    desc: 'No surprises. We keep you in the loop through the entire repair process. You will always know what we are doing and why before we do it.',
  },
  {
    num: '02',
    title: 'Precision',
    desc: 'Our ASE-Certified technicians take pride in every service and repair. We diagnose accurately and fix it right the first time.',
  },
  {
    num: '03',
    title: 'Customer First',
    desc: 'Free loaner cars, free rides, 24/7 key dropbox, free vehicle pickup and delivery. We remove every obstacle between you and getting your car fixed.',
  },
  {
    num: '04',
    title: 'Honesty',
    desc: 'Free second opinions on any repair estimate. We will never recommend work you do not need. Our loyal customers are proof of that commitment.',
  },
];

const timeline = [
  { year: 'Founded', title: 'Mauldin Shop Opens', desc: 'Killian Auto Pros opens its first location on North Main Street in Mauldin, SC, with a simple mission: honest auto repair with exceptional service.' },
  { year: 'Growth', title: 'Greenville Expansion', desc: 'Growing demand leads to a second location on Augusta Street in Greenville, bringing the same family-owned quality to more of the Upstate.' },
  { year: 'Expansion', title: 'Fountain Inn & Spartanburg', desc: 'Two more locations open to serve the wider Upstate SC community. The Killian family commitment to precision workmanship now spans four shops.' },
  { year: 'Today', title: '4 Locations Strong', desc: 'A team of ASE-Certified technicians, a fleet of loaner vehicles, and thousands of satisfied customers. Still family-owned, still putting customers first.' },
];
---

<BaseLayout
  title="About Us"
  description="Meet the Killian family. ASE-Certified technicians, 4 South Carolina locations, and a commitment to honest auto repair since day one."
>
  <Header />

  <!-- ============================================
       HERO — About
       ============================================ -->
  <section class="about-hero metal-bg">
    <div class="container about-hero__content">
      <span class="hero-tag section-tag section-tag--light">Our Story</span>
      <h1 class="hero-title" data-split>Family-Owned. Customer-Driven.</h1>
      <div class="hero-line red-line red-line--wide" aria-hidden="true"></div>
      <p class="hero-sub">
        At Killian Auto Pros, we do auto repair differently. We greet every customer who comes
        through the door and keep you in the loop through the entire repair process.
      </p>
    </div>
  </section>

  <!-- ============================================
       STATS BAR
       ============================================ -->
  <section class="stats-bar" data-animate="fade-up">
    <div class="container stats-bar__inner">
      {stats.map((s) => (
        <div class="stats-bar__item">
          <span class="stats-bar__value counter" data-counter data-target={s.value.toString()} data-suffix={s.suffix}>0</span>
          <span class="stats-bar__label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================
       MISSION STATEMENT
       ============================================ -->
  <section class="section-padding">
    <div class="container">
      <div class="mission-grid" data-animate="fade-up">
        <div class="mission-img-wrap">
          <img
            src="https://killianautopros.com/wp-content/uploads/2023/02/SLIDER3-01-01-scaled.jpg"
            alt="Killian Auto Pros team working in the shop"
            width="700"
            height="500"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="mission">
          <blockquote class="mission__quote">
            <p>Whether your car is simply due for its next oil change, or you need intricate engine
            or transmission repairs, our team of ASE-Certified technicians is waiting to help get
            you and your vehicle safely back on the road.</p>
          </blockquote>
          <div class="mission__attribution">
            <div class="red-line" aria-hidden="true"></div>
            <span class="text-label">The Killian Family</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       CORE VALUES
       ============================================ -->
  <section class="section-padding metal-bg--light" id="values">
    <div class="container">
      <div class="section-header" data-animate="fade-up">
        <span class="section-tag">What Drives Us</span>
        <h2>Our Core Values</h2>
      </div>

      <div class="values-grid" data-animate="stagger">
        {values.map((v) => (
          <div class="card card--brutal">
            <span class="number-label number-label--shifted" aria-hidden="true">{v.num}</span>
            <h3>{v.title}</h3>
            <div class="red-line" aria-hidden="true" style="margin-block: var(--space-2);"></div>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       TIMELINE
       ============================================ -->
  <section class="section-padding" id="history">
    <div class="container">
      <div class="section-header" data-animate="fade-up">
        <span class="section-tag">Our Journey</span>
        <h2>How We Got Here</h2>
      </div>

      <div class="timeline">
        {timeline.map((item, i) => (
          <div class="timeline__item" data-animate={i % 2 === 0 ? 'fade-right' : 'fade-left'}>
            <div class="timeline__marker" aria-hidden="true">
              <div class="timeline__dot"></div>
            </div>
            <div class="timeline__content">
              <span class="text-mono timeline__year">{item.year}</span>
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
        <div class="timeline__line" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ============================================
       CERTIFICATIONS
       ============================================ -->
  <section class="section-padding metal-bg" data-animate="fade-up">
    <div class="container cert-section">
      <div class="cert-section__text">
        <span class="section-tag section-tag--light">Credentials</span>
        <h2 style="color: var(--color-text-inverse);">ASE-Certified Technicians</h2>
        <p style="color: var(--color-metal);">
          Every technician at Killian Auto Pros holds ASE certification, the gold standard in
          automotive repair. This means your vehicle is serviced by professionals who have
          passed rigorous testing and demonstrated real-world expertise.
        </p>
        <a href="/contact#appointment" class="btn btn--primary" data-magnetic style="margin-block-start: var(--space-3);">
          Book With Confidence <span class="arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <div class="cert-section__badge" aria-hidden="true">
        <div class="cert-badge">
          <span class="cert-badge__text">ASE</span>
          <span class="cert-badge__sub">Certified</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       CTA
       ============================================ -->
  <section class="cta-banner">
    <div class="container" style="display: flex; flex-direction: column; align-items: center; gap: var(--space-3); text-align: center;">
      <h2 style="color: var(--color-text-inverse); font-size: var(--text-h1);">Come Meet The Family</h2>
      <p style="color: oklch(1 0 0 / 0.8); max-width: 45ch; text-align: center;">Visit any of our four South Carolina locations. We would love to show you the Killian difference.</p>
      <a href="/contact" class="btn btn--outline-light btn--lg" data-magnetic>
        Find A Location <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ---- About Hero ---- */
  .about-hero {
    padding-block: 10rem 5rem;
    position: relative;
  }

  .about-hero__content {
    position: relative;
    z-index: 2;
  }

  .about-hero .hero-title {
    font-size: var(--text-h1);
    color: var(--color-text-inverse);
    max-width: 16ch;
    margin-block: var(--space-3) var(--space-2);
  }

  .about-hero .hero-sub {
    color: var(--color-metal);
    max-width: 50ch;
  }

  /* ---- Stats Bar ---- */
  .stats-bar {
    background: var(--color-secondary);
    padding-block: var(--space-6);
  }

  .stats-bar__inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    text-align: center;

    @media (min-width: 768px) {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stats-bar__item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stats-bar__value {
    font-family: var(--font-display), 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--color-primary);
    line-height: 1;
  }

  .stats-bar__label {
    font-size: var(--text-small);
    letter-spacing: var(--tracking-expanded);
    text-transform: uppercase;
    color: var(--color-metal);
  }

  /* ---- Mission ---- */
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;

    @media (min-width: 768px) {
      grid-template-columns: 1fr 1fr;
    }
  }

  .mission-img-wrap {
    overflow: hidden;
    aspect-ratio: 7 / 5;
  }

  .mission-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mission {
    max-width: 750px;
    margin-inline: auto;
    text-align: center;

    @media (min-width: 768px) {
      text-align: start;
    }
  }

  .mission__quote p {
    font-family: var(--font-display), 'Bebas Neue', sans-serif;
    font-size: var(--text-h2);
    text-transform: uppercase;
    line-height: var(--leading-snug);
    color: var(--color-secondary);
    max-width: none;
  }

  .mission__attribution {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    margin-block-start: var(--space-4);

    @media (min-width: 768px) {
      align-items: start;
    }
  }

  /* ---- Values Grid ---- */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);

    @media (min-width: 768px) {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .values-grid .card {
    padding-block-start: var(--space-6);

    & h3 {
      font-size: var(--text-h2);
    }

    & p {
      color: var(--color-text-muted);
    }
  }

  /* ---- Timeline ---- */
  .timeline {
    position: relative;
    max-width: 700px;
    margin-inline: auto;
    padding-inline-start: var(--space-6);
  }

  .timeline__line {
    position: absolute;
    inset-inline-start: 10px;
    inset-block: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--color-primary), var(--color-border));
  }

  .timeline__item {
    position: relative;
    padding-block-end: var(--space-6);
  }

  .timeline__marker {
    position: absolute;
    inset-inline-start: calc(-1 * var(--space-6) + 2px);
    inset-block-start: 0.25rem;
  }

  .timeline__dot {
    width: 18px;
    height: 18px;
    background: var(--color-primary);
    border-radius: var(--radius-full);
    border: 3px solid var(--color-bg);
    box-shadow: 0 0 0 2px var(--color-primary);
  }

  .timeline__year {
    color: var(--color-primary);
    margin-block-end: var(--space-1);
    display: block;
  }

  .timeline__content h3 {
    font-size: var(--text-h3);
    margin-block-end: var(--space-1);
  }

  .timeline__content p {
    color: var(--color-text-muted);
    font-size: var(--text-body);
  }

  /* ---- Certifications ---- */
  .cert-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;

    @media (min-width: 768px) {
      grid-template-columns: 2fr 1fr;
    }
  }

  .cert-badge {
    width: 160px;
    height: 160px;
    border-radius: var(--radius-full);
    border: 4px solid var(--color-primary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-inline: auto;
  }

  .cert-badge__text {
    font-family: var(--font-display), 'Bebas Neue', sans-serif;
    font-size: 3rem;
    color: var(--color-primary);
    line-height: 1;
  }

  .cert-badge__sub {
    font-size: var(--text-small);
    letter-spacing: var(--tracking-expanded);
    text-transform: uppercase;
    color: var(--color-metal);
  }

  /* CTA Banner */
  .cta-banner {
    background: var(--color-primary);
    padding-block: var(--space-6);
  }
</style>
