---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Membership" description="Flexible membership plans at Refora Greenville. Unlimited Pilates, Yoga classes and café perks. Find the plan that fits your rhythm.">
  <Header />

  <section class="page-hero">
    <div class="container">
      <span class="hero-tag text-label">Membership</span>
      <h1 class="hero-title">Find Your Plan.<br />Find Your Rhythm.</h1>
      <p class="hero-sub">Flexible options designed to fit your life. Every membership includes café perks and community benefits.</p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="section">
    <div class="container">
      <div class="pricing-grid" data-animate="stagger">
        <!-- Drop In -->
        <article class="pricing-card card">
          <div class="pricing-card__header">
            <h3>Drop In</h3>
            <p class="text-muted">Try before you commit</p>
          </div>
          <div class="pricing-card__price">
            <span class="pricing-amount pricing-amount--contact">Contact for pricing</span>
          </div>
          <ul class="pricing-features">
            <li>Single class access</li>
            <li>All class types</li>
            <li>10% café discount</li>
            <li>No commitment</li>
          </ul>
          <a href="/contact/" class="btn btn--secondary">Get Started</a>
        </article>

        <!-- Monthly — Featured -->
        <article class="pricing-card pricing-card--featured card card--gold-accent">
          <div class="pricing-card__badge">Most Popular</div>
          <div class="pricing-card__header">
            <h3>Unlimited Monthly</h3>
            <p class="text-muted">For the committed practitioner</p>
          </div>
          <div class="pricing-card__price">
            <span class="pricing-amount pricing-amount--contact">Contact for pricing</span>
          </div>
          <ul class="pricing-features">
            <li>Unlimited classes</li>
            <li>All class types included</li>
            <li>15% café discount</li>
            <li>Guest passes (2/month)</li>
            <li>Priority booking</li>
            <li>Member events access</li>
          </ul>
          <a href="/contact/" class="btn btn--gold" data-magnetic>Join Now</a>
        </article>

        <!-- Class Pack -->
        <article class="pricing-card card">
          <div class="pricing-card__header">
            <h3>10-Class Pack</h3>
            <p class="text-muted">Flexibility with savings</p>
          </div>
          <div class="pricing-card__price">
            <span class="pricing-amount pricing-amount--contact">Contact for pricing</span>
          </div>
          <ul class="pricing-features">
            <li>10 classes to use anytime</li>
            <li>All class types</li>
            <li>10% café discount</li>
            <li>Valid for 3 months</li>
          </ul>
          <a href="/contact/" class="btn btn--secondary">Get Started</a>
        </article>
      </div>
    </div>
  </section>

  <!-- Intro Offer -->
  <section class="section mesh-warm" data-animate="fade-up">
    <div class="container container--narrow text-center">
      <span class="section-tag">New Members</span>
      <h2>New to Refora?</h2>
      <p>Ask about our introductory offers for first-time members. Experience our classes, community, and café — and find the membership that fits your rhythm.</p>
      <a href="/contact/" class="btn btn--primary" data-magnetic style="margin-block-start: var(--space-4);">Inquire About Intro Offers</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" data-animate="fade-up">
    <div class="container container--narrow">
      <span class="section-tag">Common Questions</span>
      <h2>Membership FAQ</h2>

      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-question">
            <span>Can I cancel anytime?</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="faq-content">
            <p>Yes. Monthly memberships can be cancelled with 30 days notice. Class packs are non-refundable but never expire within their validity period.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span>Do I need experience?</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="faq-content">
            <p>Not at all. Every class offers modifications for all levels. Our instructors are trained to welcome complete beginners and challenge experienced practitioners in the same session.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span>What should I bring?</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="faq-content">
            <p>Just yourself and comfortable workout clothes. We provide all equipment including reformers, mats, and props. Grip socks are recommended for reformer classes (available for purchase).</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span>Can I freeze my membership?</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="faq-content">
            <p>Monthly members can freeze their membership for up to 30 days per year. Contact us in advance to arrange a freeze period.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span>Are private sessions included in memberships?</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="faq-content">
            <p>Private sessions are available at a separate rate. Unlimited Monthly members receive a 20% discount on private session packages.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <Footer />
  <script src="../scripts/animations.js"></script>
  <script src="../scripts/experiences.js"></script>
</BaseLayout>

<style>
  .page-hero {
    padding-block: calc(var(--space-16) + var(--space-8)) var(--space-8);
    text-align: center;
  }

  .page-hero .hero-sub {
    font-size: var(--text-h4);
    color: var(--color-text-muted);
    max-width: 55ch;
    margin-inline: auto;
    margin-block-start: var(--space-2);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: start;

    @media (min-width: 768px) {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: relative;
  }

  .pricing-card--featured {
    @media (min-width: 768px) {
      transform: scale(1.05);
      z-index: 2;
    }
  }

  .pricing-card__badge {
    position: absolute;
    top: calc(var(--space-2) * -1);
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-secondary);
    color: var(--color-charcoal);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding: 4px 16px;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .pricing-card__price {
    display: flex;
    align-items: baseline;
    gap: var(--space-1);
  }

  .pricing-amount {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .pricing-amount--contact {
    font-family: var(--font-body);
    font-size: var(--text-h3);
    font-weight: 500;
    color: var(--color-primary);
  }

  .pricing-period {
    font-size: var(--text-small);
    color: var(--color-text-muted);
  }

  .pricing-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex-grow: 1;

    & li {
      font-size: var(--text-small);
      color: var(--color-text-muted);
      padding-inline-start: var(--space-3);
      position: relative;

      &::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.5em;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: 1.5px solid var(--color-secondary);
      }
    }
  }

  .pricing-card .btn {
    margin-block-start: auto;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-block-start: var(--space-6);
    background: var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .faq-item {
    background: var(--color-bg);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3);
    cursor: pointer;
    list-style: none;
    font-weight: 500;
    min-height: 44px;
    transition: background var(--duration-fast) ease;

    &:hover {
      background: var(--color-surface);
    }

    &::marker { display: none; }
    &::-webkit-details-marker { display: none; }
  }

  .faq-icon {
    transition: transform var(--duration-base) var(--ease-out-expo);
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  details[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-content {
    padding: 0 var(--space-3) var(--space-3);
    animation: faqSlide 0.3s var(--ease-out-expo);

    & p {
      color: var(--color-text-muted);
    }
  }

  @keyframes faqSlide {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
