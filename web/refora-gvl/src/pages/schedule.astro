---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Schedule" description="View our weekly Pilates, Reformer, and Yoga class schedule at Refora Greenville. Book your spot today.">
  <Header />

  <section class="page-hero">
    <div class="container">
      <span class="hero-tag text-label">Class Schedule</span>
      <h1 class="hero-title">Find Your Rhythm</h1>
      <p class="hero-sub">Browse our weekly classes and book the sessions that fit your life. All levels welcome.</p>
    </div>
  </section>

  <!-- Weekly Schedule Grid -->
  <section class="section">
    <div class="container">
      <div class="schedule-grid-wrap" data-animate="fade-up">
        <span class="section-tag section-tag--centered">Sample Weekly Schedule</span>
        <h2 class="text-center">Your Week at Refora</h2>
        <p class="text-muted text-center schedule-subtitle">Class times and availability may vary. Download the app for live updates and instant booking.</p>

        <div class="schedule-table-wrap">
          <table class="schedule-table">
            <thead>
              <tr>
                <th></th>
                <th>Mon</th>
                <th>Tue</th>
                <th>Wed</th>
                <th>Thu</th>
                <th>Fri</th>
                <th>Sat</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="schedule-table__time">6:00 AM</td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--yoga">Yoga Flow</span></td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--yoga">Yoga Flow</span></td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--yoga">Yoga Flow</span></td>
              </tr>
              <tr>
                <td class="schedule-table__time">7:30 AM</td>
                <td><span class="schedule-pill schedule-pill--mat">Mat Pilates</span></td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--mat">Mat Pilates</span></td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--mat">Mat Pilates</span></td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
              </tr>
              <tr>
                <td class="schedule-table__time">9:00 AM</td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--mat">Mat Pilates</span></td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--mat">Mat Pilates</span></td>
                <td><span class="schedule-pill schedule-pill--yoga">Yoga Flow</span></td>
                <td><span class="schedule-pill schedule-pill--mat">Mat Pilates</span></td>
              </tr>
              <tr>
                <td class="schedule-table__time">12:00 PM</td>
                <td><span class="schedule-pill schedule-pill--yoga">Yoga Flow</span></td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--yoga">Yoga Flow</span></td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td></td>
              </tr>
              <tr>
                <td class="schedule-table__time">4:00 PM</td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--yoga">Yoga Flow</span></td>
                <td><span class="schedule-pill schedule-pill--reformer">Reformer</span></td>
                <td><span class="schedule-pill schedule-pill--yoga">Yoga Flow</span></td>
                <td><span class="schedule-pill schedule-pill--mat">Mat Pilates</span></td>
                <td></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="schedule-legend">
          <span class="schedule-legend__item"><span class="schedule-pill schedule-pill--reformer">Reformer</span></span>
          <span class="schedule-legend__item"><span class="schedule-pill schedule-pill--mat">Mat Pilates</span></span>
          <span class="schedule-legend__item"><span class="schedule-pill schedule-pill--yoga">Yoga Flow</span></span>
        </div>
      </div>

      <!-- App CTA -->
      <div class="schedule-app-cta" data-animate="fade-up">
        <div class="card schedule-app-card text-center">
          <svg class="schedule-app-icon" width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="var(--color-secondary)" stroke-width="1.5">
            <rect x="8" y="6" width="32" height="36" rx="4"/><path d="M16 2v8"/><path d="M32 2v8"/><path d="M8 18h32"/><rect x="14" y="24" width="6" height="6" rx="1"/><rect x="28" y="24" width="6" height="6" rx="1"/><rect x="14" y="32" width="6" height="6" rx="1"/>
          </svg>
          <h3>Book Your Spot</h3>
          <p class="text-muted schedule-app-text">Download the Refora app for live class schedule, real-time availability, and instant booking.</p>
          <div class="schedule-app-actions">
            <a href="#" class="btn btn--gold" data-magnetic>Download the App</a>
            <a href="/contact/" class="btn btn--secondary">Contact Us</a>
          </div>
        </div>
      </div>

      <!-- Class Types -->
      <div class="schedule-classes" data-animate="stagger">
        <span class="section-tag">What We Offer</span>
        <h3 class="schedule-classes__title">Class Types</h3>
        <div class="schedule-types-grid">
          <div class="card card--gold-accent">
            <h4>Reformer Pilates</h4>
            <p class="text-muted">Full-body conditioning on spring-loaded reformer machines. All levels welcome.</p>
          </div>
          <div class="card card--gold-accent">
            <h4>Mat Pilates</h4>
            <p class="text-muted">Core-focused bodyweight training using classical Pilates principles.</p>
          </div>
          <div class="card card--gold-accent">
            <h4>Yoga Flow</h4>
            <p class="text-muted">Dynamic vinyasa sequences linking breath with movement.</p>
          </div>
          <div class="card card--gold-accent">
            <h4>Private Sessions</h4>
            <p class="text-muted">One-on-one instruction tailored to your individual goals.</p>
          </div>
        </div>
      </div>

      <div class="schedule-hours text-center" data-animate="fade-up">
        <p class="text-muted schedule-hours__text">
          Studio Hours: Monday–Friday 5AM–5PM · Saturday–Sunday 10AM–2PM
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section mesh-dark grain text-center" data-animate="scale-in">
    <div class="container">
      <h2>Ready to Book?</h2>
      <p class="schedule-cta__desc">Download the Refora app or contact us to reserve your spot.</p>
      <div class="schedule-cta__actions">
        <a href="/membership/" class="btn btn--gold" data-magnetic>Join the Movement</a>
        <a href="/contact/" class="btn btn--secondary schedule-cta__secondary">Contact Us</a>
      </div>
    </div>
  </section>

  <Footer />
  <script src="../scripts/animations.js"></script>
  <script src="../scripts/experiences.js"></script>
</BaseLayout>

<style>
  .page-hero {
    padding-block: calc(var(--space-16) + var(--space-8)) var(--space-8);
    text-align: center;
  }

  .page-hero .hero-sub {
    font-size: var(--text-h4);
    color: var(--color-text-muted);
    max-width: 55ch;
    margin-inline: auto;
    margin-block-start: var(--space-2);
  }

  .schedule-subtitle {
    max-width: 50ch;
    margin-inline: auto;
    margin-block: var(--space-2) var(--space-6);
    font-size: var(--text-small);
  }

  /* Schedule Table */
  .schedule-table-wrap {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    background: var(--color-surface);
  }

  .schedule-table {
    width: 100%;
    min-width: 600px;
    border-collapse: collapse;
    font-size: var(--text-small);
  }

  .schedule-table thead {
    background: var(--color-charcoal);
  }

  .schedule-table th {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-light);
    padding: var(--space-2) var(--space-2);
    text-align: center;
  }

  .schedule-table td {
    padding: var(--space-2);
    text-align: center;
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
    min-width: 80px;
  }

  .schedule-table tbody tr:last-child td {
    border-bottom: none;
  }

  .schedule-table__time {
    font-weight: 600;
    color: var(--color-charcoal);
    white-space: nowrap;
    text-align: left !important;
    padding-inline-start: var(--space-3) !important;
  }

  .schedule-pill {
    display: inline-block;
    padding: 3px 10px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
    white-space: nowrap;
  }

  .schedule-pill--reformer {
    background: rgba(196, 169, 125, 0.2);
    color: var(--color-secondary-dark);
  }

  .schedule-pill--mat {
    background: rgba(139, 125, 107, 0.15);
    color: var(--color-primary-dark);
  }

  .schedule-pill--yoga {
    background: rgba(45, 106, 79, 0.12);
    color: #2d6a4f;
  }

  .schedule-legend {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    margin-block-start: var(--space-3);
    flex-wrap: wrap;
  }

  /* App CTA */
  .schedule-app-card {
    padding: var(--space-8);
  }

  .schedule-app-icon {
    margin-inline: auto;
    margin-block-end: var(--space-3);
  }

  .schedule-app-text {
    max-width: 45ch;
    margin-inline: auto;
  }

  .schedule-app-actions {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    flex-wrap: wrap;
    margin-block-start: var(--space-4);
  }

  .schedule-app-cta {
    margin-block-start: var(--space-8);
  }

  /* Class Types */
  .schedule-classes {
    margin-block-start: var(--space-8);
  }

  .schedule-classes__title {
    margin-block-end: var(--space-4);
  }

  .schedule-types-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);

    @media (min-width: 640px) {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .schedule-hours {
    margin-block-start: var(--space-6);
  }

  .schedule-hours__text {
    font-size: var(--text-small);
  }

  /* CTA */
  .schedule-cta__desc {
    color: var(--color-text-light-muted);
    max-width: 50ch;
    margin-inline: auto;
    margin-block-end: var(--space-4);
  }

  .schedule-cta__actions {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    flex-wrap: wrap;
  }

  .schedule-cta__secondary {
    color: var(--color-text-light);
    border-color: rgba(245, 240, 235, 0.3);
  }
</style>
