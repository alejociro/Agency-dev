---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact" description="Get in touch with Refora Greenville. Visit our Pilates, Yoga & Coffee studio or reach out online.">
  <Header />

  <section class="page-hero">
    <div class="container">
      <span class="hero-tag text-label">Contact</span>
      <h1 class="hero-title">We Would Love<br />to Hear From You</h1>
      <p class="hero-sub">Questions about classes, membership, or the café? We are here to help.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Info Column -->
        <div class="contact-info" data-animate="fade-right">
          <div class="contact-info__block">
            <h3>Visit Us</h3>
            <p>Greenville, SC</p>
            <span data-open-status class="contact-status-badge"></span>
          </div>

          <div class="contact-info__block">
            <h3>Email</h3>
            <a href="mailto:reform@reforagvl.com">reform@reforagvl.com</a>
          </div>

          <div class="contact-info__block">
            <h3>Hours</h3>
            <p>Monday – Friday: 5AM – 5PM</p>
            <p>Saturday – Sunday: 10AM – 2PM</p>
          </div>

          <div class="contact-info__block">
            <h3>Follow Us</h3>
            <div class="contact-social">
              <a href="https://www.instagram.com/reforagvl/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
              </a>
              <a href="https://www.facebook.com/profile.php?id=61575630089186" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Form Column -->
        <div class="contact-form-wrap" data-animate="fade-left" data-delay="200">
          <form class="contact-form card" id="contact-form">
            <h3>Send Us a Message</h3>

            <div class="field">
              <input type="text" id="name" name="name" placeholder=" " required class="input" autocomplete="name" />
              <label for="name">Full Name</label>
            </div>

            <div class="field">
              <input type="email" id="email" name="email" placeholder=" " required class="input" autocomplete="email" />
              <label for="email">Email Address</label>
            </div>

            <div class="field">
              <input type="tel" id="phone" name="phone" placeholder=" " class="input" autocomplete="tel" />
              <label for="phone">Phone (optional)</label>
            </div>

            <div class="field">
              <select id="interest" name="interest" class="input" required>
                <option value="" disabled selected>What are you interested in?</option>
                <option value="reformer">Reformer Pilates</option>
                <option value="mat">Mat Pilates</option>
                <option value="yoga">Yoga</option>
                <option value="private">Private Sessions</option>
                <option value="membership">Membership Info</option>
                <option value="cafe">Café / Events</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="field">
              <textarea id="message" name="message" placeholder=" " rows="4" class="input"></textarea>
              <label for="message">Your Message</label>
            </div>

            <button type="submit" class="btn btn--primary" data-magnetic>Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="section contact-map-section" data-animate="fade-up">
    <div class="container">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d104687.08225682442!2d-82.45!3d34.85!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88578f526aa0d3d3%3A0x907f05eb0b4cd3c!2sGreenville%2C%20SC!5e0!3m2!1sen!2sus!4v1"
        width="1200"
        height="400"
        class="contact-map-iframe"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Refora location in Greenville, SC"
      ></iframe>
    </div>
  </section>

  <!-- Confirmation Dialog -->
  <dialog id="form-dialog" class="form-dialog">
    <div class="form-dialog__content">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="var(--color-secondary)" stroke-width="2"><circle cx="24" cy="24" r="20"/><path d="M16 24l6 6 12-12"/></svg>
      <h3>Message Sent</h3>
      <p>Thank you for reaching out. We will get back to you within 24 hours.</p>
      <button class="btn btn--primary" onclick="document.getElementById('form-dialog').close()">Close</button>
    </div>
  </dialog>

  <Footer />
  <script src="../scripts/animations.js"></script>
  <script src="../scripts/experiences.js"></script>

  <script>
    const form = document.getElementById('contact-form');
    const dialog = document.getElementById('form-dialog');

    if (form && dialog) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        dialog.showModal();
        form.reset();
      });
    }
  </script>
</BaseLayout>

<style>
  .page-hero {
    padding-block: calc(var(--space-16) + var(--space-8)) var(--space-8);
    text-align: center;
  }

  .page-hero .hero-sub {
    font-size: var(--text-h4);
    color: var(--color-text-muted);
    max-width: 55ch;
    margin-inline: auto;
    margin-block-start: var(--space-2);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);

    @media (min-width: 768px) {
      grid-template-columns: 1fr 1.5fr;
      align-items: start;
    }
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact-info__block h3 {
    font-size: var(--text-h4);
    margin-block-end: var(--space-1);
  }

  .contact-info__block p,
  .contact-info__block a {
    font-size: var(--text-body);
    color: var(--color-text-muted);
  }

  .contact-info__block a:hover {
    color: var(--color-primary);
  }

  .contact-social {
    display: flex;
    gap: var(--space-2);
    margin-block-start: var(--space-1);

    & a {
      color: var(--color-text-muted);
      transition: color var(--duration-fast) ease;

      &:hover {
        color: var(--color-secondary);
      }
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact-form h3 {
    margin-block-end: var(--space-1);
  }

  /* Floating labels */
  .field {
    position: relative;
  }

  .field label {
    position: absolute;
    left: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    font-size: var(--text-body);
    color: var(--color-text-muted);
    pointer-events: none;
    transition: all 200ms ease;
  }

  .field textarea + label {
    top: var(--space-2);
    transform: none;
  }

  .field input:focus + label,
  .field input:not(:placeholder-shown) + label,
  .field textarea:focus + label,
  .field textarea:not(:placeholder-shown) + label {
    top: 6px;
    transform: none;
    font-size: var(--text-xs);
    color: var(--color-secondary);
  }

  .field select {
    color: var(--color-text-muted);
  }

  .field select:valid {
    color: var(--color-text);
  }

  /* Dialog */
  .form-dialog {
    border: none;
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    max-width: 400px;
    text-align: center;
    box-shadow: var(--shadow-xl);
  }

  .form-dialog::backdrop {
    background: rgba(50, 55, 60, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .form-dialog__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .form-dialog__content p {
    color: var(--color-text-muted);
    margin-inline: auto;
  }

  .contact-status-badge {
    margin-block-start: var(--space-1);
  }

  .contact-map-section {
    padding-block-start: 0;
  }

  .contact-map-iframe {
    border: 0;
    border-radius: var(--radius-lg);
    width: 100%;
    min-height: 350px;
  }
</style>
