---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header nav-entrance">
  <div class="header-inner container">
    <a href="/" class="logo-link site-logo" aria-label="Roper Mountain Auto Care - Home">
      <img
        src="https://lirp.cdn-website.com/84f2f64c/dms3rep/multi/opt/mainlogoRMPC-1920w.png"
        alt="Roper Mountain Auto Care logo"
        width="180"
        height="60"
        loading="eager"
        decoding="async"
        class="logo-img"
      />
    </a>

    <nav class="main-nav" aria-label="Main navigation">
      <ul class="nav-list" data-nav-menu role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <span class="status-indicator" data-open-status aria-live="polite"></span>
      <a href="tel:+18642887633" class="btn btn-primary header-cta" data-magnetic>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        <span class="header-cta-text">(864) 288-7633</span>
      </a>
    </div>

    <button
      class="nav-toggle"
      data-nav-toggle
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Toggle navigation menu"
    >
      <span class="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(248, 246, 244, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-block-end: 1px solid var(--color-border-light);
    padding-block: var(--space-2);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .logo-link {
    flex-shrink: 0;
  }

  .logo-img {
    width: clamp(130px, 15vw, 180px);
    height: auto;
  }

  .nav-list {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-small);
    letter-spacing: var(--tracking-wide);
    color: var(--color-secondary);
    text-transform: uppercase;
    padding: var(--space-1) 0;
  }

  .nav-link.active {
    color: var(--color-primary-dark);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .header-cta {
    padding: 0.6rem 1.2rem;
    font-size: var(--text-xs);
    gap: 0.4em;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-1);
    z-index: 110;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 24px;

    & span {
      display: block;
      width: 100%;
      height: 2px;
      background: var(--color-secondary);
      border-radius: 2px;
      transition: all 0.3s var(--ease-smooth);
      transform-origin: center;
    }
  }

  /* Mobile nav */
  @media (max-width: 768px) {
    .main-nav {
      position: fixed;
      inset: 0;
      background: rgba(248, 246, 244, 0.98);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
      z-index: 100;
    }

    .nav-list {
      flex-direction: column;
      align-items: center;
      gap: var(--space-6);
    }

    .nav-link {
      font-size: var(--text-h3);
    }

    .nav-toggle {
      display: block;
    }

    .header-cta-text {
      display: none;
    }

    .header-cta {
      padding: 0.5rem;
      border-radius: 50%;
    }

    .status-indicator {
      display: none;
    }

    /* Open state */
    .main-nav:global(.nav-open) {
      opacity: 1;
      visibility: visible;
    }

    :global(.nav-open) ~ .nav-toggle .hamburger span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }

    :global(.nav-open) ~ .nav-toggle .hamburger span:nth-child(2) {
      opacity: 0;
    }

    :global(.nav-open) ~ .nav-toggle .hamburger span:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
    }
  }
</style>
