  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {currentYear} Roper Mountain Auto Care. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-block-start: var(--section-padding);
  }

  .footer-wave {
    position: relative;
    margin-block-end: -2px;
  }

  .footer-wave svg {
    display: block;
    width: 100%;
    height: clamp(60px, 8vw, 120px);
  }

  .footer-main {
    background: var(--color-secondary);
    color: #e8e0dc;
    padding-block: var(--space-8) var(--space-6);
  }

  .footer-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;

    @media (min-width: 640px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media (min-width: 1024px) {
      grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    }
  }

  .footer-logo {
    width: 140px;
    height: auto;
    filter: brightness(1.2);
    margin-block-end: var(--space-2);
  }

  .footer-tagline {
    font-size: var(--text-small);
    color: #b8aca6;
    line-height: var(--leading-normal);
    margin-block-end: var(--space-3);
    max-width: 30ch;
  }

  .footer-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .footer-badges .badge {
    font-size: 0.65rem;
    padding: 0.3em 0.7em;
    opacity: 0.8;
  }

  .footer-heading {
    font-family: var(--font-display);
    font-size: var(--text-small);
    font-weight: 700;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-block-end: var(--space-3);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-links a {
    color: #c4b8b2;
    font-size: var(--text-small);
    transition: color var(--duration-fast) var(--ease-smooth);

    &:hover {
      color: var(--color-primary-light);
    }
  }

  .footer-contact {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-1);
    color: #c4b8b2;
    font-size: var(--text-small);
    line-height: var(--leading-normal);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-smooth);

    & svg {
      flex-shrink: 0;
      margin-block-start: 2px;
      color: var(--color-primary);
    }

    &:hover {
      color: var(--color-primary-light);
    }
  }

  .footer-social {
    display: flex;
    gap: var(--space-2);
    margin-block-start: var(--space-4);
  }

  .footer-social a {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: #c4b8b2;
    border: 1px solid rgba(196, 184, 178, 0.25);
    transition: all var(--duration-fast) var(--ease-smooth);

    &:hover {
      color: var(--color-primary);
      border-color: var(--color-primary);
      background: rgba(104, 204, 209, 0.08);
    }
  }

  .footer-bottom {
    background: #3a2f2f;
    padding-block: var(--space-2);
    text-align: center;

    & p {
      font-size: var(--text-xs);
      color: #8a7d78;
      margin: 0;
      max-width: none;
    }
  }
</style>
