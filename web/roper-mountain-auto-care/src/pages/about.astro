---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About Us | Roper Mountain Auto Care | Greenville SC"
  description="Locally owned ASE-certified auto repair in Greenville SC. Learn about our team, values, and commitment to honest, quality vehicle service."
>
  <Header />

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container">
      <span class="hero-tag section-tag">Our Story</span>
      <h1 class="hero-title page-title">Locally Owned.<br/>Community Driven.</h1>
      <p class="hero-sub">More than a repair shop — we are your neighbors who happen to be really good with cars.</p>
    </div>
  </section>

  <!-- STORY -->
  <section class="about-story section" id="story">
    <div class="container">
      <div class="grid-asymmetric">
        <div class="story-content" data-animate="fade-right">
          <span class="section-tag">Who We Are</span>
          <h2>Your Trusted Greenville Auto Repair Experts</h2>
          <p>At Roper Mountain Auto Care, we are proud to be a leading auto repair shop in Greenville, SC, committed to providing top-quality vehicle service with honesty and integrity. Whether you need routine auto maintenance or complex car repairs, our ASE-certified technicians have the expertise and state-of-the-art equipment to keep your vehicle running safely and reliably.</p>
          <p>From oil changes and brake service to advanced diagnostics and fleet maintenance, we offer comprehensive solutions tailored to your needs. We work on all makes and models, from domestic favorites to European and Asian imports.</p>
          <p>We understand how important your vehicle is to your daily life. That is why we strive to make every visit convenient and comfortable. With every automotive service, we perform a complimentary courtesy inspection — because regular maintenance is the key to extending the life of your vehicle and protecting your investment.</p>
        </div>
        <div class="story-images" data-animate="fade-left">
          <img
            src="https://lirp.cdn-website.com/84f2f64c/dms3rep/multi/opt/Welcome_Image_2_Roper_Mountain-1920w.png"
            alt="Inside the Roper Mountain Auto Care shop with technicians at work"
            width="600"
            height="450"
            loading="lazy"
            decoding="async"
            class="story-img"
          />
          <div class="story-img-accent" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="values-section" id="values">
    <div class="container">
      <span class="section-tag" data-animate="fade-up">Our Values</span>
      <h2 data-animate="fade-up">What Sets Us Apart</h2>

      <div class="values-grid" data-animate="stagger">
        <div class="value-card card">
          <div class="value-icon icon-blueprint">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <h3>ASE Certified</h3>
          <p>Our technicians hold ASE certifications, the gold standard in automotive repair. You can trust that your vehicle is in qualified hands.</p>
        </div>

        <div class="value-card card">
          <div class="value-icon icon-blueprint">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Military Friendly</h3>
          <p>We are proud to support our service members and their families. Military personnel receive special consideration at our shop.</p>
        </div>

        <div class="value-card card">
          <div class="value-icon icon-blueprint">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3>Transparent Pricing</h3>
          <p>No hidden fees, no surprise charges. We provide detailed estimates before any work begins and explain findings in plain language.</p>
        </div>

        <div class="value-card card">
          <div class="value-icon icon-blueprint">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </div>
          <h3>Free Courtesy Inspection</h3>
          <p>Every service visit includes a complimentary multi-point inspection. We catch small issues before they become expensive problems.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OUR PROMISE -->
  <section class="about-promise section">
    <div class="container">
      <h2 class="promise-title" data-animate="fade-up">Trusted Automotive Service — Locally Owned, Military Friendly</h2>
      <div class="promise-grid" data-animate="stagger">
        <div class="promise-item">
          <div class="icon-blueprint">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <h3>ASE Certified Technicians</h3>
          <p>Industry gold-standard certification ensuring expert repairs</p>
        </div>
        <div class="promise-item">
          <div class="icon-blueprint">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </div>
          <h3>Free Courtesy Inspection</h3>
          <p>Complimentary multi-point check with every service visit</p>
        </div>
        <div class="promise-item">
          <div class="icon-blueprint">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          </div>
          <h3>All Makes & Models</h3>
          <p>Domestic, European, and Asian imports all welcome</p>
        </div>
        <div class="promise-item">
          <div class="icon-blueprint">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Military Friendly</h3>
          <p>Proudly supporting service members and their families</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="cta-banner-inner">
      <div class="container">
        <h2 class="cta-banner-title">Experience the Difference</h2>
        <p class="cta-banner-text">Bring your vehicle to the team Greenville trusts. We would love to earn your business.</p>
        <a href="tel:+18642887633" class="btn btn-cta-banner" data-magnetic>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call (864) 288-7633
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding-block: calc(80px + var(--space-10)) var(--space-8);
    background: var(--color-secondary);
    color: #faf8f6;
    position: relative;
    overflow: hidden;

    &::after {
      content: '';
      position: absolute;
      bottom: -30%;
      left: -10%;
      width: 50%;
      height: 160%;
      background: radial-gradient(ellipse, rgba(104, 204, 209, 0.08), transparent 70%);
      pointer-events: none;
    }
  }

  .page-hero .hero-tag {
    color: var(--color-primary-light);
    &::before { background: var(--color-primary); }
  }

  .page-hero .hero-title {
    color: #faf8f6;
    font-size: var(--text-h1);
    margin-block-end: var(--space-2);
  }

  .page-hero .hero-sub {
    color: #c4b8b2;
    max-width: 55ch;
  }

  .story-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);

    & h2 { margin-block-end: var(--space-3); }
  }

  .story-images {
    position: relative;
  }

  .story-img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .story-img-accent {
    position: absolute;
    inset: var(--space-3);
    border: 2px dashed var(--color-primary);
    border-radius: var(--radius-lg);
    z-index: -1;
    transform: translate(12px, 12px);
    opacity: 0.3;
  }

  .values-section {
    background: var(--color-bg-alt);
    padding-block: var(--section-padding);
  }

  .values-grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
    margin-block-start: var(--space-6);

    @media (min-width: 640px) {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .value-card {
    padding: var(--space-4);

    & .value-icon {
      margin-block-end: var(--space-2);
    }

    & h3 {
      font-size: var(--text-h4);
      margin-block-end: var(--space-1);
    }

    & p {
      font-size: var(--text-small);
      color: var(--color-text-muted);
      margin: 0;
      max-width: none;
    }
  }

  .about-promise {
    background: var(--color-surface);
  }

  .promise-title {
    text-align: center;
    margin-block-end: var(--space-6);
    max-width: 40ch;
    margin-inline: auto;
  }

  .promise-grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(2, 1fr);

    @media (min-width: 768px) {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .promise-item {
    text-align: center;

    & .icon-blueprint {
      margin-inline: auto;
      margin-block-end: var(--space-2);
    }

    & h3 {
      font-size: var(--text-small);
      font-weight: 700;
      margin-block-end: 0.25rem;
    }

    & p {
      font-size: var(--text-xs);
      color: var(--color-text-muted);
      margin: 0;
      max-width: none;
    }
  }

  .cta-banner {
    background: var(--color-primary);
  }

  .cta-banner-inner {
    padding-block: var(--space-8);
    text-align: center;
  }

  .cta-banner-title {
    color: var(--color-secondary);
    font-size: var(--text-h1);
    margin-block-end: var(--space-2);
  }

  .cta-banner-text {
    color: var(--color-secondary);
    opacity: 0.8;
    max-width: 50ch;
    margin-inline: auto;
    margin-block-end: var(--space-4);
  }

  .btn-cta-banner {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-body);
    padding: var(--space-2) var(--space-5);
    background: var(--color-secondary);
    color: #faf8f6;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-smooth);

    &:hover {
      background: var(--color-secondary-light);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(70, 57, 57, 0.3);
      color: #fff;
    }
  }
</style>
