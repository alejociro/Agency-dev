---
import '../styles/design-system.css';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title,
  description = "Roper Mountain Auto Care — ASE-Certified Auto Repair in Greenville, SC. Free courtesy inspection with every service. Call (864) 288-7633.",
  canonicalUrl,
  ogImage = "https://lirp.cdn-website.com/84f2f64c/dms3rep/multi/opt/Hero_Image_Roper_Mountain-1920w.png"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO Primary -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="auto repair greenville sc, car mechanic greenville, ase certified mechanic, oil change greenville, brake repair greenville sc, engine diagnostics, transmission service, roper mountain auto care" />
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Roper Mountain Auto Care" />
  {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}

  <!-- Twitter/X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="https://irp.cdn-website.com/84f2f64c/site_favicon_16_1761659898305.ico" />

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://lirp.cdn-website.com" />

  <!-- Preload hero image -->
  <link rel="preload" href="https://lirp.cdn-website.com/84f2f64c/dms3rep/multi/opt/Hero_Image_Roper_Mountain-1920w.png" as="image" fetchpriority="high" />

  <!-- Schema JSON-LD: AutoRepair -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AutoRepair",
    "name": "Roper Mountain Auto Care",
    "description": "ASE-Certified auto repair shop in Greenville, SC providing oil changes, brake repair, engine diagnostics, transmission service, A/C repair, and fleet maintenance. Free courtesy inspection with every service.",
    "url": "https://www.ropermountainautocare.com/",
    "telephone": "+18642887633",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1520 Roper Mountain Road",
      "addressLocality": "Greenville",
      "addressRegion": "SC",
      "postalCode": "29615",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 34.82,
      "longitude": -82.35
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "08:00",
        "closes": "17:30"
      }
    ],
    "sameAs": [
      "https://facebook.com/RoperMountainAutoCare/",
      "https://yelp.com/biz/roper-mountain-auto-care-greenville"
    ],
    "image": "https://lirp.cdn-website.com/84f2f64c/dms3rep/multi/opt/Hero_Image_Roper_Mountain-1920w.png",
    "logo": "https://lirp.cdn-website.com/84f2f64c/dms3rep/multi/opt/mainlogoRMPC-1920w.png",
    "priceRange": "$$",
    "areaServed": {
      "@type": "City",
      "name": "Greenville",
      "containedInPlace": {
        "@type": "State",
        "name": "South Carolina"
      }
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Auto Repair Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Oil Change" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Brake Repair" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Engine Diagnostics" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Transmission Service" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Air Conditioning Service" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fleet Maintenance" } }
      ]
    }
  })} />

  <!-- Speculation Rules: prefetch/prerender likely navigation -->
  <script type="speculationrules">
  {
    "prerender": [
      { "where": { "href_matches": "/services" } },
      { "where": { "href_matches": "/contact" } }
    ],
    "prefetch": [
      { "where": { "href_matches": "/about" } }
    ]
  }
  </script>

  <!-- Performance: content-visibility for below-fold sections -->
  <style>
    .section:not(.hero) {
      content-visibility: auto;
      contain-intrinsic-size: auto 500px;
    }

    .hero-bg-img {
      will-change: transform;
    }
  </style>
</head>
<body class="grain">
  <div class="reading-progress" aria-hidden="true"></div>
  <slot />
  <script src="../scripts/animations.js"></script>
  <script src="../scripts/experience.js"></script>
  <nav class="section-dots" aria-label="Section navigation"></nav>
</body>
</html>
