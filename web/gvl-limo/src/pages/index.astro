---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Greenville Limo Service | 24/7 Executive Transportation | GVL Limo">

  <!-- ========== HERO ========== -->
  <section class="hero">
    <div class="hero-bg hero-parallax" aria-hidden="true">
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-letterbox-bars top" aria-hidden="true"></div>
    <div class="hero-letterbox-bars bottom" aria-hidden="true"></div>
    <div class="container hero-content">
      <span class="kicker hero-kicker">Greenville's Premier Executive Fleet</span>
      <h1 class="hero-title">
        Your destination<br/>
        deserves a <em class="text-gold">grand entrance</em>
      </h1>
      <p class="hero-subtitle">
        24/7 sedan, SUV, limousine &amp; party bus transportation across the Upstate.
        USDOT certified. SLED-licensed armed security available.
      </p>
      <div class="hero-cta">
        <a href="/contact" class="btn btn-primary">Book Your Ride</a>
        <a href="/services" class="btn btn-ghost">Explore the Fleet &rarr;</a>
      </div>
      <div class="hero-proof">
        <div class="proof-items">
          <span class="proof-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1l2.1 4.3 4.7.7-3.4 3.3.8 4.7L8 11.8 3.8 14l.8-4.7L1.2 6l4.7-.7L8 1z" fill="#C9A84C"/></svg>
            4.9 Stars
          </span>
          <span class="proof-divider" aria-hidden="true">|</span>
          <span class="proof-item">USDOT #3650584</span>
          <span class="proof-divider" aria-hidden="true">|</span>
          <span class="proof-item">Available 24/7</span>
        </div>
      </div>
    </div>
    <div class="scroll-indicator" aria-hidden="true">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ========== STATS BAR ========== -->
  <div class="gold-seam gold-seam-animated"></div>
  <section class="section stats-section">
    <div class="container">
      <div class="stats-bar" data-animate="stagger">
        <div class="stat">
          <span class="stat-value" data-counter="7" data-suffix="+">0</span>
          <span class="stat-label">Premium Vehicles</span>
        </div>
        <div class="stat">
          <span class="stat-value" data-counter="5">0</span>
          <span class="stat-label">States Licensed</span>
        </div>
        <div class="stat">
          <span class="stat-value" data-counter="24" data-suffix="/7">0</span>
          <span class="stat-label">Always Available</span>
        </div>
        <div class="stat">
          <span class="stat-value" data-counter="18" data-suffix="+">0</span>
          <span class="stat-label">Team Members</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <div class="gold-seam"></div>
  <section class="section services-section" id="services">
    <div class="container">
      <span class="kicker" data-animate="fade-up">What We Do</span>
      <h2 class="section-title" data-animate="fade-up" data-delay="100">
        Transportation for<br/>
        <em class="text-gold">every occasion</em>
      </h2>

      <div class="services-grid" data-animate="stagger">
        <div class="card-accent service-card">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <path d="M8 28h24M10 20h20l2-6H8l2 6zM12 28v3M28 28v3M14 16l2-8h8l2 8" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Airport Transfers</h3>
          <p class="text-muted">GSP, CLT, ATL — door-to-door. Flight tracking included, no extra charge for commercial delays.</p>
        </div>

        <div class="card-accent service-card featured">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <path d="M20 6l4 8h8l-6.5 5 2.5 8L20 22l-8 5 2.5-8L8 14h8l4-8z" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Executive Transport</h3>
          <p class="text-muted">Maserati, Escalade, Sprinter — for the ride that speaks before you do. Corporate accounts welcome.</p>
        </div>

        <div class="card-accent service-card">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <circle cx="20" cy="16" r="6" stroke="#C9A84C" stroke-width="1.5"/>
              <path d="M10 34c0-5.5 4.5-10 10-10s10 4.5 10 10" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M28 12l4-4M28 8l4 4" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Weddings &amp; Events</h3>
          <p class="text-muted">Stretch limos, party buses up to 45 guests. Karaoke, Xbox, nightclub lighting — your party starts at pickup.</p>
        </div>

        <div class="card-accent service-card">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <path d="M20 8v24M12 16l8-8 8 8" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <rect x="10" y="28" width="20" height="4" rx="1" stroke="#C9A84C" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>GVL SAFE</h3>
          <p class="text-muted">SLED-licensed armed security transport. Ex-law enforcement details. The only service of its kind in South Carolina.</p>
        </div>

        <div class="card-accent service-card">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <path d="M6 20c0-7.7 6.3-14 14-14s14 6.3 14 14-6.3 14-14 14S6 27.7 6 20z" stroke="#C9A84C" stroke-width="1.5"/>
              <path d="M20 12v8l5.5 3.5" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Hourly Charter</h3>
          <p class="text-muted">Brewery crawls, wine tours, golf outings, city explorations. Your driver, your schedule, your pace.</p>
        </div>

        <div class="card-accent service-card">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <path d="M8 14h24v16H8z" stroke="#C9A84C" stroke-width="1.5" stroke-linejoin="round"/>
              <path d="M14 14V10a6 6 0 0112 0v4" stroke="#C9A84C" stroke-width="1.5"/>
              <circle cx="20" cy="22" r="3" stroke="#C9A84C" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>Cross-Country</h3>
          <p class="text-muted">Licensed in SC, NC, GA, TN and beyond. Long-distance comfort without the airport hassle.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FLEET PREVIEW ========== -->
  <div class="gold-seam"></div>
  <section class="section fleet-section">
    <div class="container">
      <div class="grid-asymmetric">
        <div data-animate="fade-right">
          <span class="kicker">The Fleet</span>
          <h2>
            Not just a ride.<br/>
            <em class="text-gold">An experience.</em>
          </h2>
          <p class="text-muted" style="max-width:44ch; margin-top:var(--space-3);">
            From the Maserati Ghibli S with its twin-turbo Ferrari engine to our 45-passenger party bus
            with DJ booth and nightclub lighting — every vehicle in our fleet is maintained to the highest standard.
          </p>
          <div style="margin-top:var(--space-4); display:flex; gap:var(--space-3); flex-wrap:wrap;">
            <a href="/services" class="btn btn-primary">View Full Fleet</a>
            <a href="/contact" class="btn btn-outline">Get a Quote</a>
          </div>
        </div>
        <div class="fleet-preview-stack" data-animate="fade-left">
          <div class="fleet-card-stack">
            <div class="fleet-stack-item">
              <div class="card-vehicle">
                <div class="card-vehicle-img img-reveal">
                  <img src="https://img1.wsimg.com/isteam/ip/7cfeebe0-8cbc-4d8b-810f-8f41f13db67a/b%20Maserati%20Ghibli%20S%20-%20Horizontal.jpg" alt="Maserati Ghibli S — VIP executive sedan" width="600" height="375" loading="lazy" decoding="async" />
                </div>
                <div class="card-vehicle-body">
                  <h3 class="card-vehicle-name">Maserati Ghibli S</h3>
                  <div class="card-vehicle-meta">
                    <span class="card-vehicle-capacity">Up to 4</span>
                    <span>VIP Sedan</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="fleet-stack-item">
              <div class="card-vehicle">
                <div class="card-vehicle-img img-reveal">
                  <img src="https://img1.wsimg.com/isteam/ip/7cfeebe0-8cbc-4d8b-810f-8f41f13db67a/IMG_2704.jpg" alt="Cadillac Escalade ESV — luxury SUV" width="600" height="375" loading="lazy" decoding="async" />
                </div>
                <div class="card-vehicle-body">
                  <h3 class="card-vehicle-name">Cadillac Escalade ESV</h3>
                  <div class="card-vehicle-meta">
                    <span class="card-vehicle-capacity">Up to 6</span>
                    <span>Luxury SUV</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY GVL LIMO — DIFFERENTIATORS ========== -->
  <div class="gold-seam"></div>
  <section class="section why-section ambient-glow">
    <div class="container">
      <div class="why-header" data-animate="fade-up">
        <span class="kicker">Why GVL Limo</span>
        <h2>
          This isn't a rideshare.<br/>
          <em class="text-gold">This is a standard.</em>
        </h2>
      </div>

      <div class="why-grid" data-animate="stagger">
        <div class="why-item">
          <div class="why-number text-gold">01</div>
          <div class="gold-seam-short" aria-hidden="true"></div>
          <h3>SLED-Licensed Security</h3>
          <p class="text-muted">
            The only company in South Carolina licensed by the State Law Enforcement Division
            for armed executive transportation. Ex-police officers. Secret Service-trained protocols.
          </p>
        </div>
        <div class="why-item">
          <div class="why-number text-gold">02</div>
          <div class="gold-seam-short" aria-hidden="true"></div>
          <h3>Real-Time Communication</h3>
          <p class="text-muted">
            Driver photo, cell number and vehicle info before pickup. Live text alerts
            when your driver is en route and when they arrive. Radio-equipped fleet for instant dispatch.
          </p>
        </div>
        <div class="why-item">
          <div class="why-number text-gold">03</div>
          <div class="gold-seam-short" aria-hidden="true"></div>
          <h3>Safety-First Fleet</h3>
          <p class="text-muted">
            Every vehicle: GPS tracking, speed monitoring, video recording, North American Rescue
            emergency kits. Every driver: background checked, drug tested, DOT physical certified.
          </p>
        </div>
        <div class="why-item">
          <div class="why-number text-gold">04</div>
          <div class="gold-seam-short" aria-hidden="true"></div>
          <h3>Multi-State Licensed</h3>
          <p class="text-muted">
            Fully licensed across SC, NC, GA, TN and anywhere in the U.S.
            USDOT #3650584. MC #1271873. No borders, no limits.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== HOW IT WORKS ========== -->
  <div class="gold-seam"></div>
  <section class="section process-section">
    <div class="container">
      <div class="process-header" data-animate="fade-up">
        <span class="kicker">How It Works</span>
        <h2>Stress-free in <em class="text-gold">4 steps</em></h2>
      </div>

      <div class="process-timeline" data-animate="stagger">
        <div class="process-step">
          <div class="step-number">1</div>
          <div class="step-connector" aria-hidden="true"></div>
          <h3>Book Online or Call</h3>
          <p class="text-muted">Reserve through our site, app, or call (864) 920-3342. Instant confirmation + receipt for your 25% deposit.</p>
        </div>
        <div class="process-step">
          <div class="step-number">2</div>
          <div class="step-connector" aria-hidden="true"></div>
          <h3>Meet Your Driver</h3>
          <p class="text-muted">Receive your driver's photo, cell number, vehicle info and license plate by email before pickup.</p>
        </div>
        <div class="process-step">
          <div class="step-number">3</div>
          <div class="step-connector" aria-hidden="true"></div>
          <h3>Live Updates</h3>
          <p class="text-muted">Text alerts when your driver is en route and upon arrival. Real-time tracking for your peace of mind.</p>
        </div>
        <div class="process-step">
          <div class="step-number">4</div>
          <h3>Enjoy the Ride</h3>
          <p class="text-muted">Sit back in a premium vehicle with a professional, background-checked chauffeur. You've arrived.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS ========== -->
  <div class="gold-seam"></div>
  <section class="section testimonials-section">
    <div class="container">
      <span class="kicker" data-animate="fade-up">What Riders Say</span>
      <h2 data-animate="fade-up" data-delay="100">Words carry more weight<br/>than <em class="text-gold">horsepower</em></h2>
    </div>
    <div class="testimonials-track" data-animate="fade-up" data-delay="200">
      <div class="testimonial">
        <p class="testimonial-text">
          "Booked the Escalade for our anniversary and the experience was flawless. Driver arrived early,
          vehicle was immaculate, and the communication throughout was exceptional. This is how transportation should work."
        </p>
        <span class="testimonial-author">Michael R. — Greenville, SC</span>
      </div>
      <div class="testimonial">
        <p class="testimonial-text">
          "We use GVL Limo for all our corporate clients visiting from out of state.
          The professionalism and consistency is unmatched. The Sprinter limo is always a hit."
        </p>
        <span class="testimonial-author">Sarah T. — Director of Operations, Greenville Corp</span>
      </div>
      <div class="testimonial">
        <p class="testimonial-text">
          "Hired the party bus for my daughter's sweet 16. The karaoke, Xbox, light show — the kids
          went absolutely wild. Best money I've spent on a party. Already booking for prom."
        </p>
        <span class="testimonial-author">David K. — Simpsonville, SC</span>
      </div>
      <div class="testimonial">
        <p class="testimonial-text">
          "The GVL SAFE service gave our CEO complete peace of mind during a high-profile visit.
          Discrete, professional, and clearly trained to the highest standard. We won't travel without them now."
        </p>
        <span class="testimonial-author">James W. — VP Security, National Firm</span>
      </div>
    </div>
  </section>

  <!-- ========== CTA FULL-WIDTH ========== -->
  <section class="cta-band">
    <div class="container cta-band-inner">
      <h2 class="cta-band-title" data-animate="fade-up">
        Last-minute cancellation?<br/>
        <em>Your gain.</em>
      </h2>
      <p class="cta-band-text" data-animate="fade-up" data-delay="100">
        When other riders cancel, prices drop. Get notified instantly when a vehicle you want becomes
        available at a special rate.
      </p>
      <a href="/contact" class="btn btn-primary cta-band-btn" data-animate="fade-up" data-delay="200">
        Get Cancellation Alerts
      </a>
    </div>
  </section>

  <!-- ========== SERVICE AREAS ========== -->
  <div class="gold-seam"></div>
  <section class="section areas-section">
    <div class="container">
      <span class="kicker" data-animate="fade-up">Coverage</span>
      <h2 data-animate="fade-up" data-delay="100">The entire <em class="text-gold">Upstate</em> &amp; beyond</h2>
      <div class="areas-grid" data-animate="stagger">
        <span class="area-tag">Greenville</span>
        <span class="area-tag">Spartanburg</span>
        <span class="area-tag">Asheville</span>
        <span class="area-tag">Clemson</span>
        <span class="area-tag">Anderson</span>
        <span class="area-tag">Charlotte</span>
        <span class="area-tag">Atlanta</span>
        <span class="area-tag">Greer</span>
        <span class="area-tag">Simpsonville</span>
        <span class="area-tag">Travelers Rest</span>
        <span class="area-tag">Highlands</span>
        <span class="area-tag">Hendersonville</span>
        <span class="area-tag">Seneca</span>
        <span class="area-tag">Laurens</span>
        <span class="area-tag area-tag-accent">& Wherever Else You Need Us</span>
      </div>
    </div>
  </section>

  <!-- ========== CONTACT PREVIEW ========== -->
  <div class="gold-seam"></div>
  <section class="section contact-preview-section" id="contact">
    <div class="container">
      <div class="grid-asymmetric-reverse">
        <div class="contact-info-col" data-animate="fade-right">
          <span class="kicker">Get in Touch</span>
          <h2>Ready when <em class="text-gold">you are</em></h2>
          <div class="contact-items">
            <div class="contact-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M3 5l7 5 7-5M3 5v10h14V5H3z" stroke="#C9A84C" stroke-width="1.5" stroke-linejoin="round"/></svg>
              <a href="mailto:info@gvllimo.com">info@gvllimo.com</a>
            </div>
            <div class="contact-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 3h4l2 4-2.5 1.5A11 11 0 0011.5 12.5L13 10l4 2v4a1 1 0 01-1 1C9 17 3 11 3 4a1 1 0 011-1z" stroke="#C9A84C" stroke-width="1.5" stroke-linejoin="round"/></svg>
              <a href="tel:+18649203342">(864) 920-3342</a>
            </div>
            <div class="contact-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 2C6.7 2 4 4.7 4 8c0 4.5 6 10 6 10s6-5.5 6-10c0-3.3-2.7-6-6-6z" stroke="#C9A84C" stroke-width="1.5"/><circle cx="10" cy="8" r="2" stroke="#C9A84C" stroke-width="1.5"/></svg>
              <span>155 Riverplace Suite 206<br/>Greenville, SC 29601</span>
            </div>
            <div class="contact-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="7" stroke="#C9A84C" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span>Available 24/7</span>
            </div>
          </div>
          <div class="social-links" style="margin-top:var(--space-4);">
            <a href="https://www.facebook.com/107789328182081" aria-label="Facebook" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 1a9 9 0 00-1.4 17.9v-6.3H6.5V10h2.1V8.1c0-2.1 1.2-3.2 3.1-3.2.9 0 1.8.2 1.8.2v2h-1c-1 0-1.3.6-1.3 1.3V10h2.3l-.4 2.6h-1.9v6.3A9 9 0 0010 1z" fill="#C9A84C"/></svg>
            </a>
            <a href="https://www.instagram.com/gvllimo" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="2" width="16" height="16" rx="4" stroke="#C9A84C" stroke-width="1.5"/><circle cx="10" cy="10" r="3.5" stroke="#C9A84C" stroke-width="1.5"/><circle cx="14.5" cy="5.5" r="1" fill="#C9A84C"/></svg>
            </a>
            <a href="https://www.linkedin.com/company/greenville-executive-limo-service-llc/" aria-label="LinkedIn" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="2" width="16" height="16" rx="2" stroke="#C9A84C" stroke-width="1.5"/><path d="M6 9v5M6 6v.01M9 14v-3.5c0-1 .5-1.5 1.5-1.5s1.5.5 1.5 1.5V14" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/></svg>
            </a>
            <a href="https://www.tiktok.com/@gvllimo" aria-label="TikTok" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2v12a3 3 0 11-3-3M13 6a4 4 0 003 1" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="https://www.youtube.com/channel/UCHINlly5C97aLuaVqIkOShA" aria-label="YouTube" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="4" width="16" height="12" rx="3" stroke="#C9A84C" stroke-width="1.5"/><path d="M8 8l5 2.5L8 13V8z" fill="#C9A84C"/></svg>
            </a>
          </div>
        </div>
        <div data-animate="fade-left">
          <form class="contact-form" action="#" method="POST">
            <div class="form-group field">
              <input type="text" id="name" name="name" class="form-input" placeholder=" " required />
              <label for="name" class="form-label-float">Full Name</label>
            </div>
            <div class="form-row">
              <div class="form-group field">
                <input type="email" id="email" name="email" class="form-input" placeholder=" " required />
                <label for="email" class="form-label-float">Email</label>
              </div>
              <div class="form-group field">
                <input type="tel" id="phone" name="phone" class="form-input" placeholder=" " />
                <label for="phone" class="form-label-float">Phone</label>
              </div>
            </div>
            <div class="form-group field">
              <select id="service" name="service" class="form-input" required>
                <option value="" disabled selected>Select a service</option>
                <option value="airport">Airport Transfer</option>
                <option value="executive">Executive Transportation</option>
                <option value="wedding">Wedding / Event</option>
                <option value="party">Party Bus / Limo</option>
                <option value="tour">Tour / Experience</option>
                <option value="gvl-safe">GVL SAFE Security</option>
                <option value="hourly">Hourly Charter</option>
                <option value="cross-country">Cross-Country</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group field">
              <textarea id="message" name="message" class="form-input form-textarea" placeholder=" " rows="4"></textarea>
              <label for="message" class="form-label-float">Tell us about your trip</label>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
              Request a Quote
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ========== HERO ========== */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
