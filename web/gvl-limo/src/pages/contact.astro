---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Book Your Ride | Contact GVL Limo | Greenville, SC" description="Reserve your executive transportation in Greenville, SC. Call (864) 920-3342 or book online. Available 24/7 for airport transfers, events and corporate travel." canonical="https://gvllimo.com/contact">

  <section class="page-hero">
    <div class="container">
      <span class="kicker hero-kicker">Contact</span>
      <h1 class="hero-title">
        Let's get you<br/>
        <em class="text-gold">where you're going</em>
      </h1>
      <p class="hero-subtitle text-muted">
        Book online, call us, or fill out the form below. We respond within the hour, 24/7.
      </p>
    </div>
  </section>

  <div class="gold-seam gold-seam-animated"></div>

  <section class="section">
    <div class="container">
      <div class="contact-layout">

        <!-- LEFT: Contact Info -->
        <div class="contact-info" data-animate="fade-right">
          <div class="contact-block">
            <h3>Call or Text</h3>
            <a href="tel:+18649203342" class="contact-big-link">(864) 920-3342</a>
          </div>

          <div class="contact-block">
            <h3>Email</h3>
            <a href="mailto:info@gvllimo.com" class="contact-big-link">info@gvllimo.com</a>
          </div>

          <div class="contact-block">
            <h3>Visit Us</h3>
            <p class="text-muted">
              155 Riverplace Suite 206<br/>
              Greenville, SC 29601
            </p>
            <a href="https://www.google.com/maps/search/?api=1&query=155+Riverplace+Suite+206+Greenville+SC+29601" class="btn btn-ghost" style="margin-top:var(--space-2);" target="_blank" rel="noopener">
              Get Directions &rarr;
            </a>
          </div>

          <div class="contact-block">
            <h3>Hours</h3>
            <p class="text-muted">Available 24/7<br/>365 days a year</p>
          </div>

          <div class="gold-seam" style="margin-block:var(--space-4);"></div>

          <div class="contact-block">
            <h3>Follow Us</h3>
            <div class="social-grid">
              <a href="https://www.facebook.com/107789328182081" target="_blank" rel="noopener" class="social-chip">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 1a9 9 0 00-1.4 17.9v-6.3H6.5V10h2.1V8.1c0-2.1 1.2-3.2 3.1-3.2.9 0 1.8.2 1.8.2v2h-1c-1 0-1.3.6-1.3 1.3V10h2.3l-.4 2.6h-1.9v6.3A9 9 0 0010 1z" fill="#C9A84C"/></svg>
                Facebook
              </a>
              <a href="https://www.instagram.com/gvllimo" target="_blank" rel="noopener" class="social-chip">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="2" y="2" width="16" height="16" rx="4" stroke="#C9A84C" stroke-width="1.5"/><circle cx="10" cy="10" r="3.5" stroke="#C9A84C" stroke-width="1.5"/><circle cx="14.5" cy="5.5" r="1" fill="#C9A84C"/></svg>
                Instagram
              </a>
              <a href="https://www.linkedin.com/company/greenville-executive-limo-service-llc/" target="_blank" rel="noopener" class="social-chip">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="2" y="2" width="16" height="16" rx="2" stroke="#C9A84C" stroke-width="1.5"/><path d="M6 9v5M6 6v.01M9 14v-3.5c0-1 .5-1.5 1.5-1.5s1.5.5 1.5 1.5V14" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/></svg>
                LinkedIn
              </a>
              <a href="https://www.tiktok.com/@gvllimo" target="_blank" rel="noopener" class="social-chip">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 2v12a3 3 0 11-3-3M13 6a4 4 0 003 1" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                TikTok
              </a>
              <a href="https://www.youtube.com/channel/UCHINlly5C97aLuaVqIkOShA" target="_blank" rel="noopener" class="social-chip">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="2" y="4" width="16" height="12" rx="3" stroke="#C9A84C" stroke-width="1.5"/><path d="M8 8l5 2.5L8 13V8z" fill="#C9A84C"/></svg>
                YouTube
              </a>
              <a href="https://www.yelp.com/biz/jQTpLcSbhyOb__TQ4WOv-g" target="_blank" rel="noopener" class="social-chip">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M8 1l2.1 4.3 4.7.7-3.4 3.3.8 4.7L8 11.8 3.8 14l.8-4.7L1.2 6l4.7-.7L8 1z" fill="#C9A84C"/></svg>
                Yelp
              </a>
              <a href="https://www.x.com/GvlLimo" target="_blank" rel="noopener" class="social-chip">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M3 3l5.5 7.5L3 17h1.5l4.5-5.3L13 17h4l-5.8-8L16.5 3H15l-4.2 4.8L7 3H3zm2 1.5h2l8 11h-2L5 4.5z" fill="#C9A84C"/></svg>
                X / Twitter
              </a>
            </div>
          </div>

          <!-- Map embed -->
          <div class="map-container" style="margin-top:var(--space-4);">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3281.1!2d-82.4!3d34.85!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s155+Riverplace+Greenville+SC!5e0!3m2!1sen!2sus!4v1"
              width="100%"
              height="250"
              style="border:1px solid var(--color-border); filter:grayscale(1) invert(0.92) contrast(1.1);"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="GVL Limo office location"
            ></iframe>
          </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="contact-form-wrapper" data-animate="fade-left">
          <form class="contact-form-full" action="#" method="POST">
            <h2 style="margin-bottom:var(--space-2);">Request a Quote</h2>
            <p class="text-muted text-small" style="margin-bottom:var(--space-6);">
              Fill out the form and we'll respond within the hour with availability and pricing.
            </p>

            <div class="form-group field">
              <input type="text" id="contact-name" name="name" class="form-input" placeholder=" " required />
              <label for="contact-name" class="form-label-float">Full Name</label>
            </div>

            <div class="form-row">
              <div class="form-group field">
                <input type="email" id="contact-email" name="email" class="form-input" placeholder=" " required />
                <label for="contact-email" class="form-label-float">Email</label>
              </div>
              <div class="form-group field">
                <input type="tel" id="contact-phone" name="phone" class="form-input" placeholder=" " />
                <label for="contact-phone" class="form-label-float">Phone</label>
              </div>
            </div>

            <div class="form-group field">
              <select id="contact-service" name="service" class="form-input" required>
                <option value="" disabled selected>Select a service</option>
                <option value="airport">Airport Transfer</option>
                <option value="executive">Executive Transportation</option>
                <option value="wedding">Wedding / Special Event</option>
                <option value="party">Party Bus / Limo</option>
                <option value="tour">Tour / Experience</option>
                <option value="gvl-safe">GVL SAFE Security Transport</option>
                <option value="hourly">Hourly Charter</option>
                <option value="cross-country">Cross-Country Trip</option>
                <option value="downtown-cart">Downtown Cart</option>
                <option value="corporate">Corporate Account</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-row">
              <div class="form-group field">
                <input type="date" id="contact-date" name="date" class="form-input" />
                <label for="contact-date" class="form-label-float" style="top:-10px; font-size:var(--text-small); color:var(--color-primary);">Preferred Date</label>
              </div>
              <div class="form-group field">
                <input type="number" id="contact-passengers" name="passengers" class="form-input" placeholder=" " min="1" max="45" />
                <label for="contact-passengers" class="form-label-float">Passengers</label>
              </div>
            </div>

            <div class="form-group field">
              <input type="text" id="contact-pickup" name="pickup" class="form-input" placeholder=" " />
              <label for="contact-pickup" class="form-label-float">Pickup Location</label>
            </div>

            <div class="form-group field">
              <input type="text" id="contact-dropoff" name="dropoff" class="form-input" placeholder=" " />
              <label for="contact-dropoff" class="form-label-float">Drop-off Location</label>
            </div>

            <div class="form-group field">
              <textarea id="contact-message" name="message" class="form-input form-textarea" placeholder=" " rows="4"></textarea>
              <label for="contact-message" class="form-label-float">Additional Details</label>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
              Submit Request
            </button>

            <p class="text-muted text-small" style="text-align:center; margin-top:var(--space-2);">
              We accept credit cards only. Response within 1 hour, 24/7.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Success dialog -->
  <dialog id="success-dialog" class="success-dialog">
    <div class="dialog-content">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <circle cx="24" cy="24" r="20" stroke="#C9A84C" stroke-width="2"/>
        <path d="M16 24l6 6 10-12" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <h3>Request Received</h3>
      <p class="text-muted">We'll respond within the hour with availability and pricing.</p>
      <button class="btn btn-primary" onclick="this.closest('dialog').close()">Close</button>
    </div>
  </dialog>

</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(var(--space-16) + 80px);
    padding-bottom: var(--space-12);
    background: var(--color-surface);
    text-align: center;
  }
  .page-hero .hero-title { font-size: var(--text-h1); margin-bottom: var(--space-3); & em { font-style: italic; } }
  .page-hero .hero-subtitle { max-width: 52ch; margin-inline: auto; }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-8);
    align-items: start;
  }

  .contact-block {
    margin-bottom: var(--space-4);
  }

  .contact-block h3 {
    font-size: var(--text-small);
    font-family: 'Jost', sans-serif;
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .contact-big-link {
    font-family: 'Playfair Display', serif;
    font-size: var(--text-h3);
    color: var(--color-text) !important;
    transition: color var(--duration-fast) ease;

    &:hover { color: var(--color-primary) !important; }
  }

  .social-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .social-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    font-size: var(--text-small);
    color: var(--color-text-muted) !important;
    transition: all var(--duration-fast) ease;

    &:hover {
      border-color: var(--color-primary);
      color: var(--color-primary) !important;
    }
  }

  .map-container {
    overflow: hidden;
  }

  /* Form */
  .contact-form-full {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: var(--space-8);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .field {
    position: relative;
  }

  .form-label-float {
    position: absolute;
    left: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    font-size: var(--text-body);
    color: var(--color-text-muted);
    pointer-events: none;
    transition: all 200ms ease;
  }

  textarea ~ .form-label-float {
    top: var(--space-3);
    transform: none;
  }

  .form-input:focus ~ .form-label-float,
  .form-input:not(:placeholder-shown) ~ .form-label-float {
    top: -10px;
    transform: none;
    font-size: var(--text-small);
    color: var(--color-primary);
    left: var(--space-1);
  }

  textarea:focus ~ .form-label-float,
  textarea:not(:placeholder-shown) ~ .form-label-float {
    top: -10px;
    font-size: var(--text-small);
    color: var(--color-primary);
    left: var(--space-1);
  }

  /* Dialog */
  .success-dialog {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: var(--space-8);
    max-width: 400px;
    text-align: center;

    &::backdrop {
      background: rgba(13, 13, 13, 0.8);
      backdrop-filter: blur(4px);
    }
  }

  .dialog-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  @media (max-width: 768px) {
    .contact-layout { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .contact-form-full { padding: var(--space-4); }
  }
</style>
