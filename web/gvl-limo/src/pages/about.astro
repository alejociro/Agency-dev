---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Us | USDOT Certified, SLED Licensed | GVL Limo" description="Greenville's trusted executive transportation. USDOT certified, SLED licensed, fully insured. Meet our team and learn about GVL SAFE armed security." canonical="https://gvllimo.com/about">

  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {"@type": "Question", "name": "How do I book a ride with GVL Limo?", "acceptedAnswer": {"@type": "Answer", "text": "Book online through our site, download our app, or call (864) 920-3342. You'll receive an instant confirmation email and a receipt for the 25% non-refundable deposit."}},
        {"@type": "Question", "name": "What is GVL Limo's cancellation policy?", "acceptedAnswer": {"@type": "Answer", "text": "25% deposit is non-refundable and reserves your date. Cancel before the day prior to your trip and you won't be charged the remaining balance. Post-invoice cancellations are non-refundable."}},
        {"@type": "Question", "name": "What if my flight is delayed?", "acceptedAnswer": {"@type": "Answer", "text": "Delayed commercial flights (same flight number) are tracked at no additional charge. Flight cancellations receive a 40% credit toward rescheduled trips."}},
        {"@type": "Question", "name": "What payment methods does GVL Limo accept?", "acceptedAnswer": {"@type": "Answer", "text": "Credit cards only. We do not accept cash or checks."}},
        {"@type": "Question", "name": "Where does GVL Limo operate?", "acceptedAnswer": {"@type": "Answer", "text": "Licensed in SC, NC, GA, TN and throughout the U.S. Primary service areas include Greenville, Spartanburg, Asheville, Clemson, Anderson, Charlotte, Atlanta, and everywhere in between."}},
        {"@type": "Question", "name": "Is there a wait-time fee?", "acceptedAnswer": {"@type": "Answer", "text": "5 minutes of grace time. After that, no-show charges apply. Hourly services that exceed 10+ minutes incur an additional hourly charge."}}
      ]
    }
    </script>
  </Fragment>

  <section class="page-hero">
    <div class="container">
      <span class="kicker hero-kicker">About GVL Limo</span>
      <h1 class="hero-title">
        Built on trust.<br/>
        <em class="text-gold">Driven by standards.</em>
      </h1>
      <p class="hero-subtitle text-muted">
        Greenville Executive Limo Service is the Upstate's premier transportation company.
        Fully licensed in five states. Available 24/7. The only SLED-licensed armed transport in South Carolina.
      </p>
    </div>
  </section>

  <div class="gold-seam gold-seam-animated"></div>

  <!-- ========== MISSION ========== -->
  <section class="section">
    <div class="container">
      <div class="grid-asymmetric">
        <div data-animate="fade-right">
          <blockquote class="blockquote">
            "Our rates will surprise you. Our service will exceed every expectation."
          </blockquote>
          <p class="text-muted" style="margin-top:var(--space-4); max-width:48ch;">
            Looking for affordable, professional limousine rental or executive car service in
            Greenville, South Carolina? From airport rides to Hilton Head trips, from weddings
            to corporate events — our lineup of vehicles is here to serve you with whatever you need.
          </p>
          <p class="text-muted" style="margin-top:var(--space-3); max-width:48ch;">
            We are with you every step of the way. Confirmation emails, driver details before pickup,
            live text alerts when your driver is en route, and real-time updates when they arrive.
            That's not a premium add-on. That's every single ride.
          </p>
        </div>
        <div data-animate="fade-left">
          <div class="credentials-card card-accent" style="padding:var(--space-6);">
            <h3 style="margin-bottom:var(--space-4);">Credentials</h3>
            <div class="credential-list">
              <div class="credential-item">
                <span class="text-gold credential-label">USDOT</span>
                <span>#3650584</span>
              </div>
              <div class="credential-item">
                <span class="text-gold credential-label">MC Number</span>
                <span>#1271873</span>
              </div>
              <div class="credential-item">
                <span class="text-gold credential-label">SC Charter</span>
                <span>#9576</span>
              </div>
              <div class="credential-item">
                <span class="text-gold credential-label">SC Bus Charter</span>
                <span>#0426</span>
              </div>
              <div class="credential-item">
                <span class="text-gold credential-label">Greenville License</span>
                <span>#47979, #66812</span>
              </div>
              <div class="credential-item">
                <span class="text-gold credential-label">SLED Security</span>
                <span>#4044</span>
              </div>
            </div>
            <div class="gold-seam" style="margin-block:var(--space-3);"></div>
            <p class="text-muted text-small">
              Fully licensed in SC, NC, GA, TN &amp; anywhere in the U.S.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== STATS ========== -->
  <div class="gold-seam"></div>
  <section class="section" style="background:var(--color-surface); padding-block:var(--space-8);">
    <div class="container">
      <div class="stats-bar" data-animate="stagger">
        <div class="stat">
          <span class="stat-value" data-counter="18" data-suffix="+">0</span>
          <span class="stat-label">Team Members</span>
        </div>
        <div class="stat">
          <span class="stat-value" data-counter="7">0</span>
          <span class="stat-label">Premium Vehicles</span>
        </div>
        <div class="stat">
          <span class="stat-value" data-counter="5">0</span>
          <span class="stat-label">States Licensed</span>
        </div>
        <div class="stat">
          <span class="stat-value" data-counter="6">0</span>
          <span class="stat-label">Certifications</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SAFETY ========== -->
  <div class="gold-seam"></div>
  <section class="section">
    <div class="container">
      <span class="kicker" data-animate="fade-up">Safety Protocols</span>
      <h2 data-animate="fade-up" data-delay="100">Safety isn't a feature.<br/><em class="text-gold">It's the foundation.</em></h2>

      <div class="safety-grid" data-animate="stagger">
        <div class="card-accent safety-card">
          <div class="safety-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <circle cx="18" cy="14" r="6" stroke="#C9A84C" stroke-width="1.5"/>
              <path d="M8 30c0-5.5 4.5-10 10-10s10 4.5 10 10" stroke="#C9A84C" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>Vetted Drivers</h3>
          <p class="text-muted">Criminal &amp; driving record background checks. Drug testing. DOT physicals. No exceptions, no shortcuts.</p>
        </div>
        <div class="card-accent safety-card">
          <div class="safety-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <rect x="8" y="10" width="20" height="14" rx="2" stroke="#C9A84C" stroke-width="1.5"/>
              <circle cx="18" cy="17" r="4" stroke="#C9A84C" stroke-width="1.5"/>
              <path d="M14 28h8" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Monitored Fleet</h3>
          <p class="text-muted">Every vehicle: video recording, GPS tracking, speed monitoring. Real-time oversight on every trip.</p>
        </div>
        <div class="card-accent safety-card">
          <div class="safety-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <path d="M18 6l10 4v8c0 6-4 10-10 12-6-2-10-6-10-12v-8l10-4z" stroke="#C9A84C" stroke-width="1.5" stroke-linejoin="round"/>
              <path d="M14 18l3 3 5-6" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Emergency Ready</h3>
          <p class="text-muted">North American Rescue "Stop the Bleed" crisis kits in every vehicle. Drivers trained in proper use by NAR.</p>
        </div>
        <div class="card-accent safety-card">
          <div class="safety-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <path d="M10 18h4l3-6 4 12 3-6h4" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Always Connected</h3>
          <p class="text-muted">Radio-equipped fleet with earpieces for hands-free dispatch. Never out of contact, never distracted.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== GVL SAFE ========== -->
  <div class="gold-seam"></div>
  <section class="section gvl-safe-section ambient-glow" id="gvl-safe">
    <div class="container">
      <div class="grid-asymmetric-reverse">
        <div data-animate="fade-right">
          <div class="safe-visual">
            <img
              src="https://img1.wsimg.com/isteam/ip/7cfeebe0-8cbc-4d8b-810f-8f41f13db67a/security%20video%20screen%20grab013%20-%20eric%20isaac%20pro.jpg"
              alt="GVL SAFE security officers Eric Baade and Isaac Yopp"
              width="700"
              height="467"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <div data-animate="fade-left">
          <span class="kicker">GVL SAFE</span>
          <h2>Armed executive<br/><em class="text-gold">protection transport</em></h2>
          <p class="text-muted" style="margin-top:var(--space-3);">
            The only company in South Carolina currently licensed under SLED to provide
            secure armed transportation. SLED License #4044.
          </p>
          <p class="text-muted" style="margin-top:var(--space-2);">
            All personnel: SLED-licensed private security agents with concealed armed certifications.
            Law enforcement background required. Training crafted by industry professionals from
            Secret Service members to Navy SEALs.
          </p>

          <div class="safe-officers" style="margin-top:var(--space-6);">
            <h3 style="margin-bottom:var(--space-3);">Lead Security Officers</h3>
            <div class="officer">
              <h4 class="text-gold">Eric Baade</h4>
              <p class="text-muted text-small">
                Recently retired police sergeant. 26 years of law enforcement experience.
                Distinguished Service Award. Ben Ali Shriners Award for Law Enforcement Excellence.
              </p>
            </div>
            <div class="officer" style="margin-top:var(--space-3);">
              <h4 class="text-gold">Isaac Yopp</h4>
              <p class="text-muted text-small">
                13 years public service: SC State Trooper, EMT, Firefighter. 2 years as firearms instructor.
                6 years CERT. Recognized by Governor Kasich for work at 2016 RNC.
              </p>
            </div>
          </div>

          <div class="safe-stat" style="margin-top:var(--space-6); padding:var(--space-4); border-left:3px solid var(--color-primary);">
            <p class="text-muted text-small" style="font-style:italic;">
              "33% of CEOs have received physical threats. VIPs are most at risk when leaving their home
              and while entering the office."
            </p>
            <span class="text-muted text-small">— Center for Protective Intelligence</span>
          </div>

          <a href="/contact" class="btn btn-primary" style="margin-top:var(--space-4);">Request GVL SAFE</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <div class="gold-seam"></div>
  <section class="section" style="background:var(--color-surface);">
    <div class="container" style="max-width:800px;">
      <span class="kicker" data-animate="fade-up">FAQ</span>
      <h2 data-animate="fade-up" data-delay="100">Common <em class="text-gold">questions</em></h2>

      <div class="faq-list" data-animate="stagger">
        <details class="faq-item">
          <summary class="faq-question">
            <span>How do I book a ride?</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/></svg>
          </summary>
          <div class="faq-answer">
            <p class="text-muted">
              Book online through our site, download our app, or call (864) 920-3342.
              You'll receive an instant confirmation email and a receipt for the 25% non-refundable deposit.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span>What's your cancellation policy?</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/></svg>
          </summary>
          <div class="faq-answer">
            <p class="text-muted">
              25% deposit is non-refundable and reserves your date. Cancel before the day prior to your trip
              and you won't be charged the remaining balance. Post-invoice cancellations are non-refundable.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span>What if my flight is delayed?</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/></svg>
          </summary>
          <div class="faq-answer">
            <p class="text-muted">
              Delayed commercial flights (same flight number) are tracked at no additional charge.
              Flight cancellations receive a 40% credit toward rescheduled trips.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span>What payment methods do you accept?</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/></svg>
          </summary>
          <div class="faq-answer">
            <p class="text-muted">Credit cards only. We do not accept cash or checks.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span>Where do you operate?</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/></svg>
          </summary>
          <div class="faq-answer">
            <p class="text-muted">
              Licensed in SC, NC, GA, TN and throughout the U.S. Primary service areas include Greenville,
              Spartanburg, Asheville, Clemson, Anderson, Charlotte, Atlanta, and everywhere in between.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span>Is there a wait-time fee?</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/></svg>
          </summary>
          <div class="faq-answer">
            <p class="text-muted">
              5 minutes of grace time. After that, no-show charges apply. Hourly services
              that exceed 10+ minutes incur an additional hourly charge.
            </p>
          </div>
        </details>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(var(--space-16) + 80px);
    padding-bottom: var(--space-12);
    background: var(--color-surface);
    text-align: center;
  }
  .page-hero .hero-title { font-size: var(--text-h1); margin-bottom: var(--space-3); & em { font-style: italic; } }
  .page-hero .hero-subtitle { max-width: 52ch; margin-inline: auto; }

  /* Credentials */
  .credential-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .credential-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-small);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--color-border);
  }

  .credential-label {
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    font-size: 0.75rem;
  }

  /* Safety grid */
  .safety-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-6);
  }

  .safety-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .safety-icon {
    margin-bottom: var(--space-1);
  }

  /* GVL SAFE visual */
  .safe-visual {
    overflow: hidden;
    border: 1px solid var(--color-border);

    & img {
      width: 100%;
      height: auto;
      object-fit: cover;
    }
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }

  .faq-item {
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    transition: border-color var(--duration-fast) ease;

    &[open] {
      border-color: var(--color-border-strong);
    }

    &[open] .faq-chevron {
      transform: rotate(180deg);
    }

    &[open] .faq-answer {
      animation: faqSlideDown 0.3s ease;
    }
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    list-style: none;
    font-weight: 500;
    min-height: 44px;

    &::marker { display: none; }
    &::-webkit-details-marker { display: none; }
  }

  .faq-chevron {
    flex-shrink: 0;
    transition: transform var(--duration-fast) var(--ease-out-expo);
  }

  .faq-answer {
    padding: 0 var(--space-4) var(--space-4);
  }

  @keyframes faqSlideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .safety-grid { grid-template-columns: 1fr; }
  }
</style>
