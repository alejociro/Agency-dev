---
import BaseLayout from '../layouts/BaseLayout.astro';

const vehicles = [
  {
    id: 'sedan',
    name: 'Maserati Ghibli S',
    type: 'VIP Executive Sedan',
    capacity: 4,
    image: 'https://img1.wsimg.com/isteam/ip/7cfeebe0-8cbc-4d8b-810f-8f41f13db67a/b%20Maserati%20Ghibli%20S%20-%20Horizontal.jpg',
    description: 'Twin-turbo Ferrari-built V6 with 424 horsepower. The statement vehicle for executives who want to arrive, not just show up.',
    features: ['424hp twin-turbo V6', 'Premium leather interior', 'Harman Kardon sound', 'Phone charging'],
  },
  {
    id: 'suv',
    name: 'Cadillac Escalade ESV',
    type: 'Luxury SUV',
    capacity: 6,
    image: 'https://img1.wsimg.com/isteam/ip/7cfeebe0-8cbc-4d8b-810f-8f41f13db67a/IMG_2704.jpg',
    description: '2025 model. The commanding presence of a full-size luxury SUV with room for your entire executive team and their luggage.',
    features: ['Extended wheelbase', 'Third-row seating', 'Premium entertainment', 'Ample cargo space'],
  },
  {
    id: 'compact-suv',
    name: 'Audi Q3',
    type: 'Compact Executive SUV',
    capacity: 4,
    image: 'https://img1.wsimg.com/isteam/ip/7cfeebe0-8cbc-4d8b-810f-8f41f13db67a/2022%20Audi%20Q3%20GVL%20Limo%20Horizontal.jpg',
    description: 'German precision for shorter trips and airport transfers. Nimble in city traffic, comfortable on the highway.',
    features: ['Quattro AWD', 'Virtual cockpit', 'Compact yet spacious', 'Ideal for airports'],
  },
  {
    id: 'sprinter',
    name: 'Mercedes-Benz Sprinter Limo',
    type: 'Executive Sprinter',
    capacity: 14,
    image: 'https://img1.wsimg.com/isteam/ip/7cfeebe0-8cbc-4d8b-810f-8f41f13db67a/1.%20AB.%20sprinter%20main%20shot%20crop.jpg',
    description: 'The CEO Sprinter. Full entertainment system, premium seating, perfect for corporate groups, tours, and bachelor/bachelorette parties.',
    features: ['WiFi enabled', 'Karaoke system', 'TV screens', 'Premium bar area'],
  },
  {
    id: 'limo',
    name: 'Chrysler 300 Stretch',
    type: 'Classic Stretch Limousine',
    capacity: 10,
    image: 'https://img1.wsimg.com/isteam/ip/7cfeebe0-8cbc-4d8b-810f-8f41f13db67a/1.%20Chrystler%20Stretch%20Limo%20-%20GVL%20Limo%20ext-min.jpg',
    description: 'The classic stretch experience. Karaoke, Xbox, Wii Mario Kart, Spotify, bar service, and nightclub lighting. Your party starts at pickup.',
    features: ['Karaoke system', 'Xbox/Wii gaming', 'Nightclub lighting', 'Full bar setup'],
  },
  {
    id: 'party-bus',
    name: 'BCI Falcon Party Bus',
    type: 'Party Motor Coach',
    capacity: 45,
    image: 'https://img1.wsimg.com/isteam/ip/7cfeebe0-8cbc-4d8b-810f-8f41f13db67a/GVL%20LIMO%20BUS%20Exterior%20-%20Prof%20-%206.jpg',
    description: 'The flagship. DJ booth, full bar, 50" TV screens, iPad-controlled entertainment with Alexa voice control, and a sound system that rivals downtown clubs.',
    features: ['DJ booth', '50" TV screens', 'iPad + Alexa control', 'Nightclub sound & lights'],
  },
  {
    id: 'lux-bus',
    name: 'Freightliner Grech Mini Coach',
    type: 'Luxury Mini Coach',
    capacity: 38,
    image: 'https://img1.wsimg.com/isteam/ip/7cfeebe0-8cbc-4d8b-810f-8f41f13db67a/blob-0b5ef24.png',
    description: 'Corporate luxury for large groups. Eight TV screens, WiFi, premium seating, and the smooth ride of a purpose-built coach.',
    features: ['8 TV screens', 'WiFi throughout', 'USB charging', 'Premium reclining seats'],
  },
];
---

<BaseLayout title="Our Fleet | Executive Sedans, SUVs & Limousines | GVL Limo" description="Explore our premium fleet: Maserati Ghibli S, Cadillac Escalade, Mercedes Sprinter Limo, party buses up to 45 passengers. 24/7 in Greenville, SC." canonical="https://gvllimo.com/services">

  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "GVL Limo Fleet",
      "description": "Premium vehicle fleet for executive transportation in Greenville, SC",
      "numberOfItems": 7,
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "item": {"@type": "Vehicle", "name": "Maserati Ghibli S", "description": "VIP Executive Sedan, up to 4 passengers", "seatingCapacity": 4}},
        {"@type": "ListItem", "position": 2, "item": {"@type": "Vehicle", "name": "Cadillac Escalade ESV", "description": "Luxury SUV, up to 6 passengers", "seatingCapacity": 6}},
        {"@type": "ListItem", "position": 3, "item": {"@type": "Vehicle", "name": "Audi Q3", "description": "Compact Executive SUV, up to 4 passengers", "seatingCapacity": 4}},
        {"@type": "ListItem", "position": 4, "item": {"@type": "Vehicle", "name": "Mercedes-Benz Sprinter Limo", "description": "Executive Sprinter, up to 14 passengers", "seatingCapacity": 14}},
        {"@type": "ListItem", "position": 5, "item": {"@type": "Vehicle", "name": "Chrysler 300 Stretch", "description": "Classic Stretch Limousine, up to 10 passengers", "seatingCapacity": 10}},
        {"@type": "ListItem", "position": 6, "item": {"@type": "Vehicle", "name": "BCI Falcon Party Bus", "description": "Party Motor Coach, up to 45 passengers", "seatingCapacity": 45}},
        {"@type": "ListItem", "position": 7, "item": {"@type": "Vehicle", "name": "Freightliner Grech Mini Coach", "description": "Luxury Mini Coach, up to 38 passengers", "seatingCapacity": 38}}
      ]
    }
    </script>
  </Fragment>

  <!-- ========== HERO ========== -->
  <section class="page-hero">
    <div class="container">
      <span class="kicker hero-kicker">The Fleet</span>
      <h1 class="hero-title">
        Seven vehicles.<br/>
        <em class="text-gold">One standard.</em>
      </h1>
      <p class="hero-subtitle text-muted">
        From a Maserati sedan to a 45-passenger party bus — every vehicle is GPS-tracked,
        video-monitored, equipped with emergency kits, and maintained to perfection.
      </p>
    </div>
  </section>

  <div class="gold-seam gold-seam-animated"></div>

  <!-- ========== VEHICLE GRID ========== -->
  <section class="section vehicles-section">
    <div class="container">
      {vehicles.map((v, i) => (
        <article class={`vehicle-row ${i % 2 !== 0 ? 'vehicle-row-reverse' : ''}`} id={v.id} data-animate={i % 2 === 0 ? 'fade-right' : 'fade-left'}>
          <div class="vehicle-image img-reveal">
            <img
              src={v.image}
              alt={`${v.name} — ${v.type}, up to ${v.capacity} passengers`}
              width="700"
              height="438"
              loading={i < 2 ? 'eager' : 'lazy'}
              decoding="async"
            />
            <div class="vehicle-capacity-badge">
              <span>{v.capacity}</span>
              <small>PAX</small>
            </div>
          </div>
          <div class="vehicle-info">
            <span class="kicker">{v.type}</span>
            <h2>{v.name}</h2>
            <p class="text-muted">{v.description}</p>
            <ul class="vehicle-features">
              {v.features.map((f) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7l3.5 3.5L12 4" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contact" class="btn btn-primary">Book {v.name.split(' ')[0]}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ========== DOWNTOWN CART ========== -->
  <div class="gold-seam"></div>
  <section class="section cart-section ambient-glow">
    <div class="container">
      <div class="grid-asymmetric" data-animate="fade-up">
        <div>
          <span class="kicker">Downtown Cart</span>
          <h2>
            Greenville's only<br/>
            <em class="text-gold">city-approved $5 ride</em>
          </h2>
          <p class="text-muted" style="max-width:44ch; margin-top:var(--space-3);">
            Need a quick ride downtown? Our electric golf cart service covers Main Street
            end-to-end. Featured on FOX Carolina. The only low-speed vehicle approved by
            the City of Greenville for passenger transport.
          </p>
          <div class="cart-details" style="margin-top:var(--space-4);">
            <div class="cart-stat">
              <span class="text-gold" style="font-family:'Playfair Display',serif; font-size:var(--text-h2);">$5</span>
              <span class="text-muted text-small">per person</span>
            </div>
            <div class="cart-stat">
              <span class="text-gold" style="font-family:'Playfair Display',serif; font-size:var(--text-h2);">5</span>
              <span class="text-muted text-small">passengers max</span>
            </div>
          </div>
          <div style="margin-top:var(--space-4); display:flex; gap:var(--space-3); flex-wrap:wrap;">
            <a href="/contact" class="btn btn-primary">Request a Cart Ride</a>
            <a href="tel:+18649203342" class="btn btn-outline">Call or Text</a>
          </div>
        </div>
        <div>
          <div class="card-accent" style="padding:var(--space-6);">
            <h3 style="margin-bottom:var(--space-3);">Downtown Hospitality Packages</h3>
            <p class="text-muted" style="margin-bottom:var(--space-4);">
              Hotels, restaurants, and apartment complexes — give your guests complimentary rides.
            </p>
            <div class="pricing-table">
              <div class="pricing-row">
                <span>100 Tokens</span>
                <span class="text-gold">$400/mo</span>
              </div>
              <div class="pricing-row">
                <span>50 Tokens</span>
                <span class="text-gold">$225/mo</span>
              </div>
              <div class="pricing-row">
                <span>25 Tokens</span>
                <span class="text-gold">$120/mo</span>
              </div>
              <div class="gold-seam-short" style="margin-block:var(--space-2);"></div>
              <div class="pricing-row">
                <span>Hourly Rental</span>
                <span class="text-gold">$200/hr</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="cta-band">
    <div class="container cta-band-inner">
      <h2 class="cta-band-title" data-animate="fade-up">
        Not sure which vehicle?<br/><em>We'll help you choose.</em>
      </h2>
      <p class="cta-band-text" data-animate="fade-up" data-delay="100">
        Tell us the occasion, group size, and route. We'll match you with the perfect ride.
      </p>
      <a href="/contact" class="btn btn-primary cta-band-btn" data-animate="fade-up" data-delay="200">
        Get a Custom Quote
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(var(--space-16) + 80px);
    padding-bottom: var(--space-12);
    background: var(--color-surface);
    text-align: center;
  }

  .page-hero .hero-title {
    font-size: var(--text-h1);
    margin-bottom: var(--space-3);
    & em { font-style: italic; }
  }

  .page-hero .hero-subtitle {
    max-width: 52ch;
    margin-inline: auto;
  }

  /* Vehicle rows */
  .vehicle-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-8);
    align-items: center;
    padding-block: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .vehicle-row:last-child {
    border-bottom: none;
  }

  .vehicle-row-reverse {
    direction: rtl;
    & > * { direction: ltr; }
  }

  .vehicle-image {
    position: relative;
    overflow: hidden;

    & img {
      width: 100%;
      height: auto;
      object-fit: cover;
    }
  }

  .vehicle-capacity-badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    background: rgba(13, 13, 13, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    padding: var(--space-1) var(--space-2);
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;

    & span {
      font-family: 'Playfair Display', serif;
      font-size: var(--text-h3);
      color: var(--color-primary);
    }

    & small {
      font-size: 0.6rem;
      letter-spacing: var(--tracking-widest);
      text-transform: uppercase;
      color: var(--color-text-muted);
    }
  }

  .vehicle-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .vehicle-info h2 {
    font-size: var(--text-h2);
  }

  .vehicle-features {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-1) var(--space-3);
    margin-block: var(--space-2);

    & li {
      display: flex;
      align-items: center;
      gap: 0.5em;
      font-size: var(--text-small);
      color: var(--color-text-muted);
    }
  }

  /* Cart details */
  .cart-details {
    display: flex;
    gap: var(--space-6);
  }

  .cart-stat {
    display: flex;
    flex-direction: column;
  }

  /* Pricing table */
  .pricing-table {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .pricing-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-body);
  }

  /* CTA band matching home */
  .cta-band {
    background: var(--color-primary);
    padding-block: var(--space-12);
    text-align: center;
  }
  .cta-band-title { color: var(--color-bg); margin-bottom: var(--space-3); & em { font-style: italic; } }
  .cta-band-text { color: rgba(13, 13, 13, 0.7); max-width: 48ch; margin-inline: auto; margin-bottom: var(--space-6); }
  .cta-band .btn-primary { background: var(--color-bg); color: var(--color-primary); &:hover { background: var(--color-surface); box-shadow: var(--shadow-elevated); } }

  @media (max-width: 768px) {
    .vehicle-row,
    .vehicle-row-reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .vehicle-features { grid-template-columns: 1fr; }
    .cart-details { flex-direction: column; gap: var(--space-3); }
  }
</style>
