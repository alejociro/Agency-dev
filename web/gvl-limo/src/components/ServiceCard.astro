---
interface Props {
  title: string;
  description: string;
  icon: string;
  featured?: boolean;
}

const { title, description, icon, featured = false } = Astro.props;
---

<div class={`card-accent service-card ${featured ? 'service-card-featured' : ''}`}>
  <div class="service-icon">
    <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
      <path d={icon} stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>
  <h3>{title}</h3>
  <p class="text-muted">{description}</p>
</div>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .service-card-featured {
    border-top-color: var(--color-accent);
    background: var(--color-surface-alt);
  }

  .service-icon {
    margin-bottom: var(--space-1);
  }

  h3 {
    font-size: var(--text-h3);
  }
</style>
