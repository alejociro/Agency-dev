---
interface Props {
  id: string;
  name: string;
  type: string;
  capacity: number;
  image: string;
  description: string;
  features: string[];
  reverse?: boolean;
  eager?: boolean;
}

const { id, name, type, capacity, image, description, features, reverse = false, eager = false } = Astro.props;
---

<article class={`vehicle-row ${reverse ? 'vehicle-row-reverse' : ''}`} id={id} data-animate={reverse ? 'fade-left' : 'fade-right'}>
  <div class="vehicle-image img-reveal">
    <img
      src={image}
      alt={`${name} — ${type}, up to ${capacity} passengers`}
      width="700"
      height="438"
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
    />
    <div class="vehicle-capacity-badge">
      <span>{capacity}</span>
      <small>PAX</small>
    </div>
  </div>
  <div class="vehicle-info">
    <span class="kicker">{type}</span>
    <h2>{name}</h2>
    <p class="text-muted">{description}</p>
    <ul class="vehicle-features">
      {features.map((f) => (
        <li>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7l3.5 3.5L12 4" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {f}
        </li>
      ))}
    </ul>
    <a href="/contact" class="btn btn-primary">Book {name.split(' ')[0]}</a>
  </div>
</article>

<style>
  .vehicle-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-8);
    align-items: center;
    padding-block: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .vehicle-row:last-child {
    border-bottom: none;
  }

  .vehicle-row-reverse {
    direction: rtl;
    & > * { direction: ltr; }
  }

  .vehicle-image {
    position: relative;
    overflow: hidden;

    & img {
      width: 100%;
      height: auto;
      object-fit: cover;
    }
  }

  .vehicle-capacity-badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    background: rgba(13, 13, 13, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    padding: var(--space-1) var(--space-2);
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;

    & span {
      font-family: 'Playfair Display', serif;
      font-size: var(--text-h3);
      color: var(--color-primary);
    }

    & small {
      font-size: 0.6rem;
      letter-spacing: var(--tracking-widest);
      text-transform: uppercase;
      color: var(--color-text-muted);
    }
  }

  .vehicle-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .vehicle-info h2 {
    font-size: var(--text-h2);
  }

  .vehicle-features {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-1) var(--space-3);
    margin-block: var(--space-2);

    & li {
      display: flex;
      align-items: center;
      gap: 0.5em;
      font-size: var(--text-small);
      color: var(--color-text-muted);
    }
  }

  @media (max-width: 768px) {
    .vehicle-row,
    .vehicle-row-reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .vehicle-features { grid-template-columns: 1fr; }
  }
</style>
