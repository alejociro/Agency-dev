---
interface Props {
  variant?: 'full' | 'short' | 'left' | 'animated';
}

const { variant = 'full' } = Astro.props;

const classMap: Record<string, string> = {
  full: 'gold-seam',
  short: 'gold-seam-short',
  left: 'gold-seam-left',
  animated: 'gold-seam gold-seam-animated',
};
---

<div class={classMap[variant]} aria-hidden="true"></div>
