---
interface Props {
  title: string;
  text: string;
  cta: string;
  href?: string;
}

const { title, text, cta, href = '/contact' } = Astro.props;
---

<section class="cta-band">
  <div class="container cta-band-inner">
    <h2 class="cta-band-title" data-animate="fade-up" set:html={title} />
    <p class="cta-band-text" data-animate="fade-up" data-delay="100">{text}</p>
    <a href={href} class="btn btn-primary cta-band-btn" data-animate="fade-up" data-delay="200">{cta}</a>
  </div>
</section>

<style>
  .cta-band {
    background: var(--color-primary);
    padding-block: var(--space-12);
    text-align: center;
  }

  .cta-band-title {
    color: var(--color-bg);
    margin-bottom: var(--space-3);

    & :global(em) {
      font-style: italic;
    }
  }

  .cta-band-text {
    color: rgba(13, 13, 13, 0.7);
    max-width: 48ch;
    margin-inline: auto;
    margin-bottom: var(--space-6);
  }

  .cta-band .btn-primary {
    background: var(--color-bg);
    color: var(--color-primary);

    &:hover {
      background: var(--color-surface);
      box-shadow: var(--shadow-elevated);
    }
  }
</style>
