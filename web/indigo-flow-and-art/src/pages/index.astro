---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Indigo Flow and Art | Classical Pilates & Fine Art Gallery in Greenville SC"
  description="Discover the art of movement at Indigo Flow and Art. A Classical Pilates studio and Fine Art gallery in the Village of West Greenville, SC. New Student Special: 3 private sessions for $210."
  canonical="/"
  currentPage="home"
>

  <!-- ==================== HERO — Split Screen ==================== -->
  <section class="hero" style="position: relative; min-height: 100vh; display: flex; align-items: center; overflow: hidden; background-color: var(--color-primary-dark);">

    <!-- Background split panels -->
    <div class="grid-split" style="position: absolute; inset: 0; z-index: 1;">
      <div class="hero-panel-left" style="position: relative; overflow: hidden;">
        <img
          src="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/7797301b-9933-440e-84b8-7c4091188fcb/website+2.jpg"
          alt="Classical Pilates session at Indigo studio with Gratz equipment"
          width="960" height="1080"
          style="width: 100%; height: 100%; object-fit: cover; opacity: 0.5;"
          loading="eager"
          decoding="async"
        />
      </div>
      <div class="hero-panel-right" style="position: relative; overflow: hidden; display: none;">
        <img
          src="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/1590769141691-7TO0ASKD4227B2TP5988/_MG_9679.jpg"
          alt="Fine art painting by Julie Hughes at Indigo Art Gallery"
          width="960" height="1080"
          style="width: 100%; height: 100%; object-fit: cover; opacity: 0.4;"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>

    <!-- Flowing indigo SVG line (signature motif) -->
    <svg class="indigo-flow-svg" style="position: absolute; inset-inline-start: 50%; top: 0; bottom: 0; width: 2px; z-index: 2; display: none;" viewBox="0 0 2 400" preserveAspectRatio="none" aria-hidden="true">
      <path d="M1 0 C1 100, 1 200, 1 400" stroke="#4a6fa5" stroke-width="2" fill="none"/>
    </svg>

    <!-- Dark overlay for text legibility -->
    <div style="position: absolute; inset: 0; z-index: 3; background: linear-gradient(135deg, rgba(30,38,56,0.75) 0%, rgba(30,38,56,0.5) 50%, rgba(30,38,56,0.7) 100%);"></div>

    <!-- Hero content -->
    <div class="container" style="position: relative; z-index: 4; text-align: center; padding-block: var(--space-16);">
      <span class="hero-tag section-tag" style="color: var(--color-gold); justify-content: center;">
        Classical Pilates &amp; Fine Art Gallery
      </span>

      <h1 class="hero-title" style="color: var(--color-cream); max-width: 18ch; margin-inline: auto; margin-block-end: var(--space-3);" data-split>
        The Art of Movement
      </h1>

      <p class="hero-sub" style="color: var(--color-text-inverse); max-width: 50ch; margin-inline: auto; margin-block-end: var(--space-6); font-size: var(--text-h3); line-height: var(--leading-snug);">
        Where Classical Pilates and Fine Art unite to invite your creativity and vitality to bloom.
      </p>

      <div class="hero-cta" style="display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
        <a href="/classical-pilates" class="btn btn--primary btn--large" data-magnetic>Book a Session</a>
        <a href="/fine-art" class="btn btn--ghost" style="color: var(--color-cream); border-color: var(--color-cream);">Explore the Gallery &rarr;</a>
      </div>

      <div class="hero-proof" style="margin-block-start: var(--space-8); display: flex; gap: var(--space-6); justify-content: center; flex-wrap: wrap;">
        <div style="text-align: center;">
          <span style="font-family: var(--font-display); font-size: var(--text-h2); font-weight: 700; color: var(--color-gold); display: block;" data-counter="210" data-prefix="$">0</span>
          <span style="font-size: var(--text-small); color: var(--color-text-muted);">New Student Special</span>
        </div>
        <div style="text-align: center;">
          <span style="font-family: var(--font-display); font-size: var(--text-h2); font-weight: 700; color: var(--color-gold); display: block;">Gratz</span>
          <span style="font-size: var(--text-small); color: var(--color-text-muted);">Authentic Equipment</span>
        </div>
        <div style="text-align: center;">
          <span style="font-family: var(--font-display); font-size: var(--text-h2); font-weight: 700; color: var(--color-gold); display: block;">West GVL</span>
          <span style="font-size: var(--text-small); color: var(--color-text-muted);">Village Arts District</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div style="position: absolute; bottom: var(--space-4); inset-inline-start: 50%; transform: translateX(-50%); z-index: 4; text-align: center;">
      <span style="font-size: var(--text-small); color: var(--color-text-muted); letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-block-end: 0.5rem;">Discover</span>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="1.5" style="animation: slideUp 1.5s ease-in-out infinite alternate;">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </div>
  </section>

  <!-- Show split panel on desktop -->
  <style>
    @media (min-width: 768px) {
      .hero .hero-panel-right { display: block !important; }
      .hero .indigo-flow-svg { display: block !important; }
    }
  </style>

  <!-- ==================== DUAL INTRO ==================== -->
  <section class="section section--cream" id="services">
    <div class="container">
      <div class="grid-split" style="gap: 0; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-card);" data-animate="scale-in">

        <!-- Pilates side -->
        <a href="/classical-pilates" style="display: block; position: relative; min-height: 350px; overflow: hidden; text-decoration: none;" class="img-overlay">
          <img
            src="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/050af7b3-0fc6-4a5a-99ee-7ef3db93bb3b/IndigoFlowArt-31.jpg"
            alt="Indigo Pilates studio with natural light and Gratz equipment"
            width="800" height="600"
            loading="lazy" decoding="async"
            style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0;"
          />
          <div style="position: relative; z-index: 2; padding: var(--space-6); display: flex; flex-direction: column; justify-content: flex-end; height: 100%; min-height: 350px;">
            <span class="section-tag" style="color: var(--color-gold);">Movement</span>
            <h2 style="color: var(--color-cream); margin-block-end: var(--space-1);">Classical Pilates</h2>
            <p style="color: var(--color-text-inverse); font-size: var(--text-small); max-width: 35ch;">Joseph Pilates' original Contrology Method in a light-filled studio.</p>
          </div>
        </a>

        <!-- Art side -->
        <a href="/fine-art" style="display: block; position: relative; min-height: 350px; overflow: hidden; text-decoration: none;" class="img-overlay">
          <img
            src="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/c03de3e3-6c71-463e-b152-a2b8afc7e144/0216.ubj.firstlook.indigoyogastudio.7.williamcrooks.jpg"
            alt="Interior of Indigo Art Gallery with original paintings"
            width="800" height="600"
            loading="lazy" decoding="async"
            style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0;"
          />
          <div style="position: relative; z-index: 2; padding: var(--space-6); display: flex; flex-direction: column; justify-content: flex-end; height: 100%; min-height: 350px;">
            <span class="section-tag" style="color: var(--color-gold);">Creativity</span>
            <h2 style="color: var(--color-cream); margin-block-end: var(--space-1);">Fine Art Gallery</h2>
            <p style="color: var(--color-text-inverse); font-size: var(--text-small); max-width: 35ch;">Original works capturing motion, speed, and the essence of the everyday.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== MANIFESTO BLOCK (Grid Breaker) ==================== -->
  <section style="padding-block: var(--space-4); overflow: hidden;">
    <div class="container">
      <div class="manifesto-block" data-animate="scale-in">
        <p class="manifesto-text" style="text-align: center;">
          Move<span class="manifesto-dot">.</span>
          Create<span class="manifesto-dot">.</span>
          Be<span class="manifesto-dot">.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== NEW STUDENT SPECIAL (CTA) ==================== -->
  <section class="section section--dark" id="special">
    <div class="container" style="text-align: center;">
      <span class="section-tag" data-animate="fade-up">Limited Offer</span>
      <h2 style="margin-block-end: var(--space-3);" data-animate="fade-up">New Student Special</h2>
      <div style="max-width: 500px; margin-inline: auto;" data-animate="fade-up">
        <div class="card pricing-highlight" style="background-color: rgba(245,240,232,0.06); border: 1.5px solid var(--color-gold); padding: var(--space-6); border-radius: var(--radius-lg); text-align: center;">
          <p style="font-size: var(--text-small); color: var(--color-gold); letter-spacing: 0.1em; text-transform: uppercase; margin-block-end: var(--space-2);">3 Introductory Private Sessions</p>
          <span class="price price--highlight" style="display: block; font-size: var(--text-hero); color: var(--color-gold);">$210</span>
          <p style="color: var(--color-text-inverse); margin-block: var(--space-2); font-size: var(--text-small);">New students only. Experience the fundamentals of connection through private instruction on authentic Gratz Pilates equipment.</p>
          <a href="sms:+18648845606?body=Hi%20Katie%2C%20I%27m%20interested%20in%20the%20New%20Student%20Special" class="btn btn--primary" data-magnetic style="margin-block-start: var(--space-3);">Book Your Introduction</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== HOW IT WORKS ==================== -->
  <section class="section section--cream" id="how-it-works">
    <div class="container">
      <div style="text-align: center; margin-block-end: var(--space-8);">
        <span class="section-tag" data-animate="fade-up">How to Begin</span>
        <h2 data-animate="fade-up">Your Journey Starts Here</h2>
      </div>

      <div class="process-timeline">
        <div class="timeline__line" aria-hidden="true"></div>
        <div class="timeline__line-progress" aria-hidden="true"></div>

        <div class="timeline__item">
          <div class="timeline__marker" aria-hidden="true"></div>
          <span class="timeline__step-number">Step 1</span>
          <h3 style="margin-block-end: var(--space-1);">Review Options</h3>
          <p style="color: var(--color-text-muted);">Explore our pricing and time-slot availability. The studio calendar books monthly and opens when recurring students cancel.</p>
        </div>

        <div class="timeline__item">
          <div class="timeline__marker" aria-hidden="true"></div>
          <span class="timeline__step-number">Step 2</span>
          <h3 style="margin-block-end: var(--space-1);">Text Katie</h3>
          <p style="color: var(--color-text-muted);">Reach out to Katie at <a href="sms:+18648845606">(864) 884-5606</a> for this month's available openings and reserve your time-slot.</p>
        </div>

        <div class="timeline__item">
          <div class="timeline__marker" aria-hidden="true"></div>
          <span class="timeline__step-number">Step 3</span>
          <h3 style="margin-block-end: var(--space-1);">Arrive &amp; Begin</h3>
          <p style="color: var(--color-text-muted);">Arrive 10 minutes early to your first appointment to complete paperwork and payment. Then step through our French doors into the light-filled studio.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== ABOUT / WHY INDIGO ==================== -->
  <section class="section section--alt" id="why-indigo">
    <div class="container">
      <div class="grid-asymmetric" style="align-items: center;">
        <div data-animate="fade-right">
          <span class="section-tag">Our Space</span>
          <h2 style="margin-block-end: var(--space-3);">A Space Unlike Any Other</h2>
          <p style="color: var(--color-text-muted); margin-block-end: var(--space-3);">
            Pilates registration is located in the vibrant gallery of local artist and co-owner Julie Hughes, at 1272 Pendleton Street. Following check-in, walk through our old French doors into the beautiful, light-filled Pilates room where a fully equipped Gratz Pilates studio awaits.
          </p>
          <div style="display: grid; gap: var(--space-3); margin-block-start: var(--space-4);">
            <div style="display: flex; gap: var(--space-2); align-items: flex-start;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" style="flex-shrink: 0; margin-block-start: 2px;"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg>
              <div>
                <strong>Certified Classical Method</strong>
                <p style="font-size: var(--text-small); color: var(--color-text-muted);">Power Pilates certified, preserving Joseph Pilates' original Contrology system</p>
              </div>
            </div>
            <div style="display: flex; gap: var(--space-2); align-items: flex-start;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" style="flex-shrink: 0; margin-block-start: 2px;"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg>
              <div>
                <strong>Authentic Gratz Equipment</strong>
                <p style="font-size: var(--text-small); color: var(--color-text-muted);">The gold standard in Pilates apparatus, hand-built in the USA</p>
              </div>
            </div>
            <div style="display: flex; gap: var(--space-2); align-items: flex-start;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" style="flex-shrink: 0; margin-block-start: 2px;"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg>
              <div>
                <strong>Art-Filled Environment</strong>
                <p style="font-size: var(--text-small); color: var(--color-text-muted);">Practice surrounded by original fine art in a converted gallery space</p>
              </div>
            </div>
          </div>
        </div>
        <div class="img-frame" data-animate="fade-left">
          <img
            src="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/1590883589936-SE3E8XFLOZB780E1QNQL/IMG_3775.jpg"
            alt="Interior of Indigo Flow and Art studio and gallery space"
            width="800" height="600"
            loading="lazy" decoding="async"
            style="border-radius: var(--radius-lg); aspect-ratio: 4/3; object-fit: cover;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== TESTIMONIALS (placeholder — no real testimonials in source data) ==================== -->
  <section class="section section--cream" id="testimonials">
    <div class="container" style="text-align: center;">
      <span class="section-tag" data-animate="fade-up">Testimonials</span>
      <h2 data-animate="fade-up" style="margin-block-end: var(--space-3);">What Our Students Say</h2>
      <p style="color: var(--color-text-muted); max-width: 45ch; margin-inline: auto; margin-block-end: var(--space-4);" data-animate="fade-up">
        Student testimonials coming soon. In the meantime, experience the studio for yourself.
      </p>
      <a href="/classical-pilates#pricing" class="btn btn--secondary" data-animate="fade-up">View the New Student Special</a>
    </div>
  </section>

  <!-- ==================== CTA — FULL WIDTH ==================== -->
  <section style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); padding-block: var(--space-12); text-align: center;">
    <div class="container" data-animate="fade-up">
      <h2 style="color: var(--color-cream); margin-block-end: var(--space-2);">Ready to Begin Your Practice?</h2>
      <p style="color: var(--color-text-inverse); max-width: 50ch; margin-inline: auto; margin-block-end: var(--space-4); opacity: 0.85;">
        Whether you seek the discipline of Classical Pilates or the inspiration of fine art, your journey starts with a single step through our doors.
      </p>
      <div style="display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
        <a href="sms:+18648845606?body=Hi%20Katie%2C%20I%27d%20like%20to%20book%20a%20Pilates%20session" class="btn btn--primary btn--large" data-magnetic>Text Katie to Book</a>
        <a href="/contact" class="btn btn--ghost" style="color: var(--color-cream); border-color: var(--color-gold);">Get in Touch &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ==================== MAP / LOCATION ==================== -->
  <section class="section section--alt" id="location">
    <div class="container">
      <div class="grid-asymmetric" style="align-items: center;">
        <div data-animate="fade-right">
          <span class="section-tag">Visit Us</span>
          <h2 style="margin-block-end: var(--space-3);">The Village of West Greenville</h2>
          <p style="color: var(--color-text-muted); margin-block-end: var(--space-4);">
            Located at 1272 Pendleton Street in Greenville's vibrant arts district. Open by appointment for both Pilates sessions and gallery viewings.
          </p>
          <div style="display: grid; gap: var(--space-3);">
            <div style="display: flex; gap: var(--space-2); align-items: center;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>1272 Pendleton Street, Greenville, SC 29611</span>
            </div>
            <div style="display: flex; gap: var(--space-2); align-items: center;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              <span>Pilates: <a href="sms:+18648845606">(864) 884-5606</a> &middot; Gallery: <a href="sms:+18648845607">(864) 884-5607</a> <em style="font-size: var(--text-caption); opacity: 0.7;">(text only)</em></span>
            </div>
            <div style="display: flex; gap: var(--space-2); align-items: center;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              <span>Mon&ndash;Thu: 7:15am&ndash;11:15am &middot; Gallery: By Appointment</span>
            </div>
          </div>
        </div>
        <div data-animate="fade-left" style="border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-card);">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3281.1!2d-82.42!3d34.85!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s1272+Pendleton+St+Greenville+SC+29611!5e0!3m2!1sen!2sus!4v1"
            width="100%" height="350"
            style="border: 0; display: block;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Map to Indigo Flow and Art"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
