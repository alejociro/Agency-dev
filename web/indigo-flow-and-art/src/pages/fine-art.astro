---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Fine Art Gallery | Indigo Flow and Art — Greenville SC"
  description="Explore the fine art of Julie Hughes at Indigo Art Gallery in West Greenville. Original works capturing motion, speed, and the ephemeral beauty of everyday moments. Visit by appointment or First Friday Art Crawl."
  canonical="/fine-art"
  currentPage="fine-art"
>

  <!-- ==================== HERO ==================== -->
  <section class="section--dark" style="position: relative; min-height: 70vh; display: flex; align-items: center; overflow: hidden;">
    <img
      src="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/c03de3e3-6c71-463e-b152-a2b8afc7e144/0216.ubj.firstlook.indigoyogastudio.7.williamcrooks.jpg"
      alt="Interior of Indigo Art Gallery with original fine art"
      width="1920" height="1080"
      loading="eager" decoding="async"
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.35;"
    />
    <div style="position: absolute; inset: 0; background: linear-gradient(to right, rgba(30,38,56,0.9) 0%, rgba(30,38,56,0.5) 100%);"></div>
    <div class="container" style="position: relative; z-index: 2; padding-block: var(--space-16) var(--space-8);">
      <span class="hero-tag section-tag" style="color: var(--color-gold);">Indigo Art Gallery</span>
      <h1 class="hero-title" style="color: var(--color-cream); max-width: 14ch;" data-split>Fine Art</h1>
      <p class="hero-sub" style="color: var(--color-text-inverse); max-width: 50ch; margin-block-end: var(--space-4); opacity: 0.9;">
        Original works capturing the essence, power, and movement of life — viewed through a surreal lens.
      </p>
      <a href="#gallery" class="btn btn--primary btn--large hero-cta" data-magnetic>View the Collection</a>
    </div>
  </section>

  <!-- ==================== ARTIST STATEMENT ==================== -->
  <section class="section section--cream">
    <div class="container">
      <div class="grid-asymmetric--reverse" style="align-items: center;">
        <div class="img-frame" data-animate="fade-right">
          <img
            src="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/2d5e49a2-3b49-46f2-9bce-3a26f978ccdb/mom+art+original.JPG"
            alt="Julie Hughes, fine artist and co-owner of Indigo Art"
            width="800" height="1000"
            loading="lazy" decoding="async"
            style="border-radius: var(--radius-lg); aspect-ratio: 4/5; object-fit: cover;"
          />
        </div>
        <div data-animate="fade-left">
          <span class="section-tag">The Artist</span>
          <h2 style="margin-block-end: var(--space-3);">Julie Hughes</h2>
          <blockquote style="font-family: var(--font-display); font-size: var(--text-h3); font-style: italic; color: var(--color-primary); line-height: var(--leading-snug); margin-block-end: var(--space-4); padding-inline-start: var(--space-3); border-inline-start: 2px solid var(--color-accent);">
            "Through my work, I strive to combine the every-day with the ephemeral. To capture real moments that are viewed from a surreal lens."
          </blockquote>
          <p style="color: var(--color-text-muted); margin-block-end: var(--space-3);">
            My themes are not concerned with what the world should be, but rather with what the world is — while choosing to see reality with slight distortions.
          </p>
          <p style="color: var(--color-text-muted);">
            I strive to communicate the essence, power, and movement of a scene or a person. My recent works are all about motion, specifically motion as we see it in the art of bicycle racing. Speed, motion, and gravity-defying angles — and how such intangible things can be put on canvas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== GALLERY ==================== -->
  <section class="section section--dark" id="gallery">
    <div class="container">
      <div style="text-align: center; margin-block-end: var(--space-8);">
        <span class="section-tag" data-animate="fade-up">Collection</span>
        <h2 data-animate="fade-up">Selected Works</h2>
      </div>

      <!-- Gallery Tour component -->
      <div class="gallery-tour" style="aspect-ratio: 16/10; max-height: 550px;" data-animate="scale-in">
        <div class="gallery-tour__slide active">
          <img
            src="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/1590769141691-7TO0ASKD4227B2TP5988/_MG_9679.jpg"
            alt="Fine art painting by Julie Hughes — motion and movement study"
            width="900" height="600"
            loading="lazy" decoding="async"
            data-lightbox="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/1590769141691-7TO0ASKD4227B2TP5988/_MG_9679.jpg"
            data-lightbox-alt="Fine art painting by Julie Hughes — motion and movement study"
          />
        </div>
        <div class="gallery-tour__slide">
          <img
            src="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/c03de3e3-6c71-463e-b152-a2b8afc7e144/0216.ubj.firstlook.indigoyogastudio.7.williamcrooks.jpg"
            alt="Indigo Art Gallery interior with original paintings on display"
            width="900" height="600"
            loading="lazy" decoding="async"
            data-lightbox="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/c03de3e3-6c71-463e-b152-a2b8afc7e144/0216.ubj.firstlook.indigoyogastudio.7.williamcrooks.jpg"
            data-lightbox-alt="Indigo Art Gallery interior with original paintings on display"
          />
        </div>
        <div class="gallery-tour__slide">
          <img
            src="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/050af7b3-0fc6-4a5a-99ee-7ef3db93bb3b/IndigoFlowArt-31.jpg"
            alt="The art-filled studio space at Indigo Flow and Art"
            width="900" height="600"
            loading="lazy" decoding="async"
            data-lightbox="https://images.squarespace-cdn.com/content/v1/5e94ce23cb52f15bc6719b3b/050af7b3-0fc6-4a5a-99ee-7ef3db93bb3b/IndigoFlowArt-31.jpg"
            data-lightbox-alt="The art-filled studio space at Indigo Flow and Art"
          />
        </div>

        <button class="gallery-tour__nav gallery-tour__prev" aria-label="Previous artwork">&larr;</button>
        <button class="gallery-tour__nav gallery-tour__next" aria-label="Next artwork">&rarr;</button>
        <div class="gallery-tour__dots"></div>
      </div>

      <p style="text-align: center; color: var(--color-text-muted); font-size: var(--text-small); margin-block-start: var(--space-3);">
        Click on any image to view full size. Use arrow keys to navigate.
      </p>
    </div>
  </section>

  <!-- ==================== GALLERY HOURS ==================== -->
  <section class="section section--cream">
    <div class="container" style="text-align: center;">
      <span class="section-tag" data-animate="fade-up">Visit the Gallery</span>
      <h2 data-animate="fade-up" style="margin-block-end: var(--space-6);">Gallery Hours</h2>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: var(--space-4); max-width: 700px; margin-inline: auto;" data-animate="stagger">
        <div class="card" style="padding: var(--space-4); text-align: center;">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" style="margin-inline: auto; margin-block-end: var(--space-2);">
            <rect x="4" y="6" width="32" height="30" rx="4" stroke="var(--color-secondary)" stroke-width="1.5"/>
            <path d="M4 14h32" stroke="var(--color-secondary)" stroke-width="1.5"/>
            <path d="M14 2v6M26 2v6" stroke="var(--color-accent)" stroke-width="1.5"/>
          </svg>
          <h3 style="font-size: var(--text-body); margin-block-end: var(--space-1);">Weekly Hours</h3>
          <p style="color: var(--color-text-muted); font-size: var(--text-small);">Monday &ndash; Sunday<br/><strong>By Appointment</strong></p>
          <a href="sms:+18648845607?body=Hi%20Julie%2C%20I%27d%20like%20to%20schedule%20a%20gallery%20viewing" class="btn btn--secondary" style="margin-block-start: var(--space-3); font-size: var(--text-caption);">Text Julie to Schedule</a>
        </div>

        <div class="card" style="padding: var(--space-4); text-align: center;">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" style="margin-inline: auto; margin-block-end: var(--space-2);">
            <circle cx="20" cy="20" r="16" stroke="var(--color-secondary)" stroke-width="1.5"/>
            <path d="M20 10v10l6 4" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <h3 style="font-size: var(--text-body); margin-block-end: var(--space-1);">Special Events</h3>
          <p style="color: var(--color-text-muted); font-size: var(--text-small);">
            <strong>First Friday Art Crawl</strong><br/>6:00 &ndash; 9:00 PM monthly
          </p>
          <p style="color: var(--color-text-muted); font-size: var(--text-small); margin-block-start: var(--space-1);">
            <strong>Annual Open Studio Tour</strong><br/>November, Sat 10am&ndash;6pm &amp; Sun 12pm&ndash;6pm
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); padding-block: var(--space-12); text-align: center;">
    <div class="container" data-animate="fade-up">
      <h2 style="color: var(--color-cream); margin-block-end: var(--space-2);">Interested in a Piece?</h2>
      <p style="color: var(--color-text-inverse); max-width: 50ch; margin-inline: auto; margin-block-end: var(--space-4); opacity: 0.85;">
        Schedule a private viewing to experience the works in person. All inquiries about pricing and commissions are welcome.
      </p>
      <div style="display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
        <a href="sms:+18648845607?body=Hi%20Julie%2C%20I%27m%20interested%20in%20a%20piece%20from%20the%20gallery" class="btn btn--primary btn--large" data-magnetic>Schedule a Viewing</a>
        <a href="/contact" class="btn btn--ghost" style="color: var(--color-cream); border-color: var(--color-gold);">Contact Us &rarr;</a>
      </div>
    </div>
  </section>

</BaseLayout>
