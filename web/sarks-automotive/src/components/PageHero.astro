---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  badgeIcon?: boolean;
}

const { badge, title, subtitle, badgeIcon = false } = Astro.props;
---

<section class="page-hero section-dark grain mesh-bg">
  <div class="container">
    {badge && (
      <span class="hero-tag badge">
        {badgeIcon && (
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
        )}
        {badge}
      </span>
    )}
    <h1 class="hero-title page-title" set:html={title} />
    {subtitle && <p class="hero-sub">{subtitle}</p>}
  </div>
</section>

<style>
  .page-hero {
    padding-block: 10rem 5rem;
    text-align: center;
  }

  .hero-title {
    font-size: var(--text-h1);
    margin-block: var(--space-3);
  }

  .hero-sub {
    max-width: 50ch;
    margin-inline: auto;
    color: var(--color-text-muted);
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    line-height: var(--leading-body);
  }
</style>
