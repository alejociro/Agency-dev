---
/* BRIEF CREATIVO
   Negocio    : Sarks Automotive
   Sector     : Auto Repair
   Tono       : industrial premium
   Concepto   : "The Purple Standard" — maestría certificada con identidad púrpura-dorada
   Diferenciador visual: Hero split-screen diagonal con duotono púrpura y certificaciones doradas
   Tipografía : Clash Display + Satoshi
   Mood       : oscuro · dorado · certificado
   Paleta base: #5D3F6A · #E2B13C · #1A1225 · #F5F0EB · #2D1F3D
*/
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  { id: "brakes", name: "Brake Repair", icon: "disc", desc: "Complete brake inspection, pad replacement, rotor resurfacing and fluid flush for safe stopping power." },
  { id: "diagnostics", name: "Diagnostics", icon: "scan", desc: "Advanced computer diagnostics to pinpoint issues fast. Check engine lights decoded and resolved." },
  { id: "oil-changes", name: "Oil Changes", icon: "droplet", desc: "Conventional, synthetic blend and full synthetic oil changes with multi-point inspection included." },
  { id: "tires", name: "Tire Services", icon: "circle", desc: "Tire rotation, balancing, alignment and replacement. We work with all major tire brands." },
  { id: "ac", name: "AC Repair", icon: "snowflake", desc: "AC diagnostics, refrigerant recharge, compressor repair and full system restoration." },
  { id: "transmission", name: "Transmission", icon: "cog", desc: "Transmission fluid service, diagnostics and repair for automatic and manual transmissions." },
  { id: "battery", name: "Battery Service", icon: "zap", desc: "Battery testing, replacement and charging system diagnostics to keep you starting reliably." },
  { id: "exhaust", name: "Exhaust & Muffler", icon: "wind", desc: "Muffler repair, exhaust leak fixes, catalytic converter service and emissions solutions." }
];

const testimonials = [
  { name: "Marcus T.", rating: 5, text: "Been bringing both my trucks here for two years. They diagnosed an electrical issue in 30 minutes that another shop spent a full day on. Honest pricing and they explain everything before doing the work.", location: "Greenville, SC" },
  { name: "Jennifer R.", rating: 5, text: "The warranty alone sets them apart. Had a part fail 8 months after repair and they replaced it at no charge. That kind of integrity is rare. My whole family goes to Sarks now.", location: "Mauldin, SC" },
  { name: "David K.", rating: 5, text: "Triple-certified and it shows. They caught a suspension issue during a routine oil change that could have been dangerous. Saved me money and kept my family safe.", location: "Simpsonville, SC" }
];

const blogPosts = [
  { title: "5 Essential Auto Repair Tips For Busy Families", date: "March 30, 2026", excerpt: "Keeping your family vehicle reliable does not have to be overwhelming. Here are five maintenance habits that prevent costly breakdowns." },
  { title: "10 Ways Regular Vehicle Maintenance Can Save You from Costly Repairs", date: "February 4, 2026", excerpt: "A small investment in regular maintenance protects you from expensive emergency repairs down the road." },
  { title: "Warning Signs Your Car Needs Immediate Attention", date: "December 6, 2025", excerpt: "Strange noises, dashboard lights, and performance changes you should never ignore." }
];
---

<BaseLayout title="Expert Auto Repair in Mauldin & Greenville SC">

  <!-- ════════════ HERO ════════════ -->
  <section id="home" data-label="Home" class="hero section-dark grain mesh-bg">
    <div class="container hero-content">
      <span class="hero-tag badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
        Triple-Certified Auto Repair
      </span>

      <h1 class="hero-title">
        The <span class="text-gradient-gold">Standard</span><br />
        in Auto Care
      </h1>

      <p class="hero-sub">
        ASE, IMACA & RepairPal certified technicians with 50+ years of combined experience.
        Every repair backed by our <strong>12-month / 12,000-mile warranty</strong>.
      </p>

      <div class="hero-cta">
        <a href="/contact/" class="btn btn-primary" data-magnetic>Get Your Free Estimate</a>
        <a href="/services/" class="btn btn-ghost">View All Services
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="hero-proof">
        <div class="hero-certs" data-animate="stagger">
          <span class="cert-badge cert-animate">ASE Certified</span>
          <span class="cert-badge cert-animate">IMACA Member</span>
          <span class="cert-badge cert-animate">RepairPal Certified</span>
        </div>
      </div>
    </div>

    <!-- Hero background image with duotone overlay -->
    <div class="hero-bg-image hero-parallax" aria-hidden="true">
      <img src="https://le-cdn.hibuwebsites.com/7610d4966731467fa1cef0b6adfbe67a/dms3rep/multi/opt/RSshutterstock_124885084-1920w.jpg" alt="" width="1920" height="1080" decoding="async" fetchpriority="high" />
    </div>

    <!-- Diagonal clip overlay -->
    <div class="hero-diagonal" aria-hidden="true"></div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator" aria-hidden="true">
      <span class="scroll-text">Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ════════════ SOCIAL PROOF BAR ════════════ -->
  <section class="proof-bar section-deep" data-animate="fade-up">
    <div class="container">
      <div class="proof-stats">
        <div class="proof-stat" data-stat>
          <span class="stat-number" data-counter="50" data-suffix="+">0</span>
          <span class="stat-label">Years Combined Experience</span>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-stat" data-stat>
          <span class="stat-number" data-counter="2">0</span>
          <span class="stat-label">Convenient Locations</span>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-stat" data-stat>
          <span class="stat-number" data-counter="3">0</span>
          <span class="stat-label">Industry Certifications</span>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-stat" data-stat>
          <span class="stat-number" data-counter="12" data-suffix="mo">0</span>
          <span class="stat-label">Warranty on All Repairs</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════ SERVICES ════════════ -->
  <section id="services" data-label="Services" class="section-light section-padding">
    <div class="container">
      <div class="section-header" data-animate="fade-up">
        <span class="section-tag">What We Do</span>
        <h2>Expert Care for <span class="text-gradient-purple">Every System</span></h2>
        <p class="section-intro">From routine oil changes to complex transmission repairs, our certified technicians handle it all with precision and transparency.</p>
      </div>

      <div class="grid-services" data-animate="stagger">
        {services.map((service) => (
          <a href={`/services/#${service.id}`} class="service-card card">
            <div class="service-icon" aria-hidden="true">
              {service.icon === "disc" && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/></svg>}
              {service.icon === "scan" && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M3 7V5a2 2 0 012-2h2M17 3h2a2 2 0 012 2v2M21 17v2a2 2 0 01-2 2h-2M7 21H5a2 2 0 01-2-2v-2"/><line x1="7" y1="12" x2="17" y2="12"/></svg>}
              {service.icon === "droplet" && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>}
              {service.icon === "circle" && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>}
              {service.icon === "snowflake" && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><line x1="12" y1="2" x2="12" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/><line x1="19.07" y1="4.93" x2="4.93" y2="19.07"/></svg>}
              {service.icon === "cog" && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>}
              {service.icon === "zap" && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
              {service.icon === "wind" && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M9.59 4.59A2 2 0 1111 8H2m10.59 11.41A2 2 0 1014 16H2m15.73-8.27A2.5 2.5 0 1119.5 12H2"/></svg>}
            </div>
            <h3 class="service-name">{service.name}</h3>
            <p class="service-desc">{service.desc}</p>
            <span class="service-arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="services-cta" data-animate="fade-up">
        <a href="/services/" class="btn btn-outline">View All Services
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════ WARRANTY BANNER ════════════ -->
  <section class="warranty-section full-bleed clip-diagonal section-dark grain" data-animate="scale-in">
    <div class="container warranty-inner">
      <div class="warranty-content">
        <span class="section-tag">Our Promise</span>
        <h2>Every Repair. <span class="shimmer-gold">Guaranteed.</span></h2>
        <p>We stand behind our work with a <strong>12-month / 12,000-mile parts and labor warranty</strong> on every repair. Because confidence in your mechanic should never be optional.</p>
        <a href="/contact/" class="btn btn-primary" data-magnetic>Schedule Your Repair</a>
      </div>
      <div class="warranty-badges">
        <div class="warranty-shield warranty-pulse">
          <span class="warranty-number">12</span>
          <span class="warranty-label">Month</span>
        </div>
        <div class="warranty-shield warranty-pulse" style="animation-delay: 0.3s;">
          <span class="warranty-number">12K</span>
          <span class="warranty-label">Mile</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════ PROCESS ════════════ -->
  <section id="process" data-label="Process" class="section-deep section-padding">
    <div class="container">
      <div class="section-header" data-animate="fade-up">
        <span class="section-tag">How It Works</span>
        <h2>Simple. Transparent. <span class="text-gradient-gold">Done Right.</span></h2>
        <p class="section-intro">From the moment you walk in to the moment you drive away, every step is designed for your confidence and convenience.</p>
      </div>

      <div class="timeline-container" data-timeline data-animate="fade-up">
        <svg class="timeline-line-bg" aria-hidden="true" width="2" height="100%" preserveAspectRatio="none">
          <line x1="1" y1="0" x2="1" y2="100%" stroke="oklch(1 0 0 / 0.1)" stroke-width="2"/>
        </svg>
        <svg class="timeline-line-progress" aria-hidden="true" width="2" height="100%" preserveAspectRatio="none">
          <line x1="1" y1="0" x2="1" y2="100%" stroke="var(--color-secondary)" stroke-width="2"/>
        </svg>

        <div class="timeline-step">
          <div class="timeline-dot"></div>
          <span class="timeline-step-number">Step 01</span>
          <h3>Free Estimate</h3>
          <p>Call or visit either location. We provide same-day estimates with a full explanation of what your vehicle needs and why.</p>
        </div>

        <div class="timeline-step">
          <div class="timeline-dot"></div>
          <span class="timeline-step-number">Step 02</span>
          <h3>Expert Diagnosis</h3>
          <p>Our ASE-certified technicians use advanced diagnostics to pinpoint the exact issue. No guesswork, no unnecessary repairs.</p>
        </div>

        <div class="timeline-step">
          <div class="timeline-dot"></div>
          <span class="timeline-step-number">Step 03</span>
          <h3>Transparent Repair</h3>
          <p>We walk you through the recommended repairs and pricing before any work begins. You approve everything upfront.</p>
        </div>

        <div class="timeline-step">
          <div class="timeline-dot"></div>
          <span class="timeline-step-number">Step 04</span>
          <h3>Quality Guarantee</h3>
          <p>Drive away with confidence. Every repair is backed by our 12-month/12,000-mile warranty on parts and labor.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════ WHY SARKS ════════════ -->
  <section id="why-us" data-label="Why Us" class="section-light section-padding">
    <div class="container">
      <div class="grid-asymmetric">
        <div data-animate="fade-right">
          <span class="section-tag">Why Sarks</span>
          <h2>Not Just Another <span class="text-gradient-purple">Auto Shop</span></h2>
          <p style="margin-block-end: var(--space-4);">Most shops fix cars. We build trust. Our triple certification is not just a badge on the wall; it is a standard that guides every repair, every interaction, every warranty we honor.</p>

          <div class="why-features">
            <div class="why-feature">
              <div class="why-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h4>Triple Certified</h4>
                <p>ASE, IMACA, and RepairPal certifications mean our technicians meet the highest industry standards.</p>
              </div>
            </div>

            <div class="why-feature">
              <div class="why-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
              </div>
              <div>
                <h4>Warranty You Can Trust</h4>
                <p>12-month / 12,000-mile warranty on all parts and labor. If something is not right, we make it right.</p>
              </div>
            </div>

            <div class="why-feature">
              <div class="why-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
              </div>
              <div>
                <h4>50+ Years Experience</h4>
                <p>Our team brings over half a century of combined automotive expertise to every vehicle we touch.</p>
              </div>
            </div>

            <div class="why-feature">
              <div class="why-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <h4>Two Convenient Locations</h4>
                <p>Serving Mauldin and Greenville, SC. Same quality, same warranty, closer to you.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="why-visual" data-animate="fade-left">
          <div class="why-image-stack">
            <div class="why-img-main img-zoom">
              <img src="https://le-cdn.hibuwebsites.com/7610d4966731467fa1cef0b6adfbe67a/dms3rep/multi/opt/sarks-automotive-content-home-1920w.jpg" alt="Sarks Automotive certified technicians working on a vehicle in Greenville SC" width="600" height="400" loading="lazy" decoding="async" />
            </div>
            <div class="why-img-accent">
              <div class="stat-block" data-stat>
                <span class="stat-number" data-counter="2013">0</span>
                <span class="stat-label">Serving SC Since</span>
                <span class="stat-context" data-text="Building lasting relationships in the Upstate">Building lasting relationships in the Upstate</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════ TESTIMONIALS ════════════ -->
  <section id="reviews" data-label="Reviews" class="section-dark section-padding grain">
    <div class="container">
      <div class="section-header" data-animate="fade-up">
        <span class="section-tag" style="color: var(--color-secondary);">Reviews</span>
        <h2>What Our <span class="text-gradient-gold">Customers Say</span></h2>
      </div>

      <div class="testimonials-track" data-animate="fade-up">
        {testimonials.map((t) => (
          <div class="testimonial-card card-dark">
            <div class="testimonial-rating" aria-label={`${t.rating} out of 5 stars`}>
              {Array.from({length: t.rating}).map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="testimonial-text">{t.text}</blockquote>
            <div class="testimonial-author">
              <div class="author-avatar" aria-hidden="true">{t.name[0]}</div>
              <div>
                <span class="author-name">{t.name}</span>
                <span class="author-location">{t.location}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="reviews-disclaimer" data-animate="fade">Reviews shown are illustrative of the customer experience at Sarks Automotive. See our verified reviews on RepairPal and Google.</p>
    </div>
  </section>

  <!-- ════════════ CTA FULL WIDTH ════════════ -->
  <section class="cta-full">
    <div class="container cta-full-inner" data-animate="scale-in">
      <h2>Your Car Deserves <span class="shimmer-gold">Better</span></h2>
      <p>Stop settling for shops that guess. Get certified expertise, transparent pricing, and a warranty that means something.</p>
      <div class="cta-full-buttons">
        <a href="tel:+18642104866" class="btn btn-primary" data-magnetic>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          Call (864) 210-4866
        </a>
        <a href="/contact/" class="btn btn-ghost">Book Online</a>
      </div>
    </div>
  </section>

  <!-- ════════════ BLOG PREVIEW ════════════ -->
  <section id="blog" data-label="Blog" class="section-light section-padding">
    <div class="container">
      <div class="section-header" data-animate="fade-up">
        <span class="section-tag">From Our Blog</span>
        <h2>Auto Care <span class="text-gradient-purple">Insights</span></h2>
      </div>

      <div class="grid-features" data-animate="stagger">
        {blogPosts.map((post) => (
          <article class="blog-card card">
            <div class="blog-card-content">
              <time class="blog-date">{post.date}</time>
              <h3 class="blog-title">{post.title}</h3>
              <p class="blog-excerpt">{post.excerpt}</p>
              <span class="blog-link">
                Read More
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </article>
        ))}
      </div>

      <div class="services-cta" data-animate="fade-up">
        <a href="/blog/" class="btn btn-outline">View All Articles</a>
      </div>
    </div>
  </section>

  <!-- ════════════ LOCATIONS ════════════ -->
  <section id="locations" data-label="Locations" class="section-deep section-padding">
    <div class="container">
      <div class="section-header" data-animate="fade-up">
        <span class="section-tag" style="color: var(--color-secondary);">Find Us</span>
        <h2>Two Locations, <span class="text-gradient-gold">One Standard</span></h2>
      </div>

      <div class="grid-two-col" data-animate="stagger">
        <div class="location-card card-dark">
          <div class="location-pin pin-bounce" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/><circle cx="12" cy="10" r="3" fill="var(--color-bg-dark)"/></svg>
          </div>
          <h3>Mauldin</h3>
          <p class="location-address">Mauldin, SC</p>
          <a href="tel:+18642104866" class="btn btn-outline" style="margin-block-start: var(--space-2);">Call Mauldin Shop</a>
        </div>

        <div class="location-card card-dark">
          <div class="location-pin pin-bounce" style="animation-delay: 0.3s;" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/><circle cx="12" cy="10" r="3" fill="var(--color-bg-dark)"/></svg>
          </div>
          <h3>Greenville</h3>
