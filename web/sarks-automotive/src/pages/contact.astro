---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceOptions = [
  "Brake Service & Repair",
  "Auto Diagnostics",
  "Oil Change",
  "Tire Services",
  "AC Service & Repair",
  "Alternator & Starter",
  "Battery Replacement",
  "Radiator Services",
  "Check Engine Light",
  "Muffler & Exhaust",
  "Steering & Suspension",
  "Transmission & Engine",
  "Auto Detailing",
  "Other"
];
---

<BaseLayout title="Contact & Schedule Appointment" description="Schedule your auto repair appointment at Sarks Automotive. Two locations in Mauldin and Greenville SC. Call (864) 210-4866 or book online.">

  <!-- ════════════ PAGE HERO ════════════ -->
  <section class="page-hero section-dark grain mesh-bg">
    <div class="container">
      <span class="hero-tag badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
        Get In Touch
      </span>
      <h1 class="hero-title page-title">Schedule Your <span class="text-gradient-gold">Repair</span></h1>
      <p class="hero-sub">Same-day estimates available. Call us directly or fill out the form below and we will get back to you promptly.</p>
    </div>
  </section>

  <!-- ════════════ CONTACT GRID ════════════ -->
  <section class="section-dark section-padding">
    <div class="container">
      <div class="contact-grid">

        <!-- Contact Info -->
        <div class="contact-info" data-animate="fade-right">
          <h2>Quick <span class="text-gradient-gold">Contact</span></h2>

          <div class="contact-methods">
            <a href="tel:+18642104866" class="contact-method">
              <div class="contact-method-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <div>
                <span class="contact-method-label">Call Us</span>
                <span class="contact-method-value">(864) 210-4866</span>
              </div>
            </a>

            <a href="mailto:sarksautomotive@live.com" class="contact-method">
              <div class="contact-method-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
              </div>
              <div>
                <span class="contact-method-label">Email Us</span>
                <span class="contact-method-value">sarksautomotive@live.com</span>
              </div>
            </a>
          </div>

          <hr class="divider-subtle" style="margin-block: var(--space-4);" />

          <h3 style="margin-block-end: var(--space-3);">Our Locations</h3>

          <div class="location-cards-contact">
            <div class="location-mini">
              <div class="location-mini-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/><circle cx="12" cy="10" r="3" fill="var(--color-bg-dark)"/></svg>
              </div>
              <div>
                <strong>Mauldin, SC</strong>
                <p>Serving the Mauldin community</p>
              </div>
            </div>

            <div class="location-mini">
              <div class="location-mini-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="none" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/><circle cx="12" cy="10" r="3" fill="var(--color-bg-dark)"/></svg>
              </div>
              <div>
                <strong>Greenville, SC</strong>
                <p>Serving the Greenville community</p>
              </div>
            </div>
          </div>

          <hr class="divider-subtle" style="margin-block: var(--space-4);" />

          <div class="warranty-shield warranty-pulse" style="margin-block-start: var(--space-2);">
            <span class="warranty-number">12</span>
            <span class="warranty-label">Month Warranty</span>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-wrap glass" data-animate="fade-left">
          <h2>Request Your <span class="text-gradient-gold">Estimate</span></h2>
          <p style="color: var(--color-text-muted); margin-block: var(--space-2) var(--space-4); font-size: var(--text-small);">Fill out the form below and we will contact you within one business day with your free estimate.</p>

          <form class="contact-form" action="#" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="name">Full Name</label>
                <input class="form-input" type="text" id="name" name="name" placeholder="John Smith" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="phone">Phone Number</label>
                <input class="form-input" type="tel" id="phone" name="phone" placeholder="(864) 555-0123" required />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="email">Email Address</label>
              <input class="form-input" type="email" id="email" name="email" placeholder="john@example.com" required />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="service">Service Needed</label>
                <select class="form-input form-select" id="service" name="service" required>
                  <option value="" disabled selected>Select a service</option>
                  {serviceOptions.map((s) => (
                    <option value={s}>{s}</option>
                  ))}
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="location">Preferred Location</label>
                <select class="form-input form-select" id="location" name="location" required>
                  <option value="" disabled selected>Select location</option>
                  <option value="mauldin">Mauldin, SC</option>
                  <option value="greenville">Greenville, SC</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="message">Tell Us About Your Vehicle</label>
              <textarea class="form-input form-textarea" id="message" name="message" placeholder="Year, make, model, and what issue you are experiencing..." rows="4"></textarea>
            </div>

            <button type="submit" class="btn btn-primary form-submit" data-magnetic>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              Send Request
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Confirmation dialog -->
  <dialog id="confirm-dialog" class="confirm-dialog">
    <div class="dialog-content">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
      <h3>Request Sent!</h3>
      <p>Thank you for choosing Sarks Automotive. We will contact you within one business day with your free estimate.</p>
      <button class="btn btn-primary" onclick="document.getElementById('confirm-dialog').close()">Got It</button>
    </div>
  </dialog>

</BaseLayout>

<style>
  .page-hero {
    padding-block: 10rem 5rem;
    text-align: center;
  }

  .page-hero .hero-title { font-size: var(--text-h1); margin-block: var(--space-3); }
  .page-hero .hero-sub { max-width: 50ch; margin-inline: auto; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);

    @media (min-width: 768px) {
      grid-template-columns: 1fr 1.5fr;
      align-items: start;
    }
  }

  .contact-info h2 {
    margin-block-end: var(--space-4);
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact-method {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2);
    border-radius: var(--radius-md);
    transition: background 0.2s ease;
    min-height: 44px;

    &:hover {
      background: oklch(1 0 0 / 0.05);
    }
  }

  .contact-method-icon {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    background: oklch(0.78 0.15 85 / 0.08);
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .contact-method-label {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .contact-method-value {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--color-text-light);
  }

  .location-cards-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .location-mini {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2);
    background: var(--color-surface-dark);
    border-radius: var(--radius-md);
  }

  .location-mini-icon {
    flex-shrink: 0;
  }

  .location-mini strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text-light);
  }

  .location-mini p {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Form */
  .contact-form-wrap {
    padding: var(--space-6);
  }

  .contact-form-wrap h2 {
    margin-block-end: 0;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);

    @media (min-width: 480px) {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-submit {
    align-self: flex-start;
    margin-block-start: var(--space-2);
  }

  /* Dialog */
  .confirm-dialog {
    border: none;
    border-radius: var(--radius-lg);
    background: var(--color-bg-dark);
    color: var(--color-text-light);
    padding: var(--space-6);
    max-width: 400px;
    text-align: center;
    box-shadow: var(--shadow-lg);
  }

  .confirm-dialog::backdrop {
    background: oklch(0 0 0 / 0.7);
    backdrop-filter: blur(4px);
  }

  .dialog-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .dialog-content h3 { margin-block-start: var(--space-2); }
  .dialog-content p { color: var(--color-text-muted); font-size: var(--text-small); margin-block-end: var(--space-2); }
</style>

<script is:inline>
  const form = document.querySelector('.contact-form');
  const dialog = document.getElementById('confirm-dialog');

  if (form && dialog) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      dialog.showModal();
      form.reset();
    });
  }
</script>
