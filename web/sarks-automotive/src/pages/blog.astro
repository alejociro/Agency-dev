---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = [
  {
    title: "5 Essential Auto Repair Tips For Busy Families",
    date: "March 30, 2026",
    excerpt: "Keeping your family vehicle reliable does not have to be overwhelming. Here are five maintenance habits that prevent costly breakdowns and keep everyone safe on the road.",
    category: "Maintenance"
  },
  {
    title: "10 Ways Regular Vehicle Maintenance Can Save You from Costly Repairs",
    date: "February 4, 2026",
    excerpt: "A small investment in regular maintenance protects you from expensive emergency repairs down the road. Learn the ten maintenance items with the highest return on investment.",
    category: "Savings"
  },
  {
    title: "Warning Signs Your Car Needs Immediate Attention",
    date: "December 6, 2025",
    excerpt: "Strange noises, dashboard lights, and performance changes you should never ignore. Our ASE-certified technicians explain what each warning sign means and how urgently you should respond.",
    category: "Safety"
  },
  {
    title: "7 Smart Ways to Pick a Trustworthy Auto Repair Shop Near You",
    date: "October 2, 2025",
    excerpt: "Not all repair shops are created equal. Here is what to look for in certifications, warranties, pricing transparency, and customer reviews when choosing your mechanic.",
    category: "Guides"
  }
];
---

<BaseLayout title="Auto Care Blog & Tips" description="Expert auto maintenance tips and news from Sarks Automotive. Advice on brakes, oil changes, diagnostics and more from our ASE-certified technicians.">

  <!-- ════════════ PAGE HERO ════════════ -->
  <section class="page-hero section-dark grain mesh-bg">
    <div class="container">
      <span class="hero-tag badge">Expert Advice</span>
      <h1 class="hero-title page-title">Auto Care <span class="text-gradient-gold">Insights</span></h1>
      <p class="hero-sub">Maintenance tips, repair guides, and automotive news from our ASE-certified technicians.</p>
    </div>
  </section>

  <!-- ════════════ BLOG GRID ════════════ -->
  <section class="section-light section-padding">
    <div class="container blog-container">
      <div class="blog-grid" data-animate="stagger">
        {posts.map((post, i) => (
          <article class={`blog-post card ${i === 0 ? 'blog-post--featured' : ''}`}>
            <div class="blog-post-header">
              <span class="blog-category">{post.category}</span>
              <time class="blog-date">{post.date}</time>
            </div>
            <h2 class="blog-post-title">{post.title}</h2>
            <p class="blog-post-excerpt">{post.excerpt}</p>
            <span class="blog-read-more">
              Read Article
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </article>
        ))}
      </div>

      <!-- Newsletter CTA -->
      <div class="newsletter-cta card-dark" data-animate="fade-up" style="margin-block-start: var(--space-8);">
        <div class="newsletter-content">
          <h3>Stay in the <span class="text-gradient-gold">Know</span></h3>
          <p>Get maintenance reminders and exclusive tips from our certified technicians.</p>
        </div>
        <div class="newsletter-form-wrap">
          <form class="newsletter-form">
            <input type="email" placeholder="your@email.com" class="form-input" required aria-label="Email address" />
            <button type="submit" class="btn btn-primary">Subscribe</button>
          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    padding-block: 10rem 5rem;
    text-align: center;
  }

  .page-hero .hero-title { font-size: var(--text-h1); margin-block: var(--space-3); }
  .page-hero .hero-sub { max-width: 50ch; margin-inline: auto; }

  .blog-container { max-width: 900px; }

  .blog-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .blog-post {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .blog-post--featured {
    padding: var(--space-6);
    background: var(--color-bg-dark);
    color: var(--color-text-light);

    .blog-post-excerpt { color: var(--color-text-muted); }
    .blog-read-more { color: var(--color-secondary); }
    .blog-category { background: oklch(0.78 0.15 85 / 0.1); color: var(--color-secondary); }
  }

  .blog-post-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .blog-category {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    background: oklch(0.45 0.12 300 / 0.08);
    color: var(--color-primary);
    border-radius: var(--radius-full);
  }

  .blog-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .blog-post-title {
    font-size: var(--text-h3);
    line-height: var(--leading-snug);
  }

  .blog-post--featured .blog-post-title {
    font-size: var(--text-h2);
  }

  .blog-post-excerpt {
    font-size: var(--text-small);
    color: oklch(0.35 0.02 300);
    line-height: var(--leading-body);
  }

  .blog-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-primary);
    margin-block-start: auto;
    transition: gap 0.3s var(--ease-out-expo), color 0.2s ease;
  }

  .blog-post:hover .blog-read-more {
    gap: 0.75rem;
    color: var(--color-secondary);
  }

  /* Newsletter */
  .newsletter-cta {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: center;

    @media (min-width: 640px) {
      grid-template-columns: 1fr 1fr;
    }
  }

  .newsletter-content h3 { margin-block-end: 0.5rem; }
  .newsletter-content p { color: var(--color-text-muted); font-size: var(--text-small); }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;

    @media (max-width: 480px) {
      flex-direction: column;
    }
  }

  .newsletter-form .form-input {
    flex: 1;
  }

  .newsletter-form .btn {
    white-space: nowrap;
  }
</style>
